<!-- 颜色资源（可按需微调） -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#DCE6F2"/>
    <!-- 表头浅蓝灰 -->
    <SolidColorBrush x:Key="BorderLineBrush"     Color="#D6DEE8"/>
    <!-- 底部分隔线 -->
    <SolidColorBrush x:Key="RowBackgroundBrush"  Color="#FFFFFF"/>
    <!-- 行：奇数 -->
    <SolidColorBrush x:Key="RowAltBrush"         Color="#F7F9FC"/>
    <!-- 行：偶数 -->
    <SolidColorBrush x:Key="RowHoverBrush"       Color="#F0F6FF"/>
    <!-- 悬停 -->
    <!--<SolidColorBrush x:Key="RowSelectedBrush"    Color="#EAF2FE"/>-->
    <!-- 选中 -->
    <SolidColorBrush x:Key="TextBrush"           Color="#333842"/>
    <!-- 文本 -->
    <SolidColorBrush x:Key="RowHoverBrushEven" Color="#F6FAFF"/>
    <SolidColorBrush x:Key="RowHoverBrushOdd"  Color="#EEF6FF"/>
    <SolidColorBrush x:Key="RowSelectedBrush" Color="#3D7EFF"/>
    <SolidColorBrush x:Key="RowSelectedForeground" Color="White"/>

    <!-- —— 通用 DataGrid 样式：应用到所有 DataGrid —— -->
    <Style x:Key="FlatDataGrid" TargetType="DataGrid"
           BasedOn="{StaticResource DataGrid.Small}">
        <!-- 如无此基础样式可删掉整行 -->
        <!-- 通用属性 -->
        <Setter Property="Background" Value="{StaticResource DataGridBackgroundColor}"/>
        <Setter Property="AlternationCount" Value="2"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HorizontalGridLinesBrush" Value="Transparent"/>
        <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>

        <!-- 头部样式 -->
        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                    <Setter Property="Foreground" Value="#3A4150" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Margin" Value="0,0,0,5"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </Style>
            </Setter.Value>
        </Setter>

        <!-- 单元格样式：文字颜色跟随行；选中时透明以透出整行蓝色 -->
        <Setter Property="CellStyle">
            <Setter.Value>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground"
                            Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </MultiTrigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>

        <!-- 行样式：斑马纹；Hover 区分奇偶；选中=整行蓝底白字且无分隔线 -->
        <Setter Property="RowStyle">
            <Setter.Value>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                    <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="SnapsToDevicePixels" Value="True" />
                    <Style.Triggers>
                        <!-- 偶数行底色 -->
                        <Trigger Property="AlternationIndex" Value="1">
                            <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                        </Trigger>
                        <!-- Hover：按奇偶 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="AlternationIndex" Value="0"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{StaticResource RowHoverBrushEven}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="AlternationIndex" Value="1"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{StaticResource RowHoverBrushOdd}"/>
                        </MultiTrigger>
                        <!-- 选中：整行蓝底 + 白字，无分隔线 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{StaticResource RowSelectedBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource RowSelectedForeground}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{StaticResource RowSelectedBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource RowSelectedForeground}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </MultiTrigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

