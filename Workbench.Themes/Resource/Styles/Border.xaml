<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- TitleBarBorder -->
    <Style x:Key="TitleBarBorder" TargetType="Border">
        <Setter Property="Height" Value="30"/>
        <Setter Property="VerticalAlignment" Value="Center"/> 
        <Setter Property="CornerRadius" Value="8,8,0,0"/>

    </Style>

    <!-- FooterBorder -->
    <Style x:Key="FooterBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="0,0,8,8"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="{DynamicResource FooterBackgroundColor}"/>
    </Style>

    <!-- SeparatorBorder -->
    <Style x:Key="SeparatorBorder" TargetType="Border">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource BottomBarSeparatorColor}"/>
        <Setter Property="Margin" Value="15,0"/>
    </Style>

    <!-- Tag标签 -->
    <Style x:Key="TagStyle" TargetType="Border">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#a0cfff"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background" Value="#fff"/>
        <Setter Property="Padding" Value="10,3"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
    </Style>

    <!-- 垂直分割符 -->
    <Style x:Key="VerticalSeparatorStyle" TargetType="Border">
        <Setter Property="Height" Value="18"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background" Value="{DynamicResource PrimaryFontColor}"/>
        <Setter Property="Width" Value="1"/>
        <Setter Property="Margin" Value="8,0"/>
    </Style>

    <!-- 快速开始 -->
    <Style x:Key="QuickStartBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="TabContentBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="4,0,0,0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
</ResourceDictionary>