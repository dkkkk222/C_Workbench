    <SolidColorBrush x:Key="MainPageBackgroundColor" Color="Transparent"/>
    <!--标题栏底色-->
    <SolidColorBrush x:Key="TitleBarBackgroundColor" Color="#212531"/>
    <!-- 按钮栏文字 -->
    <SolidColorBrush x:Key="ButtonBarTextColor" Color="#0071BC"/>
    <!-- 首页按钮背景 -->
    <SolidColorBrush x:Key="FirstButtonTextBack" Color="#E5E5E5"/>
