    <SolidColorBrush x:Key="TabsNoSelectBackgroundColor" Color="#D7E2EC"/>
    <!--Tabs选中区域颜色-->
    <SolidColorBrush x:Key="TabsSelectBackgroundColor" Color="#E8EFF7"/>
