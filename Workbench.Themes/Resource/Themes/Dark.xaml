    <SolidColorBrush x:Key="TreeViewTitleBackgroundColor" Color="#ffffff"/>
    <!-- TreeView背景色 -->
    <SolidColorBrush x:Key="TreeViewBackgroundColor" Color="#313C4F"/>
    <!-- TreeViewItem选择背景色 -->
    <SolidColorBrush x:Key="TreeViewItemSelectedBackgroundColor" Color="#212531"/>
