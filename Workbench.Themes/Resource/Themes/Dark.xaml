    <SolidColorBrush x:Key="IndexPageFontBackground" Color="#315985"/>
    <!--DataGrid-->
    <SolidColorBrush x:Key="DataGridBackgroundColor" Color="#C7D6E3"/>
    <SolidColorBrush x:Key="DataGridHeadBackgroundColor" Color="#A8BDD2"/>
    <SolidColorBrush x:Key="DataGridRowBackgroundColor" Color="#CBD9E6"/>
    <SolidColorBrush x:Key="DataGridRowAltBackgroundColor" Color="#F0F7FF"/>
    <SolidColorBrush x:Key="DataGridSelectRowFontBackgroundColor" Color="#FFF"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#DCE6F2"/>
