<prism:PrismApplication x:Class="Workbench.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="pack://application:,,,/Workbench.Themes;component/Resource/Themes/Light.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Workbench.Themes;component/Resource/Styles/Controls.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Workbench;component/Resource/Styles/AvalonDock.xaml"/>
