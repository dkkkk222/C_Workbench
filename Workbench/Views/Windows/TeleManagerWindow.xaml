<comCtrl:NoTitleBarWindow x:Class="Workbench.Views.Windows.TeleManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Workbench.Views.Windows"
        mc:Ignorable="d"
        xmlns:comCtrl="clr-namespace:Common.Controls;assembly=Workbench.Controls"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DefaulClientWindow}"
        Title="TeleManagerWindow" Height="480" Width="780">
    <comCtrl:NoTitleBarWindow.TitleBarContent>
        <comCtrl:TitleBar Background="{DynamicResource TitleBarBordBackgroundColor}">
            <comCtrl:TitleBar.Title>
                <TextBlock Text="遥控指令管理"  Foreground="{DynamicResource TreeViewTitleBackgroundColor}"  Style="{DynamicResource TitleBarStyle}"/>
            </comCtrl:TitleBar.Title>
        </comCtrl:TitleBar>
    </comCtrl:NoTitleBarWindow.TitleBarContent>

</comCtrl:NoTitleBarWindow>
