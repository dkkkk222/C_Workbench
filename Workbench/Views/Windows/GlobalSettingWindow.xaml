<comCtrl:NoTitleBarWindow x:Class="Workbench.Views.Windows.GlobalSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Workbench.Views.Windows"
        xmlns:comCtrl="clr-namespace:Common.Controls;assembly=Workbench.Controls"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Normal"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DefaulClientWindow}"
        Height="586" Width="960">
    <comCtrl:NoTitleBarWindow.TitleBarContent>
        <comCtrl:TitleBar ShowMaximize="False" ShowMinimize="False">
            <comCtrl:TitleBar.Title>
                <TextBlock Text="全局设置" Style="{DynamicResource TitleBarStyle}"/>
            </comCtrl:TitleBar.Title>
        </comCtrl:TitleBar>
    </comCtrl:NoTitleBarWindow.TitleBarContent>

</comCtrl:NoTitleBarWindow>
