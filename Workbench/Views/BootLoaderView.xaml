<UserControl x:Class="Workbench.Views.BootLoaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:converters="clr-namespace:Workbench.Utils.ConverterUtil"
             xmlns:enums="clr-namespace:Workbench.Models.Enums"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <Style x:Key="ComboboxTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Width" Value="90"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleBarColor}"/>
        </Style>
        <Style x:Key="ccb" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource CommonComboBoxStyle}">
            <Setter Property="Height" Value="25"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid Background="{DynamicResource TreeViewBackgroundColor}">
        <Border Padding="20,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border>
                            <StackPanel>
                                <Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="升级协议：" Style="{DynamicResource ComboboxTitle}"/>
                                        <ComboBox ItemsSource="{Binding ComConnectTypes}"
                                                  Height="25"
                                                  SelectedIndex="{Binding BBLLCConnectTypeListIndex,Mode=TwoWay}"
                                                  IsEnabled="{calc:Binding !IsConnect}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Value"/>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="端口：" Style="{DynamicResource ComboboxTitle}"/>
                                        <ComboBox ItemsSource="{Binding PortList}"
                                                  Height="25"
                                                  IsEnabled="{calc:Binding !IsConnect}"
                                                  Visibility="{calc:Binding 'BBLLCConnectTypeListIndex==0',FalseToVisibility=Collapsed}"
                                                  SelectedIndex="{Binding SerialPortIndex,Mode=TwoWay}"/>
                                        <ComboBox 
                                            ItemsSource="{Binding BBLLCCANList}"
                                            Height="25"
                                            Visibility="{calc:Binding 'BBLLCConnectTypeListIndex==1',FalseToVisibility=Collapsed}"
                                            IsEnabled="{calc:Binding !IsConnect}"
                                            DisplayMemberPath="Name"
                                            SelectedValuePath="Value"
                                            SelectedIndex="{Binding BBLLCCANListIndex,Mode=TwoWay}"/>
                                    </StackPanel>
                                </Border>
                                <Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="升级方式：" Style="{DynamicResource ComboboxTitle}"/>
                                        <ComboBox ItemsSource="{Binding UpdateModeItemSource}"
                                                  Height="25"
                                                  IsEnabled="{calc:Binding !IsUpgrading}"
                                                  SelectedIndex="{Binding UpdateModeSelectedIndex,Mode=TwoWay}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1">
                            <Button Content="{calc:Binding 'IsConnect ? SDisConnect : SConnect'}" 
                            Style="{DynamicResource CommonButtonStyle}"
                            Command="{Binding ConnectCommand}"/>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Background="Transparent">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" 
                            Visibility="{calc:Binding 'UpdateModeSelectedIndex == 0', FalseToVisibility=Collapsed}">
                            <Button Content="文件载入" Style="{DynamicResource CommonButtonStyle}" 
                            Command="{Binding LoadFileCommand}"
                            HorizontalAlignment="Left"/>
                            <TextBlock Text="文件路径：" Margin="0,15,0,5" FontSize="14" Foreground="{DynamicResource TitleBarColor}"/>
                            <TextBox Text="{Binding FileName}" IsEnabled="False" 
                             Height="25" 
                             VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Top"
                            IsEnabled="{calc:Binding !IsUpgrading}"
                            Visibility="{calc:Binding 'UpdateModeSelectedIndex == 1', FalseToVisibility=Collapsed}">
                            <Border Padding="0,15,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="100">
                                        <TextBlock Text="升级拓扑：" FontSize="14" Foreground="{DynamicResource TitleBarColor}"/>
                                    </Border>
                                    <Border Grid.Column="1">
                                        <StackPanel>
                                            <RadioButton FontSize="14" 
                                                         Foreground="{DynamicResource TitleBarColor}"
                                                         GroupName="updateTopo" IsChecked="{Binding UpdateTopoEnum,Converter={StaticResource EnumToBooleanConverter},ConverterParameter={x:Static enums:UpdateTopoEnum.移相全桥}}"
                                                         Content="移相全桥"/>
                                            <RadioButton FontSize="14" 
                                                         Foreground="{DynamicResource TitleBarColor}"
                                                         GroupName="updateTopo" IsChecked="{Binding UpdateTopoEnum,Converter={StaticResource EnumToBooleanConverter},ConverterParameter={x:Static enums:UpdateTopoEnum.LC}}" 
                                                         Content="LC"/>
                                            <RadioButton FontSize="14" 
                                                         Foreground="{DynamicResource TitleBarColor}"
                                                         GroupName="updateTopo" IsChecked="{Binding UpdateTopoEnum,Converter={StaticResource EnumToBooleanConverter},ConverterParameter={x:Static enums:UpdateTopoEnum.LLC}}" 
                                                         Content="LLC"/>
                                            <RadioButton FontSize="14" 
                                                         Foreground="{DynamicResource TitleBarColor}"
                                                         GroupName="updateTopo" IsChecked="{Binding UpdateTopoEnum,Converter={StaticResource EnumToBooleanConverter},ConverterParameter={x:Static enums:UpdateTopoEnum.单相逆变整流}}" 
                                                         Content="单相逆变整流"/>
                                            <RadioButton FontSize="14" 
                                                         Foreground="{DynamicResource TitleBarColor}"
                                                         GroupName="updateTopo" IsChecked="{Binding UpdateTopoEnum,Converter={StaticResource EnumToBooleanConverter},ConverterParameter={x:Static enums:UpdateTopoEnum.三相逆变整流}}" 
                                                         Content="三相逆变整流"/>
                                            <RadioButton FontSize="14" 
                                                         Foreground="{DynamicResource TitleBarColor}"
                                                         GroupName="updateTopo" IsChecked="{Binding UpdateTopoEnum,Converter={StaticResource EnumToBooleanConverter},ConverterParameter={x:Static enums:UpdateTopoEnum.DAB}}" 
                                                         Content="DAB"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Background="Transparent" Height="50">
                    <StackPanel>
                        <Button Content="升   级" Height="30" 
                        FontSize="16"
                        IsEnabled ="{calc:Binding IsConnect}"
                        Command="{Binding UpgradeCommand}"
                        Visibility="{calc:Binding !IsUpgrading, FalseToVisibility=Collapsed}"/>
                        <ProgressBar Visibility="{calc:Binding IsUpgrading, FalseToVisibility=Collapsed}"
                             Value="{Binding ProcessValue}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <controls:LoadingPage Visibility="{Binding IsShowLoading}" />
    </Grid>
    
</UserControl>
