<UserControl x:Class="Workbench.Views.dw.BatchParamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.dw"
             xmlns:viewModels="clr-namespace:Workbench.ViewModels.dw"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:views="clr-namespace:Workbench.Views.dw"
             xmlns:cvt="clr-namespace:Workbench.Converters"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
              xmlns:utils="clr-namespace:Workbench.Utils"
              xmlns:behaviors="clr-namespace:Workbench.Behaviors"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:controls_Title="clr-namespace:Workbench.Controls.Controls.Title;assembly=Workbench.Controls"
              xmlns:local_Model="clr-namespace:Workbench.Models"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewModels:BatchParamsViewModel}">
            <views:BatchParamsView />
        </DataTemplate>
        <!--<cvt:AddOneConverter x:Key="AddOneConverter"/>-->
        <cvt:RowIndexConverter x:Key="RowIndexConverter"/>
        <cvt:IsOddAlternationConverter x:Key="IsOddAlternationConverter"/>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>

        </Style>
        <Storyboard x:Key="ExpandStoryboard">
            <local_Model:GridLengthAnimation Storyboard.TargetName="LeftCol"
                                Storyboard.TargetProperty="Width"
                                From="0" To="300"
                                Duration="0:0:0.18"/>
        </Storyboard>
        <Storyboard x:Key="CollapseStoryboard">
            <local_Model:GridLengthAnimation Storyboard.TargetName="LeftCol"
                                Storyboard.TargetProperty="Width"
                                From="300" To="0"
                                Duration="0:0:0.18"/>
        </Storyboard>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Name="LeftCol" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions> 
        <Border Grid.Column="0" Width="300" HorizontalAlignment="Left" Background="{StaticResource AvalonDockAreaBackgroundColor}" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                    <Border Style="{StaticResource BorderCircular}" Margin="5,10,0,0"  BorderBrush="Transparent" Background="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <controls_Title:StandTitle Padding="0,0,0,0" BordMargin="0,0,5,0" StandText="寄存器目录" StandFontSize="{DynamicResource SubHeadFontSize}"/>
                        </StackPanel>
                    </Border>
                    <hc:UniformSpacingPanel Spacing="8" Orientation="Horizontal" Margin="0,10">
                        <RadioButton GroupName="OrderBy" Content="按分类"
             IsChecked="{Binding IsOrderByCategory, Mode=TwoWay}" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"/>
                        <RadioButton GroupName="OrderBy" Content="按名称"
             IsChecked="{Binding IsOrderByName, Mode=TwoWay}" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"/>
                        <RadioButton GroupName="OrderBy" Content="按地址"
             IsChecked="{Binding IsOrderByAddress, Mode=TwoWay}" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"/>
                        <CheckBox Content="全选/反选" Command="{Binding SelectAllCommand}" CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="false">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>
                    </hc:UniformSpacingPanel>
                </hc:UniformSpacingPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">

                    <Border>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="5"></TextBlock>
                            <!--<TextBlock Text="当前选中寄存器:"   VerticalAlignment="Center"/>-->
                            <TextBlock Text="{Binding CurrentRegister.AddressHex}"   VerticalAlignment="Center"/>
                            <TextBlock Text=" : "   VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentRegister.Name}"   VerticalAlignment="Center"/>
                            </StackPanel>
                    </Border>
                    
                    <!--<TextBlock Width="10"></TextBlock>
                    <Border>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="地址:"   VerticalAlignment="Center"/>
                            <TextBlock Width="10"></TextBlock>
                            <TextBlock Text="{Binding CurrentRegister.AddressHex}"   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>-->

                </StackPanel>
                <hc:SearchBar Grid.Row="3" Style="{StaticResource SearchBarPlus}" hc:InfoElement.Placeholder="请输入搜索关键字" hc:InfoElement.ShowClearButton="True">
                    <hc:SearchBar.Text>
                        <Binding Path="TreeKeyword" UpdateSourceTrigger="PropertyChanged"/>
                    </hc:SearchBar.Text>
                </hc:SearchBar>
                <Border Margin="0,5,0,0" Grid.Row="4">
                    <TreeView ItemsSource="{Binding SingleParamTrees}" Background="{DynamicResource InLeftTreeViewBackGround}">
                        <TreeView.Resources>
                            <!-- ★ 继承原样式，只追加两个 Setter -->
                            <Style x:Key="BindableTreeViewItemStyle"
                                TargetType="TreeViewItem"
                                BasedOn="{StaticResource TreeViewItemStyle}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.Resources>

                        <!-- 只影响当前这棵 TreeView -->
                        <TreeView.ItemContainerStyle>
                            <StaticResource ResourceKey="BindableTreeViewItemStyle"/>
                        </TreeView.ItemContainerStyle>
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectedItemChanged">
                                <i:InvokeCommandAction Command="{Binding SelectedItemChangedCommand}" 
                                 CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel>
                                    <TextBlock Visibility="{c:Binding 'AddressHex==null',FalseToVisibility=Collapsed}" Text="{Binding Title}" Foreground="{DynamicResource TreeViewNodeBrush}"/>
                                    <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'AddressHex!=null',FalseToVisibility=Collapsed}">
                                        <CheckBox IsChecked="{Binding IsCheck}">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCheck}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCheck}" Value="false">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>
                                        <TextBlock Width="5"></TextBlock>
                                        <TextBlock Text="{Binding AddressHex}" Foreground="{DynamicResource TreeViewNodeBrush}"/>
                                        <TextBlock Text=" : "/>
                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TreeViewNodeBrush}"/>
                                    
                                        
                                    </StackPanel>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>
        </Border>
        
        <Border Grid.Column="1" Padding="0,8,28,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/> 
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border>
                    <Grid>
                        <Border Margin="0,0,0,0" MinHeight="200">
                            <DockPanel LastChildFill="True">
                                <Border Style="{StaticResource BorderCircular}" Margin="5,10,0,5" DockPanel.Dock="Top"  BorderBrush="Transparent" Background="Transparent">
                                    <DockPanel LastChildFill="True">
                                        <!--<TextBlock Text="序列管理列表" FontSize="{StaticResource SubHeadFontSize}" DockPanel.Dock="Left" VerticalAlignment="Center"/>-->
                                        <controls_Title:StandTitle Padding="0,0,0,0" BordMargin="0,0,5,0" StandText="序列管理列表" StandFontSize="{DynamicResource SubHeadFontSize}"/>
                                        <TextBlock Width="10"></TextBlock>
                                        <Button Style="{StaticResource ButtonDefault.Small}" Margin="0,0,0,6" Width="126" VerticalAlignment="Center"
        ToolTip="展开/收起寄存器目录" Content="展开寄存器目录" Visibility="{c:Binding !IsLeftOpen,FalseToVisibility=Collapsed}"
        Command="{Binding ToggleDrawerCommand}" hc:IconElement.Geometry="{StaticResource  AlignLeftGeometry}"/>
                                        <Button Style="{StaticResource ButtonDefault.Small}" Margin="0,0,0,6" Width="126" VerticalAlignment="Center"
ToolTip="展开/收起寄存器目录" Content="收起寄存器目录" Visibility="{c:Binding IsLeftOpen,FalseToVisibility=Collapsed}"
Command="{Binding ToggleDrawerCommand}" hc:IconElement.Geometry="{StaticResource AlignRightGeometry}" />
                                        <Border>
                                            <hc:UniformSpacingPanel Spacing="10" HorizontalAlignment="Right">
                                                <Button Content="新增序列" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource GenButtonBackgroundColor}" BorderBrush="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                                    Command="{Binding AddSequenceCommand}"/>
                                                <Button Content="批量下发" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource GenButtonBackgroundColor}" BorderBrush="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource AllGeometry}"
                                                        Command="{Binding BatchSendCommand}"/>
                                            </hc:UniformSpacingPanel>
                                        </Border>
                                    </DockPanel>
                                </Border>
                                <DataGrid ItemsSource="{Binding SequenceList}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                      CanUserSortColumns="False" CanUserAddRows="False" Margin="0,5,0,0"  Height="Auto"
                                       Background="{DynamicResource DataGridBackgroundColor}" AlternationCount="2"
                                      SelectedItem="{Binding CurrentSequence}">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}"  >
                                            <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Padding" Value="10,0,0,0"/>
                                            <Setter Property="Margin" Value="0,0,12,0"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
     Color="Transparent"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
     Color="#3D7EFF"/>
                                    </DataGrid.Resources>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                            <Setter Property="Margin" Value="8,0,12,0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <!-- 前景色跟随行 -->
                                            <Setter Property="Foreground"
Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>

                                            <Style.Triggers>
                                                <!-- 选中 -->
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>

                                                <!-- 选中 + DataGrid失焦（例如右键弹菜单） -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </MultiDataTrigger>

                                                <!-- Hover 时也别盖住整行背景 -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Height" Value="30"/>
                                            <Setter Property="Tag" Value="{Binding Path=DataContext,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <Setter Property="ContextMenu">
                                                <Setter.Value>
                                                    <ContextMenu Style="{StaticResource ContextMenu.Small}" Width="125">
                                                        <MenuItem Header="删除" Command="{Binding Path=PlacementTarget.Tag.RemoveSequenceListCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
CommandParameter="{Binding}"/>
                                                        <MenuItem Header="复制" Command="{Binding Path=PlacementTarget.Tag.CopySequenceListCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
CommandParameter="{Binding}"/>
                                                        <MenuItem Header="上移" Command="{Binding Path=PlacementTarget.Tag.MoveUpSequenceListCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
CommandParameter="{Binding}"/>
                                                        <MenuItem Header="下移" Command="{Binding Path=PlacementTarget.Tag.MoveDownSequenceListCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
CommandParameter="{Binding}"/>
                                                    </ContextMenu>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                            <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="SnapsToDevicePixels" Value="True" />
                                            <Style.Triggers>
                                                <Trigger Property="AlternationIndex" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                                </Trigger>

                                                <!-- 选中（鼠标不在上面） -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource TreeViewItemSelectedBackgroundColor}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                    <!-- 白字 -->
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <!-- 去掉分割线 -->
                                                </MultiTrigger>

                                                <!-- 选中 + 悬停 -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource TreeViewItemSelectedBackgroundColor}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn  Header="序列编号" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock VerticalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <!-- 使用 MultiBinding -->
                                                            <MultiBinding Converter="{StaticResource RowIndexConverter}">
                                                                <!-- 第一个绑定：绑定到当前行的数据项 (DataContext) -->
                                                                <Binding />
                                                                <!-- 第二个绑定：通过 RelativeSource 找到父级的 DataGrid 控件 -->
                                                                <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="序列名称" Width="*" MinWidth="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  VerticalAlignment="Center"
                                                             Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Placeholder="请输入名称"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="参数下发数量" Binding="{Binding Items.Count}"  Width="*" IsReadOnly="True"  ElementStyle="{StaticResource CenterCellStyle}"/>
                                        <DataGridTemplateColumn Header="参数下发间隔(ms)"  Width="*" MinWidth="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <hc:NumericUpDown Style="{StaticResource NumericUpDownExtend.Small}" Minimum="1" DecimalPlaces="0" VerticalAlignment="Center">
                                                        <hc:NumericUpDown.Value>
                                                            <Binding Path="ParamPushInterval" UpdateSourceTrigger="PropertyChanged"></Binding>
                                                        </hc:NumericUpDown.Value>
                                                    </hc:NumericUpDown>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="下发" Width="*" MinWidth="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource ButtonInfo.Small}" VerticalAlignment="Center"
                                                            Content="下发"
                                                            Command="{Binding DataContext.SendCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            HorizontalAlignment="Left" Background="{DynamicResource GenButtonBackgroundColor}"
                                                            BorderBrush="{DynamicResource GenButtonBackgroundColor}"
                                                            hc:IconElement.Geometry="{StaticResource PushGeometry}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="下发状态" Width="*" MinWidth="180">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <hc:UniformSpacingPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                        <ProgressBar Style="{StaticResource ProgressBarWarning}" Value="{Binding Progress,Mode=TwoWay}" Width="100"/>
                                                        <Border>
                                                            <TextBlock Text="{Binding Statement}" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </hc:UniformSpacingPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Width="*">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                    <TextBlock Text="选择"/>
                                                    <CheckBox IsChecked="{Binding Path=DataContext.CheckAll,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          Margin="5,0,0,0"/>
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsChecked,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#10000000" ResizeDirection="Rows"></GridSplitter>

                <!--<hc:Divider Grid.Row="1" Margin="0,8"/>-->
                <Border Grid.Row="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="5"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <DockPanel LastChildFill="True" MinWidth="560">

                            <Border Style="{StaticResource BorderCircular}" DockPanel.Dock="Top"  Margin="5,10,0,5"  BorderBrush="Transparent" Background="Transparent">
                                <DockPanel LastChildFill="True">
                                    <hc:UniformSpacingPanel  DockPanel.Dock="Left" Spacing="5">
                                        <!--<TextBlock Text="序列配置详情:" FontSize="{StaticResource SubHeadFontSize}" VerticalAlignment="Center"/>-->
                                        <controls_Title:StandTitle  Padding="0,5,0,0"  BordMargin="0,0,5,0" StandText="序列配置详情 :" StandFontSize="{DynamicResource SubHeadFontSize}"/>
                                        <TextBlock Padding="0,5,0,0"  Text="{Binding CurrentSequence.Name}" ToolTip="{Binding CurrentSequence.Name}"  TextTrimming="CharacterEllipsis"  MaxWidth="100"  FontSize="{StaticResource SubHeadFontSize}" VerticalAlignment="Center"/>
                                    </hc:UniformSpacingPanel>
                                    <Border Margin="0,0,10,0">
                                        <hc:UniformSpacingPanel Spacing="10" HorizontalAlignment="Right">
                                           
                                            <Button Content="添加到序列" Style="{StaticResource ButtonPrimary}" Width="110"  Background="{DynamicResource GenButtonBackgroundColor}" BorderBrush="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                            Command="{Binding AddRegisterToSequenceCommand}"/>

                                            <Button Content="查看配置" Style="{StaticResource ButtonPrimary}" Width="100"  Background="{DynamicResource GenButtonBackgroundColor}"  BorderBrush="{DynamicResource GenButtonBackgroundColor}"  hc:IconElement.Geometry="{StaticResource EnlargeGeometry}"
                                                        Command="{Binding ConfigRegisterCommand}" CommandParameter="{Binding SelectedItem, ElementName=SequenceGrid}"/>

                                            <hc:SplitButton DockPanel.Dock="Right" Content="显示列：" Style="{StaticResource SplitButtonDefault}" HorizontalAlignment="Right">
                                                <hc:SplitButton.DropDownContent>
                                                    <ItemsControl ItemsSource="{Binding TableColumns}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="8,0">
                                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </hc:SplitButton.DropDownContent>
                                            </hc:SplitButton>
                                        </hc:UniformSpacingPanel>
                                    </Border>
                                </DockPanel>
                            </Border>

                            <DataGrid x:Name="SequenceGrid" ItemsSource="{Binding CurrentSequence.Items}" AutoGenerateColumns="False" CanUserResizeColumns="True"                                  
                                  AlternationCount="2"   Background="{DynamicResource DataGridBackgroundColor}"  ColumnHeaderHeight="30"
                                      RowHeaderWidth="60" LoadingRow="SequenceGrid_LoadingRow" Sorting="SequenceGrid_Sorting"
                                      Loaded="SequenceGrid_OnLoaded"
                              CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseDoubleClick">
                                        <i:InvokeCommandAction Command="{Binding ConfigRegisterCommand}" CommandParameter="{Binding SelectedItem, ElementName=SequenceGrid}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="{x:Type DataGridColumnHeader}"  >
                                        <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Padding" Value="10,0,0,0"/>
                                        <Setter Property="Margin" Value="0,0,12,0"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />                                       
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Resources>
                                    <utils:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#3D7EFF"/>
                                </DataGrid.Resources>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                        <Setter Property="Margin" Value="8,0,12,0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <!-- 前景色跟随行 -->
                                        <Setter Property="Foreground"
Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>

                                        <Style.Triggers>
                                            <!-- 选中 -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>

                                            <!-- 选中 + DataGrid失焦（例如右键弹菜单） -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </MultiDataTrigger>

                                            <!-- Hover 时也别盖住整行背景 -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
                                        <Setter Property="Tag" Value="{Binding Path=DataContext,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu Style="{StaticResource ContextMenu.Small}" Width="125">
                                                    <MenuItem Header="删除" Command="{Binding Path=PlacementTarget.Tag.RemoveSequenceItemCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                                    <MenuItem Header="复制" Command="{Binding Path=PlacementTarget.Tag.CopyCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                                    <MenuItem Header="上移" Command="{Binding Path=PlacementTarget.Tag.MoveUpCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                                    <MenuItem Header="下移" Command="{Binding Path=PlacementTarget.Tag.MoveDownCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="SnapsToDevicePixels" Value="True" />
                                        <Style.Triggers>
                                            <!-- 斑马纹：奇数行底色 -->
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self},
                                               Path=AlternationIndex,
                                               Converter={StaticResource IsOddAlternationConverter}}"
                             Value="True">
                                                <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                            </DataTrigger>

                                            <!-- Hover：偶数行 -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=AlternationIndex,
                                                     Converter={StaticResource IsOddAlternationConverter}}"
                                   Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="{StaticResource RowHoverBrushEven}"/>
                                            </MultiDataTrigger>

                                            <!-- Hover：奇数行 -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=AlternationIndex,
                                                     Converter={StaticResource IsOddAlternationConverter}}"
                                   Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="{StaticResource RowHoverBrushOdd}"/>
                                            </MultiDataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                            </Trigger>

                                            <!-- 选中（鼠标不在上面） -->
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{StaticResource TreeViewItemSelectedBackgroundColor}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                <!-- 白字 -->
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <!-- 去掉分割线 -->
                                            </MultiTrigger>

                                            <!-- 选中 + 悬停 -->
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{StaticResource TreeViewItemSelectedBackgroundColor}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </MultiTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="寄存器地址" Width="Auto" MinWidth="60" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[0].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding AddressHex}" ToolTip="{Binding AddressHex}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="分类" Binding="{Binding Category}"  Width="*" MinWidth="100" ElementStyle="{StaticResource CenterCellStyle}" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[1].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}"/>
                                    <DataGridTextColumn Header="子分类" Binding="{Binding SubCategory}"  Width="*" MinWidth="60" ElementStyle="{StaticResource CenterCellStyle}" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[2].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}"/>
                                    <DataGridTextColumn Header="寄存器名称" Binding="{Binding Name}"  Width="Auto" MinWidth="120"  Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[3].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="ToolTip" Value="{Binding Name}"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="数据(HEX)" Width="*" MinWidth="110" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[4].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding HexValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Style="{StaticResource TextBoxExtend.Small}"
                                                 LostFocus="HexValueText_LostFocus"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据(Binary)" Width="*" MinWidth="648" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[5].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding BinaryList,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,10,0,0">
                                                                <TextBox hc:BorderElement.CornerRadius="0" BorderBrush="{StaticResource AvalonDockPannelBordBrush}" Text="{Binding Value}" Style="{StaticResource TextBox.Small}" PreviewTextInput="BinaryTextBox_PreviewTextInput" DataObject.Pasting="BinaryTextBox_Pasting" LostFocus="BinaryTextBox_LostFocus"/>
                                                                <TextBlock Text="{Binding Display}" HorizontalAlignment="Center" FontSize="9"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                        <GridSplitter Grid.Column="1" Width="10" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></GridSplitter>
                        <DockPanel LastChildFill="True" Grid.Column="2">
                            <Border Style="{StaticResource BorderCircular}" Margin="5,10,0,5" DockPanel.Dock="Top"  BorderBrush="Transparent" Background="Transparent">
                                <Grid> 
                                    <hc:UniformSpacingPanel Spacing="15">
                                        <!--<TextBlock Text="寄存器详情" FontSize="{StaticResource SubHeadFontSize}"/>-->
                                     
                                        <controls_Title:StandTitle Padding="0,5,0,0" BordMargin="0,0,5,0" StandText="寄存器详情" StandFontSize="{DynamicResource SubHeadFontSize}"/>
                                        <TextBlock Padding="0,5,0,0"  Text="{Binding WriteCurrentRegister.AddressHex}" FontSize="{StaticResource SubHeadFontSize}"/>
                                        <TextBlock Padding="0,5,0,0"  Text=":" FontSize="{StaticResource SubHeadFontSize}"/>
                                        <TextBlock Padding="0,5,0,3"  Text="{Binding WriteCurrentRegister.Name}" FontSize="{StaticResource SubHeadFontSize}"/>

                                        <hc:SplitButton DockPanel.Dock="Right" Content="显示列：" Style="{StaticResource SplitButtonDefault}" HorizontalAlignment="Right">
                                            <hc:SplitButton.DropDownContent>
                                                <ItemsControl ItemsSource="{Binding TableColumnsR}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="8,0">
                                                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </hc:SplitButton.DropDownContent>
                                        </hc:SplitButton>
                                    </hc:UniformSpacingPanel>
                                </Grid>
                            </Border>

                            <DataGrid ItemsSource="{Binding WriteCurrentRegister.BitFields}" AutoGenerateColumns="False"  ColumnHeaderHeight="30"
                                           Background="{DynamicResource DataGridBackgroundColor}" AlternationCount="2" CanUserResizeColumns="True"    
                         CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0">

                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}"  >
                                            <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Padding" Value="10,0,0,0"/>
                                            <Setter Property="Margin" Value="0,0,12,0"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Resources>
                                    <utils:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
     Color="Transparent"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
     Color="#3D7EFF"/>
                                    </DataGrid.Resources>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                            <Setter Property="Margin" Value="8,0,12,0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <!-- 前景色跟随行 -->
                                            <Setter Property="Foreground"
Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>

                                            <Style.Triggers>
                                                <!-- 选中 -->
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>

                                                <!-- 选中 + DataGrid失焦（例如右键弹菜单） -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </MultiDataTrigger>

                                                <!-- Hover 时也别盖住整行背景 -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                            <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="SnapsToDevicePixels" Value="True" />
                                            <Style.Triggers>
                                                <Trigger Property="AlternationIndex" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                                </Trigger>

                                                <!-- 选中（鼠标不在上面） -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{StaticResource TreeViewItemSelectedBackgroundColor}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                <!-- 白字 -->
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <!-- 去掉分割线 -->
                                                </MultiTrigger>

                                                <!-- 选中 + 悬停 -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{StaticResource TreeViewItemSelectedBackgroundColor}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="位" Width="*" MinWidth="70" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumnsR[0].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">                                          
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="b"/>
                                                        <TextBlock Text="{Binding EndBit}"/>
                                                        <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'Length>1',FalseToVisibility=Collapsed}">
                                                            <TextBlock Text="-"/>
                                                            <TextBlock Text="b"/>
                                                            <TextBlock Text="{Binding StartBit}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="名称" Binding="{Binding Desc}" Width="*" MinWidth="150" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumnsR[1].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="ToolTip" Value="{Binding Desc}"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <!--<DataGridTextColumn Header="数据(Binary)" Binding="{Binding ReadBinary}"  Width="*" MinWidth="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="ToolTip" Value="{Binding ReadBinary}"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>-->
                                    <DataGridTextColumn Header="数据(HEX)" Binding="{Binding ReadHex}"  Width="*" MinWidth="100" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumnsR[2].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="ToolTip" Value="{Binding ReadHex}"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <!--<DataGridTextColumn Header="解析" Binding="{Binding ResolveStr}"  Width="*" MinWidth="70">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="ToolTip" Value="{Binding ResolveStr}"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>-->
                                        <DataGridTemplateColumn Header="数据配置解析(Binary)" Width="*" MinWidth="160" Visibility="Hidden">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                        <TextBox Style="{StaticResource TextBoxExtend.Small}" HorizontalAlignment="Stretch" hc:InfoElement.Placeholder="请输入"
                                                            MaxLength="{Binding Length}" Text="{Binding WriteBinary}"
                                                            behaviors:InputMaskBehavior.IsBinaryOnly="True"
                                                            LostFocus="TextBox_LostFocus"
                                                            IsEnabled="{Binding IsTextbox}"
                                                            Visibility="{c:Binding 'RangeMin==null',FalseToVisibility=Collapsed}"/>
                                                        <hc:NumericUpDown Minimum="{Binding RangeMin}" Maximum="{Binding RangeMax}"
                                                                     Style="{StaticResource NumericUpDownExtend.Small}"
                                                                     hc:InfoElement.Placeholder="请输入"
                                                                     LostFocus="NumericUpDown_LostFocus"
                                                                     Visibility="{c:Binding 'RangeMin!=null and RangeMax!=null',FalseToVisibility=Collapsed}">
                                                            <hc:NumericUpDown.Value>
                                                                <Binding Path="WriteBinary" UpdateSourceTrigger="PropertyChanged"/>
                                                            </hc:NumericUpDown.Value>
                                                        </hc:NumericUpDown>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="配置"  Width="*" MinWidth="100" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumnsR[3].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <ComboBox Style="{StaticResource ComboBoxExtend.Small}" ItemsSource="{Binding Options}"
      DisplayMemberPath="Display" SelectedValuePath="Key" hc:InfoElement.Placeholder="请选择"
      SelectedValue="{Binding SelectedValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
      Visibility="{c:Binding 'Options.Count>0',FalseToVisibility=Collapsed}"
      >
                                                            <i:Interaction.Triggers>
                                                                <i:EventTrigger EventName="SelectionChanged">
                                                                    <i:InvokeCommandAction Command="{Binding DataContext.OptionChangeCommand,RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                               CommandParameter="{Binding}" />
                                                                </i:EventTrigger>
                                                            </i:Interaction.Triggers>
                                                        </ComboBox>
                                                    </StackPanel>
                                                   
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                    </DataGrid.Columns>
                                </DataGrid>
                       
                        </DockPanel>
                        
                    </Grid>
                </Border>

            </Grid>
        </Border>

    </Grid>
</UserControl>
