<UserControl x:Class="Workbench.Views.dw.BatchParamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.dw"
             xmlns:viewModels="clr-namespace:Workbench.ViewModels.dw"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:views="clr-namespace:Workbench.Views.dw"
             xmlns:cvt="clr-namespace:Workbench.Converters"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
              xmlns:behaviors="clr-namespace:Workbench.Behaviors"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
              xmlns:local_Model="clr-namespace:Workbench.Models"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewModels:BatchParamsViewModel}">
            <views:BatchParamsView />
        </DataTemplate>
        <cvt:AddOneConverter x:Key="AddOneConverter"/>
        <cvt:RowIndexConverter x:Key="RowIndexConverter"/>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>

        </Style>
        <Storyboard x:Key="ExpandStoryboard">
            <local_Model:GridLengthAnimation Storyboard.TargetName="LeftCol"
                                Storyboard.TargetProperty="Width"
                                From="0" To="324"
                                Duration="0:0:0.18"/>
        </Storyboard>
        <Storyboard x:Key="CollapseStoryboard">
            <local_Model:GridLengthAnimation Storyboard.TargetName="LeftCol"
                                Storyboard.TargetProperty="Width"
                                From="324" To="0"
                                Duration="0:0:0.18"/>
        </Storyboard>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Name="LeftCol" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Width="332" Background="#fafafa" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                    <Border Style="{StaticResource BorderTipPrimary}"  BorderBrush="{DynamicResource BordTitleBackgroundColor}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="寄存器目录" FontSize="{StaticResource SubHeadFontSize}"/>
                        </StackPanel>
                    </Border>
                    <hc:UniformSpacingPanel Spacing="8" Orientation="Horizontal" Margin="0,10">
                        <RadioButton GroupName="OrderBy" Content="按分类"
             IsChecked="{Binding IsOrderByCategory, Mode=TwoWay}" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"/>
                        <RadioButton GroupName="OrderBy" Content="按名称"
             IsChecked="{Binding IsOrderByName, Mode=TwoWay}" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"/>
                        <RadioButton GroupName="OrderBy" Content="按地址"
             IsChecked="{Binding IsOrderByAddress, Mode=TwoWay}" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"/>
                        
                    </hc:UniformSpacingPanel>
                </hc:UniformSpacingPanel>
                <StackPanel  Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                    <ComboBox Grid.Row="1"  ItemsSource="{Binding SettingCategoryList}" Style="{StaticResource ComboBoxExtend}"
hc:InfoElement.Title="分类：" hc:InfoElement.TitlePlacement="Left" Width="130"
SelectedItem="{Binding CurrentCategory}" DisplayMemberPath="Label" SelectedValuePath="Value"></ComboBox>
                    <TextBlock Width="10"></TextBlock>
                    <ComboBox ItemsSource="{Binding CategoryAddressList}" Style="{StaticResource ComboBoxExtend}"
hc:InfoElement.Title="地址：" hc:InfoElement.TitlePlacement="Left" Width="167"
SelectedItem="{Binding CategoryAddress}" DisplayMemberPath="Label" SelectedValuePath="Value"></ComboBox>
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">

                    <Border> 
                            <StackPanel Orientation="Horizontal">
                            <TextBlock Text="当前选中寄存器:"   VerticalAlignment="Center"/>
                            <TextBlock Width="5"></TextBlock>
                            <TextBlock Text="{Binding CurrentRegister.Name}"   VerticalAlignment="Center"/>
                            </StackPanel>
                    </Border>
                    
                    <TextBlock Width="10"></TextBlock>
                    <Border>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="地址:"   VerticalAlignment="Center"/>
                            <TextBlock Width="10"></TextBlock>
                            <TextBlock Text="{Binding CurrentRegister.AddressHex}"   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
                <hc:SearchBar Grid.Row="3" Style="{StaticResource SearchBarPlus}" hc:InfoElement.Placeholder="请输入搜索关键字" hc:InfoElement.ShowClearButton="True">
                    <hc:SearchBar.Text>
                        <Binding Path="TreeKeyword" UpdateSourceTrigger="PropertyChanged"/>
                    </hc:SearchBar.Text>
                </hc:SearchBar>
                <Border Margin="0,5,0,0" Grid.Row="4">
                    <TreeView ItemsSource="{Binding SingleParamTrees}">
                        <TreeView.Resources>
                            <!-- ★ 继承原样式，只追加两个 Setter -->
                            <Style x:Key="BindableTreeViewItemStyle"
                                TargetType="TreeViewItem"
                                BasedOn="{StaticResource TreeViewItemStyle}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.Resources>

                        <!-- 只影响当前这棵 TreeView -->
                        <TreeView.ItemContainerStyle>
                            <StaticResource ResourceKey="BindableTreeViewItemStyle"/>
                        </TreeView.ItemContainerStyle>
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectedItemChanged">
                                <i:InvokeCommandAction Command="{Binding SelectedItemChangedCommand}" 
                                 CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel>
                                    <TextBlock Visibility="{c:Binding 'AddressHex==null',FalseToVisibility=Collapsed}" Text="{Binding Title}"/>
                                    <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'AddressHex!=null',FalseToVisibility=Collapsed}">
                                        <TextBlock Text="{Binding AddressHex}"/>
                                        <TextBlock Text=" : "/>
                                        <TextBlock Text="{Binding Title}"/>
                                        <TextBlock Width="10"></TextBlock>
                                        <CheckBox IsChecked="{Binding IsCheck}"></CheckBox>
                                    </StackPanel>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Margin="0,0,15,0">
                            <DockPanel LastChildFill="True">
                                <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top"  BorderBrush="{DynamicResource BordTitleBackgroundColor}">
                                    <DockPanel LastChildFill="True">
                                        <TextBlock Text="序列管理列表" FontSize="{StaticResource SubHeadFontSize}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                        <TextBlock Width="10"></TextBlock>
                                        <Button Style="{StaticResource ButtonDefault.Small}" Width="86"
        ToolTip="展开/收起目录" Content="展开目录" Visibility="{c:Binding !IsLeftOpen,FalseToVisibility=Collapsed}"
        Command="{Binding ToggleDrawerCommand}" hc:IconElement.Geometry="{StaticResource  AlignLeftGeometry}"/>
                                        <Button Style="{StaticResource ButtonDefault.Small}" Width="86"
ToolTip="展开/收起目录" Content="收起目录" Visibility="{c:Binding IsLeftOpen,FalseToVisibility=Collapsed}"
Command="{Binding ToggleDrawerCommand}" hc:IconElement.Geometry="{StaticResource AlignRightGeometry}" />
                                        <Border>
                                            <hc:UniformSpacingPanel Spacing="10" HorizontalAlignment="Right">
                                                <Button Content="新增序列" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                                    Command="{Binding AddSequenceCommand}"/>
                                                <Button Content="批量下发" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource AllGeometry}"
                                                        Command="{Binding BatchSendCommand}"/>
                                            </hc:UniformSpacingPanel>
                                        </Border>
                                    </DockPanel>
                                </Border>
                                <DataGrid ItemsSource="{Binding SequenceList}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                      CanUserSortColumns="False" CanUserAddRows="False" Margin="0,5,0,0" Height="346"
                                      SelectedItem="{Binding CurrentSequence}">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle}">
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Margin" Value="0,0,0,5"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn  Header="序列编号" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <TextBlock.Text>
                                                            <!-- 使用 MultiBinding -->
                                                            <MultiBinding Converter="{StaticResource RowIndexConverter}">
                                                                <!-- 第一个绑定：绑定到当前行的数据项 (DataContext) -->
                                                                <Binding />
                                                                <!-- 第二个绑定：通过 RelativeSource 找到父级的 DataGrid 控件 -->
                                                                <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="序列名称" Width="*" MinWidth="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                                             Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Placeholder="请输入名称"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="参数下发数量" Binding="{Binding Items.Count}"  Width="*" IsReadOnly="True"/>
                                        <DataGridTemplateColumn Header="参数下发间隔(ms)"  Width="*" MinWidth="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <hc:NumericUpDown Style="{StaticResource NumericUpDownExtend.Small}" Minimum="1" DecimalPlaces="0">
                                                        <hc:NumericUpDown.Value>
                                                            <Binding Path="ParamPushInterval" UpdateSourceTrigger="PropertyChanged"></Binding>
                                                        </hc:NumericUpDown.Value>
                                                    </hc:NumericUpDown>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="下发" Width="*" MinWidth="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource ButtonInfo.Small}"
                                                            Content="下发"
                                                            Command="{Binding DataContext.SendCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            HorizontalAlignment="Left"
                                                            hc:IconElement.Geometry="{StaticResource PushGeometry}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="下发状态" Width="*" MinWidth="180">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <hc:UniformSpacingPanel Orientation="Horizontal" Spacing="5">
                                                        <ProgressBar Style="{StaticResource ProgressBarWarning}" Value="{Binding Progress,Mode=TwoWay}" Width="100"/>
                                                        <Border>
                                                            <TextBlock Text="{Binding Statement}" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </hc:UniformSpacingPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Width="*">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="选择"/>
                                                    <CheckBox IsChecked="{Binding Path=DataContext.CheckAll,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          Margin="5,0,0,0"/>
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsChecked,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                        <Border Grid.Column="1">
                        </Border>

                    </Grid>
                </Border>
                <hc:Divider Grid.Row="1" Margin="0,8"/>
                <Border Grid.Row="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <DockPanel LastChildFill="True">

                            <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top"  BorderBrush="{DynamicResource BordTitleBackgroundColor}">
                                <DockPanel LastChildFill="True">
                                    <hc:UniformSpacingPanel  DockPanel.Dock="Left" Spacing="5">
                                        <TextBlock Text="序列配置详情:" FontSize="{StaticResource SubHeadFontSize}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CurrentSequence.Name}" FontSize="{StaticResource SubHeadFontSize}" VerticalAlignment="Center"/>
                                    </hc:UniformSpacingPanel>
                                    <Border>
                                        <hc:UniformSpacingPanel Spacing="10" HorizontalAlignment="Right">
                                            <Button Content="添加到序列" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                            Command="{Binding AddRegisterToSequenceCommand}"/>

                                            <Button Content="配置" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                                        Command="{Binding ConfigRegisterCommand}" CommandParameter="{Binding SelectedItem, ElementName=SequenceGrid}"/>
                                        </hc:UniformSpacingPanel>
                                    </Border>
                                </DockPanel>
                            </Border>

                            <DataGrid x:Name="SequenceGrid" ItemsSource="{Binding CurrentSequence.Items}" AutoGenerateColumns="False" CanUserResizeColumns="True"                                  
                                  AlternationCount="{x:Static sys:Int32.MaxValue}"
                              CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
                                        <Setter Property="Tag" Value="{Binding Path=DataContext,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu Style="{StaticResource ContextMenu.Small}" Width="165">
                                                    <MenuItem Header="删除" Command="{Binding Path=PlacementTarget.Tag.RemoveSequenceItemCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}"/>
                                                    <MenuItem Header="复制" Command="{Binding Path=PlacementTarget.Tag.CopyCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}"/>
                                                    <MenuItem Header="上移" Command="{Binding Path=PlacementTarget.Tag.MoveUpCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}"/>
                                                    <MenuItem Header="下移" Command="{Binding Path=PlacementTarget.Tag.MoveDownCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Margin" Value="0,0,0,5"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn  Header="发送顺序" MinWidth="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock  Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                   Path=AlternationIndex,
                                                   Converter={StaticResource AddOneConverter}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="地址" Width="Auto" MinWidth="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding AddressHex}" ToolTip="{Binding AddressHex}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="名称" Binding="{Binding Name}"  Width="*" MinWidth="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="ToolTip" Value="{Binding Name}"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="分类" Binding="{Binding Category}"  Width="*" MinWidth="100"/>
                                    <!--<DataGridTextColumn Header="子分类" Binding="{Binding SubCategory}"  Width="*" MinWidth="60"/>-->
                                    <DataGridTemplateColumn Header="数据(HEX)" Width="*" MinWidth="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding HexValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend.Small}"
                                                 LostFocus="HexValueText_LostFocus"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据(DEC)" Width="*" MinWidth="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <hc:NumericUpDown Minimum="0" Style="{StaticResource NumericUpDownExtend.Small}" LostFocus="DecValueText_LostFocus">
                                                    <hc:NumericUpDown.Value>
                                                        <Binding Path="DecValue" UpdateSourceTrigger="PropertyChanged"/>
                                                    </hc:NumericUpDown.Value>
                                                </hc:NumericUpDown>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据(Binary)" Width="*" MinWidth="648">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding BinaryList,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Vertical">
                                                                <TextBox Text="{Binding Value}" Style="{StaticResource TextBox.Small}" PreviewTextInput="BinaryTextBox_PreviewTextInput" DataObject.Pasting="BinaryTextBox_Pasting" LostFocus="BinaryTextBox_LostFocus"/>
                                                                <TextBlock Text="{Binding Display}" HorizontalAlignment="Center" FontSize="9"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                        <DockPanel LastChildFill="True" Grid.Column="1">
                            <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top"  BorderBrush="{DynamicResource BordTitleBackgroundColor}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <hc:UniformSpacingPanel Spacing="15">
                                        <TextBlock Text="寄存器详情" FontSize="{StaticResource SubHeadFontSize}"/>
                                        <TextBlock Text="{Binding WriteCurrentRegister.AddressHex}" FontSize="{StaticResource SubHeadFontSize}"/>
                                        <TextBlock Text=":" FontSize="{StaticResource SubHeadFontSize}"/>
                                        <TextBlock Text="{Binding WriteCurrentRegister.Name}" FontSize="{StaticResource SubHeadFontSize}"/>
                                    </hc:UniformSpacingPanel>
                                </Grid>
                            </Border>
                            <Border Background="{DynamicResource DarkDefaultBrush}" Margin="0,5,0,0"    VerticalAlignment="Top">
                                <DataGrid ItemsSource="{Binding WriteCurrentRegister.BitFields}" AutoGenerateColumns="False"  CanUserResizeColumns="True"    
                         CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False">
                                   
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Margin" Value="0,0,0,5"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="位" Width="*" MinWidth="70">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="b"/>
                                                        <TextBlock Text="{Binding EndBit}"/>
                                                        <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'Length>1',FalseToVisibility=Collapsed}">
                                                            <TextBlock Text="-"/>
                                                            <TextBlock Text="b"/>
                                                            <TextBlock Text="{Binding StartBit}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="名称" Binding="{Binding Desc}" Width="*" MinWidth="150">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="ToolTip" Value="{Binding Desc}"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="数据(Binary)" Binding="{Binding ReadBinary}"  Width="*" MinWidth="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="ToolTip" Value="{Binding ReadBinary}"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="数据(HEX)" Binding="{Binding ReadHex}"  Width="*" MinWidth="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="ToolTip" Value="{Binding ReadHex}"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="解析" Binding="{Binding ResolveStr}"  Width="*" MinWidth="70">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="ToolTip" Value="{Binding ResolveStr}"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Header="数据配置解析(Binary)" Width="*" MinWidth="100" >
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Vertical">
                                                        <TextBox Style="{StaticResource TextBoxExtend.Small}" HorizontalAlignment="Stretch" hc:InfoElement.Placeholder="请输入"
                                                            MaxLength="{Binding Length}" Text="{Binding WriteBinary}"
                                                            behaviors:InputMaskBehavior.IsBinaryOnly="True"
                                                            LostFocus="TextBox_LostFocus"
                                                            IsEnabled="{Binding IsTextbox}"
                                                            Visibility="{c:Binding 'RangeMin==null',FalseToVisibility=Collapsed}"/>
                                                        <hc:NumericUpDown Minimum="{Binding RangeMin}" Maximum="{Binding RangeMax}"
                                                                     Style="{StaticResource NumericUpDownExtend.Small}"
                                                                     hc:InfoElement.Placeholder="请输入"
                                                                     LostFocus="NumericUpDown_LostFocus"
                                                                     Visibility="{c:Binding 'RangeMin!=null and RangeMax!=null',FalseToVisibility=Collapsed}">
                                                            <hc:NumericUpDown.Value>
                                                                <Binding Path="WriteBinary" UpdateSourceTrigger="PropertyChanged"/>
                                                            </hc:NumericUpDown.Value>
                                                        </hc:NumericUpDown>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="配置"  Width="*" MinWidth="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Style="{StaticResource ComboBoxExtend.Small}" ItemsSource="{Binding Options}"
                                                         DisplayMemberPath="Display" SelectedValuePath="Key" hc:InfoElement.Placeholder="请选择"
                                                         SelectedValue="{Binding SelectedValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{c:Binding 'Options.Count>0',FalseToVisibility=Collapsed}"
                                                         >
                                                        <i:Interaction.Triggers>
                                                            <i:EventTrigger EventName="SelectionChanged">
                                                                <i:InvokeCommandAction Command="{Binding DataContext.OptionChangeCommand,RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                                                  CommandParameter="{Binding}" />
                                                            </i:EventTrigger>
                                                        </i:Interaction.Triggers>
                                                    </ComboBox>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </DockPanel>
                        
                    </Grid>
                </Border>

            </Grid>
        </Border>

    </Grid>
</UserControl>
