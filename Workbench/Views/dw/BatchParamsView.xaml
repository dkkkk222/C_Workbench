<UserControl x:Class="Workbench.Views.dw.BatchParamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.dw"
             xmlns:viewModels="clr-namespace:Workbench.ViewModels.dw"
             xmlns:views="clr-namespace:Workbench.Views.dw"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewModels:BatchParamsViewModel}">
            <views:BatchParamsView />
        </DataTemplate>
    </UserControl.Resources>
    <Border Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Margin="0,0,15,0">
                        <DockPanel LastChildFill="True">
                            <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top">
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="序列管理列表" FontSize="{StaticResource SubHeadFontSize}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                    <Border>
                                        <hc:UniformSpacingPanel Spacing="10" HorizontalAlignment="Right">
                                            <Button Content="新增序列" Style="{StaticResource ButtonPrimary.Small}" hc:IconElement.Geometry="{StaticResource AddGeometry}"/>
                                            <Button Content="批量下发" Style="{StaticResource ButtonPrimary.Small}" hc:IconElement.Geometry="{StaticResource AllGeometry}"/>
                                        </hc:UniformSpacingPanel>
                                    </Border>
                                </DockPanel>
                            </Border>
                            <DataGrid ItemsSource="{Binding SequenceList}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                              CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Margin" Value="0,0,0,5"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="序列编号" Binding="{Binding Bit}" Width="*"/>
                                    <DataGridTextColumn Header="序列名称" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="参数下发数量" Binding="{Binding DataPull}"  Width="*"/>
                                    <DataGridTextColumn Header="参数下发间隔(us)" Binding="{Binding DataPullResolve}"  Width="*"/>
                                    <DataGridTextColumn Header="下发" Binding="{Binding DataPush}"  Width="*"/>
                                    <DataGridTextColumn Header="下发状态" Binding="{Binding DataPushResolve}"  Width="*"/>
                                    <DataGridTextColumn Header="选择" Binding="{Binding DataPushResolve}"  Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="1">
                        <hc:UniformSpacingPanel Spacing="5" Orientation="Vertical">
                            <Border>
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox ItemsSource="{Binding SettingCategoryList}" Style="{StaticResource ComboBoxExtend}"
                                      hc:InfoElement.Title="分类：" hc:InfoElement.TitlePlacement="Left" Width="180" SelectionChanged="ComboBox_SelectionChanged"
                                      SelectedItem="{Binding CurrentSettingCategory}" DisplayMemberPath="Label" SelectedValuePath="Value"></ComboBox>
                                    <hc:SearchBar Style="{StaticResource SearchBarPlus}" hc:InfoElement.Placeholder="请输入搜索关键字" Margin="10,0,0,0"
                                          Width="180">
                                        <hc:SearchBar.Text>
                                            <Binding Path="TreeKeyword" UpdateSourceTrigger="PropertyChanged"/>
                                        </hc:SearchBar.Text>
                                    </hc:SearchBar>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource DarkDefaultBrush}" Padding="5" CornerRadius="5">
                                <TreeView ItemsSource="{Binding BatchParamTrees}" Height="350">
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource TreeViewItemBaseStyle}">
                                            <!-- 将TreeViewItem的IsExpanded属性绑定到数据模型的IsExpanded属性 -->
                                            <Setter Property="IsExpanded" Value="True" />
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <TextBlock Text="{Binding Title}"/>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </Border>
                        </hc:UniformSpacingPanel>
                    </Border>

                </Grid>
            </Border>
            <hc:Divider Grid.Row="1" Margin="0,8"/>
            <Border Grid.Row="2">
                <DockPanel LastChildFill="True">
                    <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="序列详情:MPPT保护设置" FontSize="{StaticResource SubHeadFontSize}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                            <Border>
                                <hc:UniformSpacingPanel Spacing="10" HorizontalAlignment="Right">
                                    <Button Content="添加到序列" Style="{StaticResource ButtonPrimary.Small}" hc:IconElement.Geometry="{StaticResource AddGeometry}"/>
                                </hc:UniformSpacingPanel>
                            </Border>
                        </DockPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding SequenceList}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                              CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Margin" Value="0,0,0,5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="发送顺序" Binding="{Binding Bit}" Width="*"/>
                            <DataGridTextColumn Header="地址(DEC/HEX)" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding DataPull}"  Width="*"/>
                            <DataGridTextColumn Header="分类" Binding="{Binding DataPullResolve}"  Width="*"/>
                            <DataGridTextColumn Header="子分类" Binding="{Binding DataPush}"  Width="*"/>
                            <DataGridTextColumn Header="数据(HEX)" Binding="{Binding DataPushResolve}"  Width="*"/>
                            <DataGridTextColumn Header="数据(DEC)" Binding="{Binding DataPushResolve}"  Width="*"/>
                            <DataGridTextColumn Header="数据(Binary)" Binding="{Binding DataPushResolve}"  Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

        </Grid>
    </Border>
</UserControl>
