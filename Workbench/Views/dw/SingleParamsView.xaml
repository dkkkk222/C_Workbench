<UserControl x:Class="Workbench.Views.dw.SingleParamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.dw"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:viewModels="clr-namespace:Workbench.ViewModels.dw"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:views="clr-namespace:Workbench.Views.dw"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewModels:SingleParamsViewModel}">
            <views:SingleParamsView />
        </DataTemplate>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>

        </Style>
        <Style x:Key="DataGridTextCenterColumnStyle" TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Width="224" Background="#fafafa" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <hc:SearchBar Style="{StaticResource SearchBarPlus}" hc:InfoElement.Placeholder="请输入搜索关键字" hc:InfoElement.ShowClearButton="True">
                    <hc:SearchBar.Text>
                        <Binding Path="TreeKeyword" UpdateSourceTrigger="PropertyChanged"/>
                    </hc:SearchBar.Text>
                </hc:SearchBar>
                <Border Margin="0,5,0,0" Grid.Row="1">
                    <TreeView ItemsSource="{Binding SingleParamTrees}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectedItemChanged">
                                <i:InvokeCommandAction Command="{Binding SelectedItemChangedCommand}" 
                                 CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Title}"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>
        </Border>
        <Border Grid.Column="1" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <Border>
                        <Border Style="{StaticResource BorderTipPrimary}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="寄存器地址：DEC: " FontSize="{StaticResource SubHeadFontSize}"/>
                                <TextBlock Text="{Binding CurrentRegister.AddressDec}" FontSize="{StaticResource SubHeadFontSize}"/>
                                <TextBlock Text="/HEX: " FontSize="{StaticResource SubHeadFontSize}"/>
                                <TextBlock Text="{Binding CurrentRegister.AddressHex}" FontSize="{StaticResource SubHeadFontSize}"/>
                            </StackPanel>

                        </Border>
                    </Border>
                    <hc:Divider Padding="0" Margin="0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <Border>
                                <hc:UniformSpacingPanel Spacing="10" Orientation="Vertical">
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="数据DEC:" Style="{StaticResource ItemTitle}"/>
                                            <hc:NumericUpDown x:Name="DecValueText" Width="200" Minimum="0" LostFocus="DecValueText_LostFocus">
                                                <hc:NumericUpDown.Value>
                                                    <Binding Path="CurrentRegister.DecValue" UpdateSourceTrigger="PropertyChanged"></Binding>
                                                </hc:NumericUpDown.Value>
                                            </hc:NumericUpDown>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="数据HEX:" Style="{StaticResource ItemTitle}"/>
                                            <TextBox x:Name="HexValueText" Text="{Binding CurrentRegister.HexValue,Mode=TwoWay}" Style="{StaticResource TextBoxExtend}" 
                                                     hc:InfoElement.Placeholder="请输入" Width="200" LostFocus="HexValueText_LostFocus"/>
                                        </StackPanel>
                                    </Border>
                                </hc:UniformSpacingPanel>
                            </Border>
                            <Border Margin="0,10,0,0">
                                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="数据Binary:" Style="{StaticResource ItemTitle}"/>
                                            <ItemsControl ItemsSource="{Binding CurrentRegister.BinaryArray[0],Mode=TwoWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1" Columns="8" Width="200"/>

                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Value}" TextChanged="BinaryTextBox_TextChanged" LostFocus="BinaryTextBox_LostFocus"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="bit->" Style="{StaticResource ItemTitle}"/>
                                            <hc:Row Width="200">
                                                <hc:Col Span="3">
                                                    <TextBlock Text="31" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="30" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="29" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="28" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="27" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="26" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="25" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="24" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                            </hc:Row>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="" Style="{StaticResource ItemTitle}"/>
                                            <ItemsControl ItemsSource="{Binding CurrentRegister.BinaryArray[1],Mode=TwoWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1" Columns="8" Width="200"/>

                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Value}" TextChanged="BinaryTextBox_TextChanged" LostFocus="BinaryTextBox_LostFocus"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="bit->" Style="{StaticResource ItemTitle}"/>
                                            <hc:Row Width="200">
                                                <hc:Col Span="3">
                                                    <TextBlock Text="23" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="22" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="21" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="20" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="19" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="18" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="17" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="16" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                            </hc:Row>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="" Style="{StaticResource ItemTitle}"/>
                                            <ItemsControl ItemsSource="{Binding CurrentRegister.BinaryArray[2],Mode=TwoWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1" Columns="8" Width="200"/>

                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Value}" TextChanged="BinaryTextBox_TextChanged" LostFocus="BinaryTextBox_LostFocus"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="bit->" Style="{StaticResource ItemTitle}"/>
                                            <hc:Row Width="200">
                                                <hc:Col Span="3">
                                                    <TextBlock Text="15" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="14" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="13" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="12" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="11" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="10" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="9" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="8" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                            </hc:Row>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="" Style="{StaticResource ItemTitle}"/>
                                            <ItemsControl ItemsSource="{Binding CurrentRegister.BinaryArray[3],Mode=TwoWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1" Columns="8" Width="200"/>

                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Value}" TextChanged="BinaryTextBox_TextChanged" LostFocus="BinaryTextBox_LostFocus"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="bit->" Style="{StaticResource ItemTitle}"/>
                                            <hc:Row Width="200">
                                                <hc:Col Span="3">
                                                    <TextBlock Text="7" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="6" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="5" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="4" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="3" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="2" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="1" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="0" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                            </hc:Row>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="80,5,0,0">
                                            <Button Content="读 取" Style="{StaticResource ButtonPrimary}" Margin="0,0,15,0" Width="80" 
                                                    IsEnabled="{Binding CurrentRegister.AllowRead}"
                                                    hc:IconElement.Geometry="{StaticResource ReadGeometry}" Command="{Binding ReadRegisterCommand}"/>
                                            <Button Content="下 发" Style="{StaticResource ButtonPrimary}" Width="80" 
                                                    IsEnabled="{Binding CurrentRegister.AllowWrite}"
                                                    hc:IconElement.Geometry="{StaticResource PushGeometry}" Command="{Binding SendRegisterCommand}"/>
                                        </StackPanel>
                                    </Border>
                                </hc:UniformSpacingPanel>
                            </Border>
                        </StackPanel>
                        <Border Grid.Column="1" Padding="15,0,0,0">
                            <DockPanel LastChildFill="True">
                                <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top">
                                    <hc:UniformSpacingPanel Spacing="15">
                                        <TextBlock Text="历史数据" FontSize="14"/>
                                        <Button Content="下载" Style="{StaticResource ButtonPrimary.Small}" hc:IconElement.Geometry="{StaticResource CustomDownload}"
                                                Command="{Binding HistoryDownloadCommand}"/>
                                    </hc:UniformSpacingPanel>
                                </Border>
                                <Border Background="{DynamicResource DarkDefaultBrush}" Margin="0,5,0,0">
                                    <DataGrid ItemsSource="{Binding ReadWriteHistory}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                              CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Height="280">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Margin" Value="0,0,0,5"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="读/写" Binding="{Binding ReadWrite}"  Width="70"/>
                                            <DataGridTextColumn Header="地址" Binding="{Binding Address}"  Width="80"/>
                                            <DataGridTextColumn Header="名称" Binding="{Binding Name}"  Width="*"/>
                                            <DataGridTextColumn Header="数据(HEX)" Binding="{Binding Hex}"  Width="120"/>
                                            <DataGridTextColumn Header="状态" Binding="{Binding State}"  Width="80"/>
                                            <DataGridTextColumn Header="操作时间" Binding="{Binding Datetime}"  Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </DockPanel>
                        </Border>
                    </Grid>
                </StackPanel>
                <hc:Divider Grid.Row="1" Margin="0,8"/>
                <Border Grid.Row="2">
                    <DockPanel LastChildFill="True">
                        <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top">
                            <TextBlock Text="寄存器详情" FontSize="{StaticResource SubHeadFontSize}"/>
                        </Border>
                        <DataGrid ItemsSource="{Binding CurrentRegister.BitFields}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                  CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Margin" Value="0,0,0,5"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="位" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="b"/>
                                                <TextBlock Text="{Binding EndBit}"/>
                                                <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'Length>1',FalseToVisibility=Collapsed}">
                                                    <TextBlock Text="-"/>
                                                    <TextBlock Text="b"/>
                                                    <TextBlock Text="{Binding StartBit}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="名称" Binding="{Binding Desc}" Width="*"/>
                                <DataGridTextColumn Header="数据读取" Binding="{Binding DataPull}"  Width="*"/>
                                <DataGridTextColumn Header="解析" Binding="{Binding DataPullResolve}"  Width="*"/>
                                <DataGridTemplateColumn Header="数据下发" Width="100" >
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Style="{StaticResource TextBoxExtend.Small}" HorizontalAlignment="Stretch"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="配置"  Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox Style="{StaticResource ComboBoxExtend.Small}" ItemsSource="{Binding Options}"
                                                      DisplayMemberPath="Display" SelectedValuePath="Value"
                                                      Visibility="{c:Binding 'Options.Count>0',FalseToVisibility=Collapsed}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>
