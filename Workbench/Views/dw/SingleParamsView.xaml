                                            </hc:Row>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="80,5,0,0">
                                            <Button Content="读 取" Style="{StaticResource ButtonPrimary}" Margin="0,0,15,0" Width="80" hc:IconElement.Geometry="{StaticResource ReadGeometry}"/>
                                            <Button Content="下 发" Style="{StaticResource ButtonPrimary}" Width="80" hc:IconElement.Geometry="{StaticResource PushGeometry}"/>
                                        </StackPanel>
                                    </Border>
                                </hc:UniformSpacingPanel>
                            </Border>
                        </StackPanel>
                        <Border Grid.Column="1" Padding="15,0,0,0">
                            <DockPanel LastChildFill="True">
                                <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top">
                                    <TextBlock Text="历史数据"/>
                                </Border>
                                <Border Background="{DynamicResource DarkDefaultBrush}" Margin="0,5,0,0">
                                    <DataGrid ItemsSource="{Binding HistoryData}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                              CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Margin" Value="0,0,0,5"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="读/写" Binding="{Binding ReadWrite}" CellStyle="{StaticResource DataGridTextCenterColumnStyle}" Width="*"/>
                                            <DataGridTextColumn Header="地址" Binding="{Binding Address}" CellStyle="{StaticResource DataGridTextCenterColumnStyle}" Width="*"/>
                                            <DataGridTextColumn Header="数据(HEX)" Binding="{Binding Hex}" CellStyle="{StaticResource DataGridTextCenterColumnStyle}" Width="*"/>
                                            <DataGridTextColumn Header="数据(Binary)" Binding="{Binding Binary}" CellStyle="{StaticResource DataGridTextCenterColumnStyle}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </DockPanel>
                        </Border>
                    </Grid>
                </StackPanel>
                <hc:Divider Grid.Row="1" Margin="0,8"/>
                <Border Grid.Row="2">
                    <DockPanel LastChildFill="True">
                        <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top">
                            <TextBlock Text="寄存器详情" FontSize="{StaticResource SubHeadFontSize}"/>
                        </Border>
                        <DataGrid ItemsSource="{Binding RegisterInfoList}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                  CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Margin" Value="0,0,0,5"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="位" Binding="{Binding Bit}" Width="*"/>
                                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="数据读取" Binding="{Binding DataPull}"  Width="*"/>
                                <DataGridTextColumn Header="解析" Binding="{Binding DataPullResolve}"  Width="*"/>
                                <DataGridTextColumn Header="数据下发" Binding="{Binding DataPush}"  Width="*"/>
                                <DataGridTextColumn Header="解析" Binding="{Binding DataPushResolve}"  Width="*"/>

                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
