                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <Border>
                                <hc:UniformSpacingPanel Spacing="10" Orientation="Vertical">
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="数据DEC:" Style="{StaticResource ItemTitle}"/>
                                            <TextBox Text="" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="请输入" Width="200"/>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="数据HEX:" Style="{StaticResource ItemTitle}"/>
                                            <TextBox Text="" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="请输入" Width="200"/>
                                        </StackPanel>
                                    </Border>
                                </hc:UniformSpacingPanel>
                            </Border>
                            <Border Margin="0,10,0,0">
                                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="数据Binary:" Style="{StaticResource ItemTitle}"/>
