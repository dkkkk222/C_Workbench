                                            </hc:Row>
                                        </StackPanel>
                                    </Border>
                                    <Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="bit->" Style="{StaticResource ItemTitle}"/>
                                            <hc:Row Width="200">
                                                <hc:Col Span="3">
                                                    <TextBlock Text="31" HorizontalAlignment="Center"/>
                                                </hc:Col>
                                                <hc:Col Span="3">
                                                    <TextBlock Text="30" HorizontalAlignment="Center"/>
                                                </hc:Col>
