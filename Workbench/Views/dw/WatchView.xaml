<UserControl x:Class="Workbench.Views.dw.WatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.dw"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:cvt="clr-namespace:Workbench.Converters"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:utils="clr-namespace:Workbench.Utils"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:controls_Scottplot="clr-namespace:Workbench.Controls.Controls.Scottplot;assembly=Workbench.Controls"
             xmlns:controls_Title="clr-namespace:Workbench.Controls.Controls.Title;assembly=Workbench.Controls"
             xmlns:local_Model="clr-namespace:Workbench.Models"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>       
        <cvt:RowIndexConverter x:Key="RowIndexConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>

        </Style>
        <Storyboard x:Key="ExpandStoryboard">
            <local_Model:GridLengthAnimation Storyboard.TargetName="LeftCol"
                                Storyboard.TargetProperty="Width"
                                From="0" To="300"
                                Duration="0:0:0.18"/>
        </Storyboard>
        <Storyboard x:Key="CollapseStoryboard">
            <local_Model:GridLengthAnimation Storyboard.TargetName="LeftCol"
                                Storyboard.TargetProperty="Width"
                                From="300" To="0"
                                Duration="0:0:0.18"/>
        </Storyboard>

        <!-- ComboBoxItem 样式 -->
        <Style x:Key="CustomComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{StaticResource ComboBoxItem.Small}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Bd" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" 
                Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" 
                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- 选中项鼠标悬停时的背景色 -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="ListBoxItem.IsSelected" Value="False"/>
                        <Condition Property="UIElement.IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Value="{DynamicResource SecondaryRegionBrush}" Property="Background"/>
                </MultiTrigger>
                <!-- 选中项的背景颜色 -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="ListBoxItem.IsSelected" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Value="{DynamicResource PrimaryBrush}" Property="Background"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiTrigger>
                <!-- 设置选中项的背景颜色 -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryBackgroundColor}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- ComboBox 样式 -->
        <Style x:Key="CustomComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ComboBoxExtend.Small}">
            <Setter Property="ItemContainerStyle" Value="{StaticResource CustomComboBoxItemStyle}" />
            <Style.Triggers>
                <!-- 获得焦点时变色 -->
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Name="LeftCol" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Width="324" Background="{StaticResource AvalonDockAreaBackgroundColor}" HorizontalAlignment="Left" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                    <Border Style="{StaticResource BorderCircular}" Margin="0,10,0,0" BorderBrush="Transparent" Background="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <!--<TextBlock Text="寄存器目录" FontSize="{StaticResource SubHeadFontSize}"/>-->
                            <controls_Title:StandTitle Padding="0,0,0,0" BordMargin="0,0,5,0" StandText="寄存器目录" StandFontSize="{DynamicResource SubHeadFontSize}"/>

                        </StackPanel>
                
                    </Border>
                    <hc:UniformSpacingPanel Spacing="8" Orientation="Horizontal" Margin="0,10">
                        <RadioButton GroupName="OrderBy" Content="按分类" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"
             IsChecked="{Binding IsOrderByCategory, Mode=TwoWay}"/>
                        <RadioButton GroupName="OrderBy" Content="按名称" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"
             IsChecked="{Binding IsOrderByName, Mode=TwoWay}"/>
                        <RadioButton GroupName="OrderBy" Content="按地址" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"
             IsChecked="{Binding IsOrderByAddress, Mode=TwoWay}"/>
                        <CheckBox Content="全选/反选" Command="{Binding SelectAllCommand}" CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="false">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>
                    </hc:UniformSpacingPanel>
                </hc:UniformSpacingPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">

                    <Border>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="5"   VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentRegister.AddressHex}"   VerticalAlignment="Center"/>
                            <TextBlock Text=" : "   VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentRegister.Name}"   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <hc:SearchBar Grid.Row="4" hc:InfoElement.Placeholder="请输入搜索关键字" hc:InfoElement.ShowClearButton="True">
                    <hc:SearchBar.Style>
                        <Style TargetType="hc:SearchBar" BasedOn="{StaticResource SearchBarPlus}">
                            <Style.Triggers>
                                <!-- 获得焦点时变色 -->
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </hc:SearchBar.Style>
                    <hc:SearchBar.Text>
                        <Binding Path="TreeKeyword" UpdateSourceTrigger="PropertyChanged"/>
                    </hc:SearchBar.Text>
                </hc:SearchBar>
                <Border Margin="0,5,0,0" Grid.Row="5">
                    <TreeView ItemsSource="{Binding SingleParamTrees}"  Background="{DynamicResource InLeftTreeViewBackGround}">
                        <TreeView.Resources>
                            <!-- ★ 继承原样式，只追加两个 Setter -->
                            <Style x:Key="BindableTreeViewItemStyle"
                                TargetType="TreeViewItem"
                                BasedOn="{StaticResource TreeViewItemStyle}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.Resources>

                        <!-- 只影响当前这棵 TreeView -->
                        <TreeView.ItemContainerStyle>
                            <StaticResource ResourceKey="BindableTreeViewItemStyle"/>
                        </TreeView.ItemContainerStyle>
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectedItemChanged">
                                <i:InvokeCommandAction Command="{Binding SelectedItemChangedCommand}" 
                                 CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel>
                                    <TextBlock Visibility="{c:Binding 'AddressHex==null',FalseToVisibility=Collapsed}" Text="{Binding Title}" Foreground="{DynamicResource TreeViewNodeBrush}"/>
                                    <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'AddressHex!=null',FalseToVisibility=Collapsed}">
                                       
                                      
                                            <CheckBox x:Name="cb"  IsChecked="{Binding IsCheck}" Command="{Binding DataContext.CheckChangeCommand, RelativeSource={RelativeSource AncestorType=TreeView}}" CommandParameter="{Binding}">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCheck}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCheck}" Value="false">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                            </CheckBox>                                         
                                        
                                        <TextBlock Width="5"></TextBlock>
                                        <TextBlock Text="{Binding AddressHex}" Foreground="{DynamicResource TreeViewNodeBrush}"/>
                                        <TextBlock Text=" : "/>
                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TreeViewNodeBrush}"/>
                                 
                                    </StackPanel>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>
        </Border>
        <Border Background="{StaticResource AvalonDockAreaBackgroundColor}"   Grid.Column="1" Padding="0,8,28,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Margin="2,0,0,0">
                    <DockPanel LastChildFill="True">
                        <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top"  Background="Transparent" BorderBrush="Transparent">

                            <DockPanel LastChildFill="True" Margin="-8,0,-10,0">
                                <controls_Title:StandTitle Padding="0,0,0,0" x:Name="tbx_control" BordMargin="0,0,5,0" StandText="监测数据配置" StandFontSize="{DynamicResource SubHeadFontSize}"/>

                                <!--<TextBlock Text="监测数据配置" FontSize="{StaticResource SubHeadFontSize}"/>-->
                                <TextBlock Width="10"></TextBlock>
                                <Button Style="{StaticResource ButtonDefault.Small}" Width="116" Margin="0,0,0,6"
        ToolTip="展开/收起寄存器目录" Content="展开寄存器目录" Visibility="{c:Binding !IsLeftOpen,FalseToVisibility=Collapsed}"
        Command="{Binding ToggleDrawerCommand}" hc:IconElement.Geometry="{StaticResource  AlignLeftGeometry}"/>
                                <Button Style="{StaticResource ButtonDefault.Small}" Width="116" Margin="0,0,0,6"
ToolTip="展开/收起寄存器目录" Content="收起寄存器目录" Visibility="{c:Binding IsLeftOpen,FalseToVisibility=Collapsed}"
Command="{Binding ToggleDrawerCommand}" hc:IconElement.Geometry="{StaticResource AlignRightGeometry}" />
                                <TextBox Text="{Binding AllTime,Mode=TwoWay}"   Margin="5,0,0,6" hc:InfoElement.TitlePlacement="Left" Width="60" >
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxExtend.Small}">
                                            <Style.Triggers>
                                                <!-- 获得焦点时变色 -->
                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <Button Content="批量设置时间" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource ShowPageButtonBackgroundColor}" BorderBrush="{DynamicResource ShowPageButtonBackgroundColor}"   
HorizontalAlignment="Left" hc:IconElement.Width="14"  Margin="5,0,0,6"
Command="{Binding SettingAllTimeCommand}"/>
                                <TextBlock Width="10"></TextBlock>
                                <ComboBox  ItemsSource="{Binding RecordTimeSource}" DisplayMemberPath="Display"  Width="70" Style="{DynamicResource CustomComboBoxStyle}"
           SelectedValuePath="Key" hc:InfoElement.Placeholder="请选择" SelectedValue="{Binding SelectRecordTimeType,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                   
                                </ComboBox>
                                <TextBlock Width="10"></TextBlock>
                                <Button Content="批量设置时间单位" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource ShowPageButtonBackgroundColor}" BorderBrush="{DynamicResource ShowPageButtonBackgroundColor}"   
HorizontalAlignment="Left" hc:IconElement.Width="14"  Margin="0,0,0,6"
Command="{Binding SettingAllUnitCommand}"/>
                                <TextBlock Width="10"></TextBlock>
                                <ComboBox ItemsSource="{Binding WatchGroups,Mode=TwoWay}"  Width="70" Style="{DynamicResource CustomComboBoxStyle}"
                                     DisplayMemberPath="Header" SelectedValue="{Binding SelectTab,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" >
                                     
                                </ComboBox>
                                <TextBlock Width="10"></TextBlock>
                                <Button Content="批量设置表" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource ShowPageButtonBackgroundColor}" BorderBrush="{DynamicResource ShowPageButtonBackgroundColor}"   
HorizontalAlignment="Left" hc:IconElement.Width="14"  Margin="5,0,0,6"
Command="{Binding SettingAllTableCommand}"/>
                                <TextBlock Width="10"></TextBlock>
                                <hc:UniformSpacingPanel Spacing="10" HorizontalAlignment="Right">
                                    <Button Content="全部开始监测" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource StartButtonBackground}" BorderBrush="{DynamicResource StartButtonBackground}"   
HorizontalAlignment="Left" hc:IconElement.Width="14" 
Command="{Binding StartAllCommand}"/> 
                                <Button Content="全部停止监测" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource StopButtonBackground}" BorderBrush="{DynamicResource StopButtonBackground}"  
HorizontalAlignment="Right" hc:IconElement.Width="14"  
Command="{Binding StopAllCommand}"/>
                                </hc:UniformSpacingPanel>
                            </DockPanel>
                            
                        </Border>
                        <!--<Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top"  Background="Transparent" BorderBrush="Transparent">-->
                            
                            <DataGrid    MinWidth="200" Grid.Row="1" ItemsSource="{Binding CategoryRegisters}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
               CanUserSortColumns="False" CanUserAddRows="False" Margin="0,0,0,0" MinHeight="200" IsReadOnly="True"   RowHeight="40"
                                         Background="{DynamicResource DataGridBackgroundColor}" AlternationCount="2" CanUserResizeColumns="True"    
               SelectedItem="{Binding CurrentRegister}" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="{x:Type DataGridColumnHeader}"  >
                                        <Setter Property="Padding" Value="10,0,0,0"/>
                                        <Setter Property="Margin" Value="0,0,12,0"/>
                                        <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                        <Setter Property="Foreground" Value="{StaticResource DataGridHeTextBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="13"/> 
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                        <Setter Property="BorderThickness" Value="1,0,0,1" />
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
     Color="Transparent"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
     Color="#3D7EFF"/>
                                </DataGrid.Resources>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                        <Setter Property="Margin" Value="8,0,12,0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <!-- 前景色跟随行 -->
                                        <Setter Property="Foreground"
Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>

                                        <Style.Triggers>
                                            <!-- 选中 -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>

                                            <!-- 选中 + DataGrid失焦（例如右键弹菜单） -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </MultiDataTrigger>

                                            <!-- Hover 时也别盖住整行背景 -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Height" Value="40"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="SnapsToDevicePixels" Value="True" />
                                        <!-- 新增：默认不加粗 -->
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Style.Triggers>
                                            <Trigger Property="AlternationIndex" Value="1">
                                                <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Trigger>
                                            <!-- 选中（鼠标不在上面） -->
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                <!-- 白字 -->
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <!-- 去掉分割线 -->
                                            </MultiTrigger>

                                            <!-- 选中 + 悬停 -->
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </MultiTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding AddressHex}" Header="寄存器地址(HEX)" Width="*"  MinWidth="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="ToolTip" Value="{Binding AddressHex}"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Category}" Header="分类" Width="*"  MinWidth="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="ToolTip" Value="{Binding Category}"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding SubCategory}" Header="子分类" Width="*" MinWidth="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="ToolTip" Value="{Binding SubCategory}"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Name}" Header="寄存器名称" Width="*"  MinWidth="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="ToolTip" Value="{Binding Name}"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding HexValue}" Header="数据(HEX)" Width="*" MinWidth="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="ToolTip" Value="{Binding HexValue}"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="监测时间" Width="Auto" MinWidth="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <hc:NumericUpDown Width="80" Minimum="0">
                                                        <hc:NumericUpDown.Style>
                                                            <Style TargetType="hc:NumericUpDown" BasedOn="{StaticResource NumericUpDownExtend.Small}">
                                                                    <Style.Triggers>
                                                                        <!-- 获得焦点时变色 -->
                                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>                                                         
                                                        </hc:NumericUpDown.Style>
                                                        <hc:NumericUpDown.Value>
                                                            <Binding Path="RecordTime" UpdateSourceTrigger="PropertyChanged"/>
                                                        </hc:NumericUpDown.Value>
                                                    </hc:NumericUpDown>
                                                    <TextBlock Text="" VerticalAlignment="Center" Width="5"/>
                                                <ComboBox  ItemsSource="{Binding RecordTimeSource}" DisplayMemberPath="Display" Style="{StaticResource CustomComboBoxStyle}"
                                                              SelectedValuePath="Key" hc:InfoElement.Placeholder="请选择" SelectedValue="{Binding RecordTimeTypeItem,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center">
                                                         
                                                    </ComboBox>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="开始" Width="*" MinWidth="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="开始监测" VerticalAlignment="Center" Style="{StaticResource ButtonInfo.Small}" BorderThickness="0" Background="{DynamicResource StartButtonBackground}" HorizontalAlignment="Left"  IsEnabled="{c:Binding !IsStartRecord}"
                             Command="{Binding Path=DataContext.BeginRecordCommand,RelativeSource={RelativeSource AncestorType=DataGrid}}" Height="23"
                             CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="停止" Width="*"  MinWidth="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="停止监测" VerticalAlignment="Center" Style="{StaticResource ButtonWarning.Small}" BorderThickness="0" Background="{DynamicResource StopButtonBackground}" HorizontalAlignment="Left"  IsEnabled="{c:Binding IsStartRecord}"
                              Command="{Binding Path=DataContext.StopRecordCommand,RelativeSource={RelativeSource AncestorType=DataGrid}}" Height="23"
                              CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="添加到数据监测表" Width="*"  MinWidth="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center">
                                                <ComboBox ItemsSource="{Binding Path=DataContext.WatchGroups,RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource CustomComboBoxStyle}"
                                                              DisplayMemberPath="Header" SelectedValue="{Binding TableId,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Id" >
                                                       
                                                        <i:Interaction.Triggers>
                                                            <i:EventTrigger EventName="SelectionChanged">
                                                                <i:InvokeCommandAction Command="{Binding DataContext.TableChangeCommand,RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                         CommandParameter="{Binding}" />
                                                            </i:EventTrigger>
                                                        </i:Interaction.Triggers>
                                                    </ComboBox>
                                                </StackPanel>
                                               
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        <!--</Border>-->


                        <!--</StackPanel>-->
                    </DockPanel>
                </Border>
                <GridSplitter Grid.Row="1" Margin="2,10,0,10" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{StaticResource GridSplitterBordColor}" ResizeDirection="Rows"></GridSplitter>

                <Grid Grid.Row="2" Margin="2,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="0,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="增加数据监测表" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource StartButtonBackground}" BorderBrush="{DynamicResource StartButtonBackground}"  hc:IconElement.Geometry="{StaticResource AddGeometry}"
                   HorizontalAlignment="Left" hc:IconElement.Width="14"
                   Command="{Binding AddWatchGroupCommand}"/>
                            <TextBlock Width="10"></TextBlock>
                            <Button Content="增加数据监测图" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource StopButtonBackground}"  BorderBrush="{DynamicResource StopButtonBackground}"  hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                    HorizontalAlignment="Left" hc:IconElement.Width="14"
                                    Command="{Binding AddWatchGroupChartCommand}"/>
                            <TextBlock Width="10"></TextBlock>
                            <Button Content="展示数据监测表" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource StartButtonBackground}" BorderBrush="{DynamicResource StartButtonBackground}"  hc:IconElement.Geometry="{StaticResource  PushGeometry}"
                                    HorizontalAlignment="Left" hc:IconElement.Width="14"
                                    Command="{Binding ShowWatchGroupCommand}"/>
                            <TextBlock Width="10"></TextBlock>
                            <Button Content="展示数据监测图" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource StopButtonBackground}" BorderBrush="{DynamicResource StopButtonBackground}"   hc:IconElement.Geometry="{StaticResource   HTabGroup}"
                                    HorizontalAlignment="Left" hc:IconElement.Width="14"
                                    Command="{Binding ShowChartGroupCommand}"/>
                        </StackPanel>

                    </Border>
                    <Border Grid.Row="1" Padding="0,0,0,0" Background="{StaticResource AvalonDockAreaBackgroundColor}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"></ColumnDefinition>
                                <ColumnDefinition Width="10"></ColumnDefinition>
                                <ColumnDefinition Width="1.3*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <hc:TabControl Grid.Row="2" IsAnimationEnabled="True" Margin="0,5,0,0" ShowCloseButton="False" IsDraggable="True" Background="{StaticResource AvalonDockAreaBackgroundColor}"
                                   ItemsSource="{Binding WatchGroupsForTab}" ShowOverflowButton="False"  IsScrollable="True"  OverflowMenuDisplayMemberPath="Header" SelectedItem="{Binding CurrentTab}" Visibility="{Binding HasRealTables, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TabControl.ItemTemplate> 
                                    <DataTemplate >
                                        <StackPanel Orientation="Horizontal" Width="Auto">
                                            <TextBlock Text="{Binding Header}"  FontWeight="Black"/>
                                            <Button   Margin="130,0,0,0" Foreground="Black" Style="{StaticResource ButtonPrimary.Small}" BorderBrush="Transparent" Background="Transparent" hc:IconElement.Geometry="{StaticResource CloseGeometry}" Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>

                                        </StackPanel>

                                    </DataTemplate>
                                </TabControl.ItemTemplate>
                                
                                <TabControl.ContentTemplate>
                                    <DataTemplate>
                                        <Border Padding="5" Background="{StaticResource AvalonDockAreaBackgroundColor}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <DockPanel LastChildFill="True" Grid.Column="0" Grid.ColumnSpan="2">
                                                    <Border Style="{StaticResource BorderCircular}" Margin="5,5,0,5" DockPanel.Dock="Top"  Background="{StaticResource TitleBarBackgroundColor}" BorderBrush="Transparent">
                                                        <DockPanel>
                                                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                                <!--<TextBlock Text="{Binding TableName}" FontSize="{StaticResource SubHeadFontSize}" VerticalAlignment="Center"/>-->
                                                                <controls_Title:StandTitle Padding="0,5,0,0" BordMargin="0,0,5,0" StandText="{Binding TableName}" StandFontSize="{DynamicResource SubHeadFontSize}"/>

                                                                <Button Style="{StaticResource ButtonDefault.Small}" hc:IconElement.Geometry="{StaticResource PenGeometry}"
                                                                Margin="5,3,0,0" 
                                                                Command="{Binding RenameCommand}"
                                                                CommandParameter="Table"/>
                                                                
                                                            </StackPanel>
                                                        
                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
 
                                                                <ComboBox ItemsSource="{Binding Path=DataContext.WatchChartGroups,RelativeSource={RelativeSource AncestorType=UserControl}}"
                         DisplayMemberPath="Header"  SelectedValuePath="Id" MinWidth="70" Style="{StaticResource CustomComboBoxStyle}" VerticalAlignment="Center"
           SelectedValue="{Binding DataContext.SelectedChartValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,RelativeSource={RelativeSource AncestorType=UserControl}}">

                                                                </ComboBox>
                                                                <TextBlock Width="10"></TextBlock>
                                                                <Button DockPanel.Dock="Right" Content="批量设置图" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource ShowPageButtonBackgroundColor}" BorderBrush="{DynamicResource ShowPageButtonBackgroundColor}" 
 Command="{Binding DataContext.BatchChartCommand,RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                                <TextBlock Width="10"></TextBlock>
                                                                <Button DockPanel.Dock="Right" Content="下载" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource GenButtonBackgroundColor}" BorderBrush="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource CustomDownload}"
                                                                Command="{Binding DataContext.HistoryDownloadCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                                <TextBlock Width="10"></TextBlock>
                                                                <hc:SplitButton DockPanel.Dock="Right" Content="显示列：" Style="{StaticResource SplitButtonDefault}" HorizontalAlignment="Right">
                                                                    <hc:SplitButton.DropDownContent>
                                                                        <ItemsControl ItemsSource="{Binding TableColumns}">
                                                                            <ItemsControl.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                    <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5"/>
                                                                                </ItemsPanelTemplate>
                                                                            </ItemsControl.ItemsPanel>
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <Border Padding="8,0">
                                                                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                                                            <CheckBox.Style>
                                                                                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                                                                                            <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                                                                        </DataTrigger>
                                                                                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="false">
                                                                                                            <Setter Property="Background" Value="Transparent"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </CheckBox.Style>
                                                                                        </CheckBox>
                                                                                    </Border>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </hc:SplitButton.DropDownContent>
                                                                </hc:SplitButton>

                                                            </StackPanel>
                                                        </DockPanel>
                                                    </Border>
                                                    <DataGrid ItemsSource="{Binding BitFields}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                                      CanUserSortColumns="False" CanUserAddRows="False" Margin="0,5,0,0" RowHeight="40"
                                                     Background="{DynamicResource DataGridBackgroundColor}" AlternationCount="2"
                                                      SelectedItem="{Binding CurrentSequence}"  ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      x:Name="MyDataGrid">
                                                        <DataGrid.ColumnHeaderStyle>
                                                            <Style TargetType="{x:Type DataGridColumnHeader}"  >
                                                                <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                                <Setter Property="FontSize" Value="13"/>
                                                                <Setter Property="Padding" Value="0,0,0,0"/>
                                                                <Setter Property="Margin" Value="0,0,0,0"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                                                <Setter Property="BorderThickness" Value="1,0,0,1" />
                                                            </Style>
                                                        </DataGrid.ColumnHeaderStyle>
                                                        <DataGrid.Resources>
                                                            <utils:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
                                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#3D7EFF"/>
                                                        </DataGrid.Resources>
                                                        <DataGrid.CellStyle>
                                                            <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                                                <Setter Property="Margin" Value="8,0,12,0"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                                <!-- 前景色跟随行 -->
                                                                <Setter Property="Foreground"
Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>

                                                                <Style.Triggers>
                                                                    <!-- 选中 -->
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                                    </Trigger>

                                                                    <!-- 选中 + DataGrid失焦（例如右键弹菜单） -->
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                                    </MultiDataTrigger>

                                                                    <!-- Hover 时也别盖住整行背景 -->
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </DataGrid.CellStyle>
                                                        <DataGrid.RowStyle>
                                                            <Style TargetType="DataGridRow">
                                                                <Setter Property="Height" Value="40"/>
                                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                                <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                                <Setter Property="SnapsToDevicePixels" Value="True" />
                                                                <!-- 新增：默认不加粗 -->
                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="AlternationIndex" Value="1">
                                                                        <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                    </Trigger>
                                                                    <!-- 选中（鼠标不在上面） -->
                                                                    <MultiTrigger>
                                                                        <MultiTrigger.Conditions>
                                                                            <Condition Property="IsSelected" Value="True"/>
                                                                            <Condition Property="IsMouseOver" Value="False"/>
                                                                        </MultiTrigger.Conditions>
                                                                        <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                                        <!-- 白字 -->
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                        <!-- 去掉分割线 -->
                                                                    </MultiTrigger>

                                                                    <!-- 选中 + 悬停 -->
                                                                    <MultiTrigger>
                                                                        <MultiTrigger.Conditions>
                                                                            <Condition Property="IsSelected" Value="True"/>
                                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                                        </MultiTrigger.Conditions>
                                                                        <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                    </MultiTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </DataGrid.RowStyle>
                                                        <DataGrid.Columns>
                                                            <DataGridTemplateColumn  Header="序号" Width="45"  MinWidth="45" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[0].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <TextBlock.Text>
                                                                                <MultiBinding Converter="{StaticResource RowIndexConverter}">
                                                                                    <Binding />
                                                                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                                                </MultiBinding>
                                                                            </TextBlock.Text>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <!--<DataGridTextColumn Binding="{Binding Desc}" Header="名称" Width="Auto" MinWidth="30"
                                                                        Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[1].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>-->
                                                            <DataGridTemplateColumn Header="名称" Width="Auto" MinWidth="30" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[1].IsChecked,
                                                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                                                <!-- 显示状态 -->
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Desc}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTemplateColumn Header="寄存器地址(HEX)" Width="Auto"
                                                                            Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[2].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" >
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock HorizontalAlignment="Center" Text="{Binding AddressHexName}" VerticalAlignment="Center"/>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTextColumn Header="寄存器值(HEX)" Width="Auto" IsReadOnly="True" Binding="{Binding SourceHex}" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[3].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}">
                                                             
                                                            </DataGridTextColumn>
                                                            <DataGridTemplateColumn Header="解析内容(bit)" Width="75"
                                                                            Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[4].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <TextBlock Text="b"/>
                                                                            <TextBlock Text="{Binding EndBit}"/>
                                                                            <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'Length>1',FalseToVisibility=Collapsed}">
                                                                                <TextBlock Text="-"/>
                                                                                <TextBlock Text="b"/>
                                                                                <TextBlock Text="{Binding StartBit}"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTemplateColumn Header="解析要求" Width="Auto"  MinWidth="70"  Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[5].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" >
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Visible" HorizontalAlignment="Center" Margin="0,0,0,0">
                                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding FormParam.ParamName}" TextWrapping="Wrap"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </StackPanel>
                                                                        </ScrollViewer>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTextColumn Header="解析结果" Binding="{Binding Result}"  IsReadOnly="True" MinWidth="70" Width="Auto" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[6].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                                            <DataGridTextColumn Header="解析内容(hex)" Binding="{Binding Value}" IsReadOnly="True" Width="Auto" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[7].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                                            <DataGridTextColumn Header="解析内容(binery)" Binding="{Binding ReadBinary}" IsReadOnly="True" Width="Auto" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[8].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                                            <DataGridTextColumn Header="单位"  Binding="{Binding FormParam.UnitName}"  IsReadOnly="True" MinWidth="50" Width="Auto" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[9].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"></DataGridTextColumn>
                                                            <DataGridTemplateColumn Header="添加到监测图" Width="Auto" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[10].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <ComboBox ItemsSource="{Binding Path=DataContext.WatchChartGroups,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                                    DisplayMemberPath="Header"  SelectedValuePath="Id" MinWidth="70" Style="{StaticResource CustomComboBoxStyle}"
                                                                                      SelectedValue="{Binding SelectedChartValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                                          
                                                                                <i:Interaction.Triggers>
                                                                                    <i:EventTrigger EventName="SelectionChanged">
                                                                                        <i:InvokeCommandAction Command="{Binding DataContext.ChartTableChangeCommand,RelativeSource={RelativeSource AncestorType=UserControl}}" PassEventArgsToCommand="True"  />
                                                                             
                                                                                    </i:EventTrigger>
                                                                                </i:Interaction.Triggers>
                                                                                 
                                                                            </ComboBox>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                        </DataGrid.Columns>

                                                    </DataGrid>
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </TabControl.ContentTemplate>
                            </hc:TabControl>

                            <GridSplitter Grid.Column="1" Margin="0,5,0,0" Width="5" Background="{StaticResource GridSplitterBordColor}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></GridSplitter>
                            <hc:TabControl Grid.Row="2" Grid.Column="2" IsAnimationEnabled="True" Margin="0,5,0,0" ShowCloseButton="False" 
                                           IsDraggable="True" Background="{StaticResource AvalonDockAreaBackgroundColor}" IsScrollable="True" ShowOverflowButton="False"
        ItemsSource="{Binding WatchChartGroupsForTab}" OverflowMenuDisplayMemberPath="Header" SelectedItem="{Binding CurrentChartTab}"
                                           Visibility="{Binding HasRealCharts, Converter={StaticResource BooleanToVisibilityConverter}}">
                               
                                <TabControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Width="Auto">
                                            <TextBlock Text="{Binding Header}" FontWeight="Black"/>
                                            <Button   Margin="130,0,0,0" Foreground="Black" Style="{StaticResource ButtonPrimary.Small}" BorderBrush="Transparent" Background="Transparent" hc:IconElement.Geometry="{StaticResource CloseGeometry}" Command="{Binding DataContext.CloseChartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </TabControl.ItemTemplate>
                                <TabControl.ContentTemplate>
                                    <DataTemplate>
                                        <DockPanel LastChildFill="True" Grid.Column="1" Margin="0,0,0,0">
                                            <!--BorderTipPrimary-->
                                            <Border Style="{StaticResource BorderClip}" Margin="0,0,0,0"  CornerRadius="0" DockPanel.Dock="Top" VerticalAlignment="Center" Background="{StaticResource TitleBarBackgroundColor}" BorderBrush="Transparent">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition></RowDefinition>
                                                        <RowDefinition></RowDefinition>
                                                    </Grid.RowDefinitions>
                                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="4">

                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition></RowDefinition>
                                                                <RowDefinition></RowDefinition>
                                                                <RowDefinition></RowDefinition>
                                                            </Grid.RowDefinitions>
                                                            <StackPanel Orientation="Horizontal">
                                                                <controls_Title:StandTitle Padding="0,0,0,0" BordMargin="10,0,5,0" Margin="0,0,0,0" TextMargin="0,0,0,0"  StandText="{Binding ChartName}" StandFontSize="{DynamicResource SubHeadFontSize}"/>

                                                                <Button Style="{StaticResource ButtonDefault.Small}" hc:IconElement.Geometry="{StaticResource PenGeometry}" Margin="5,0,5,0"  Command="{Binding RenameCommand}" CommandParameter="Chart"/>
                                                                <!--<Button Style="{StaticResource ButtonPrimary}" Content="设置" Background="{DynamicResource GenButtonBackgroundColor}"  BorderBrush="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource  PenGeometry }"
Margin="5,0,0,0"  Command="{Binding SettingChartLimitCommand}" CommandParameter="{Binding}"/>-->
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,0">
                                                                <TextBox Text="{Binding Chart1MinX}"   hc:InfoElement.Title="X最小值："  Margin="5,0,0,0" hc:InfoElement.TitlePlacement="Left" Width="110" >
                                                                    <TextBox.Style>
                                                                        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxExtend.Small}">
                                                                            <Style.Triggers>
                                                                                <!-- 获得焦点时变色 -->
                                                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                                    <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBox.Style>
                                                                </TextBox>
                                                                <TextBox Text="{Binding Chart1MaxX}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="X最大值："  Margin="5,0,0,0" hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                                <TextBox Text="{Binding Chart1MinY}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="Y最小值："  Margin="5,0,0,0" hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                                <TextBox Text="{Binding Chart1MaxY}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="Y最大值："  Margin="5,0,0,0" hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                                <TextBox Text="{Binding ChartXName,Mode=TwoWay}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="X名称："  Margin="5,0,0,0" hc:InfoElement.TitlePlacement="Left" Width="100" />
                                                                <TextBox Text="{Binding ChartYName,Mode=TwoWay}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="Y名称："  Margin="5,0,0,0" hc:InfoElement.TitlePlacement="Left" Width="98" />

                                                                <Button Style="{StaticResource ButtonPrimary}" Content="设置" Background="{DynamicResource GenButtonBackgroundColor}"  BorderBrush="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource  PenGeometry }"
           Margin="5,0,0,0"  Command="{Binding SettingChartLimitCommand}" CommandParameter="{Binding}"/>
                                                            </StackPanel>
                                                            <!--<StackPanel Grid.Row="2"  Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0">
                                                                <TextBlock Width="348"/>
                                                                <TextBox Text="{Binding ChartXName,Mode=TwoWay}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="X名称："  Margin="0,0,12,0"
hc:InfoElement.TitlePlacement="Left" Width="100" />

                                                                <TextBox Text="{Binding ChartYName,Mode=TwoWay}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="Y名称："  Margin="5,0,5,0"
hc:InfoElement.TitlePlacement="Left" Width="98" />
                                                            </StackPanel>-->
                                                        </Grid>

                                                     
                                                        
                                                    </StackPanel>
                                                    
                                                </Grid>
                                       
                                            </Border>
                                            <Border Margin="0,1,0,0">
                                                <!--<ContentControl Content="{Binding WpfPlotControl,Mode=TwoWay}"/>-->
                                                <controls_Scottplot:LiveDataPlot PlotData="{Binding WpfPlotControl,Mode=TwoWay}"/>
                                            </Border>
                                        </DockPanel>                   
                                    </DataTemplate>                           
                                
                                </TabControl.ContentTemplate>
                            </hc:TabControl>
                            
                        </Grid>
                        
                    </Border>

                </Grid>
            </Grid>
        </Border>
    </Grid>
    
</UserControl>
