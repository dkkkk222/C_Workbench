<UserControl x:Class="Workbench.Views.dw.WatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.dw"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:cvt="clr-namespace:Workbench.Converters"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:utils="clr-namespace:Workbench.Utils"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:local_Model="clr-namespace:Workbench.Models"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <cvt:RowIndexConverter x:Key="RowIndexConverter"/>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>

        </Style>
        <Storyboard x:Key="ExpandStoryboard">
            <local_Model:GridLengthAnimation Storyboard.TargetName="LeftCol"
                                Storyboard.TargetProperty="Width"
                                From="0" To="324"
                                Duration="0:0:0.18"/>
        </Storyboard>
        <Storyboard x:Key="CollapseStoryboard">
            <local_Model:GridLengthAnimation Storyboard.TargetName="LeftCol"
                                Storyboard.TargetProperty="Width"
                                From="324" To="0"
                                Duration="0:0:0.18"/>
        </Storyboard>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Name="LeftCol" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Width="332" Background="#fafafa" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                    <Border Style="{StaticResource BorderTipPrimary}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="寄存器目录" FontSize="{StaticResource SubHeadFontSize}"/>
                        </StackPanel>
                    </Border>
                    <hc:UniformSpacingPanel Spacing="8" Orientation="Horizontal" Margin="0,10">
                        <RadioButton GroupName="OrderBy" Content="按分类"
             IsChecked="{Binding IsOrderByCategory, Mode=TwoWay}"/>
                        <RadioButton GroupName="OrderBy" Content="按名称"
             IsChecked="{Binding IsOrderByName, Mode=TwoWay}"/>
                        <RadioButton GroupName="OrderBy" Content="按地址"
             IsChecked="{Binding IsOrderByAddress, Mode=TwoWay}"/> 
                    </hc:UniformSpacingPanel>
                </hc:UniformSpacingPanel>
                <StackPanel  Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                    <ComboBox Grid.Row="1"  ItemsSource="{Binding SettingCategoryList}" Style="{StaticResource ComboBoxExtend}"
hc:InfoElement.Title="分类：" hc:InfoElement.TitlePlacement="Left" Width="130"
SelectedItem="{Binding CurrentCategory}" DisplayMemberPath="Label" SelectedValuePath="Value"></ComboBox>
                    <TextBlock Width="10"></TextBlock>
                    <ComboBox ItemsSource="{Binding CategoryAddressList}" Style="{StaticResource ComboBoxExtend}"
hc:InfoElement.Title="地址：" hc:InfoElement.TitlePlacement="Left" Width="167"
SelectedItem="{Binding CategoryAddress}" DisplayMemberPath="Label" SelectedValuePath="Value"></ComboBox>
                </StackPanel>
                <!--<StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">

                    <Border>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="所选寄存器:" Style="{StaticResource ItemTitle}" VerticalAlignment="Center"/>
                            <TextBlock Width="5"></TextBlock>
                            <TextBlock Text="{Binding CurrentRegister.Name}" Style="{StaticResource ItemTitle}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Width="10"></TextBlock>
                    <Border>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="地址:" Style="{StaticResource ItemTitle}" VerticalAlignment="Center"/>
                            <TextBlock Width="10"></TextBlock>
                            <TextBlock Text="{Binding CurrentRegister.AddressHex}" Style="{StaticResource ItemTitle}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>-->
                <hc:SearchBar Grid.Row="3" Style="{StaticResource SearchBarPlus}" hc:InfoElement.Placeholder="请输入搜索关键字" hc:InfoElement.ShowClearButton="True">
                    <hc:SearchBar.Text>
                        <Binding Path="TreeKeyword" UpdateSourceTrigger="PropertyChanged"/>
                    </hc:SearchBar.Text>
                </hc:SearchBar>
                <Border Margin="0,5,0,0" Grid.Row="4">
                    <TreeView ItemsSource="{Binding SingleParamTrees}">
                        <TreeView.Resources>
                            <!-- ★ 继承原样式，只追加两个 Setter -->
                            <Style x:Key="BindableTreeViewItemStyle"
                                TargetType="TreeViewItem"
                                BasedOn="{StaticResource TreeViewItemStyle}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.Resources>

                        <!-- 只影响当前这棵 TreeView -->
                        <TreeView.ItemContainerStyle>
                            <StaticResource ResourceKey="BindableTreeViewItemStyle"/>
                        </TreeView.ItemContainerStyle>
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectedItemChanged">
                                <i:InvokeCommandAction Command="{Binding SelectedItemChangedCommand}" 
                                 CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel>
                                    <TextBlock Visibility="{c:Binding 'AddressHex==null',FalseToVisibility=Collapsed}" Text="{Binding Title}"/>
                                    <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'AddressHex!=null',FalseToVisibility=Collapsed}">
                                        <TextBlock Text="{Binding AddressHex}"/>
                                        <TextBlock Text=" : "/>
                                        <TextBlock Text="{Binding Title}"/>
                                        <TextBlock Width="10"></TextBlock>
                                        <CheckBox IsChecked="{Binding IsCheck}"></CheckBox>
                                    </StackPanel>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>
        </Border>
        <Border Background="#fafafa"   Grid.Column="1" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0">
                    <DockPanel LastChildFill="True">
                        <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="监控数据配置" FontSize="{StaticResource SubHeadFontSize}"/>
                                <TextBlock Width="10"></TextBlock>
                                <Button Style="{StaticResource ButtonDefault.Small}" Width="86"
        ToolTip="展开/收起目录" Content="展开目录" Visibility="{c:Binding !IsLeftOpen,FalseToVisibility=Collapsed}"
        Command="{Binding ToggleDrawerCommand}" hc:IconElement.Geometry="{StaticResource  AlignLeftGeometry}"/>
                                <Button Style="{StaticResource ButtonDefault.Small}" Width="86"
ToolTip="展开/收起目录" Content="收起目录" Visibility="{c:Binding IsLeftOpen,FalseToVisibility=Collapsed}"
Command="{Binding ToggleDrawerCommand}" hc:IconElement.Geometry="{StaticResource AlignRightGeometry}" />
                            </StackPanel>
                            
                        </Border>
                        <!--<StackPanel Orientation="Vertical">-->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Border Margin="0,8,0,0" Grid.Row="0">
                                <hc:UniformSpacingPanel Spacing="20" Orientation="Horizontal">
                                    <ComboBox ItemsSource="{Binding SettingCategoryList}" Style="{StaticResource ComboBoxExtend}"
                   hc:InfoElement.Title="分类：" hc:InfoElement.TitlePlacement="Left" Width="180"
                   SelectedItem="{Binding CurrentSettingCategory}" DisplayMemberPath="Label" SelectedValuePath="Value"></ComboBox>
                                    <TextBox Text="{Binding AddressKeyword}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Title="地址：" 
                  hc:InfoElement.TitlePlacement="Left" Width="180" hc:InfoElement.Placeholder="请输入关键字检索"/>
                                    <Button Style="{StaticResource ButtonPrimary}" Content="搜索" hc:IconElement.Geometry="{StaticResource SearchGeometry}" 
                 hc:IconElement.Width="14" Command="{Binding SearchCommand}"/>

                                    <Button Style="{StaticResource ButtonPrimary}" HorizontalAlignment="Right" Content="添加到监控配置表" hc:IconElement.Geometry="{StaticResource AddGeometry}" 
hc:IconElement.Width="14" Command="{Binding AddTreeListToTableCommand}"/>
                                </hc:UniformSpacingPanel>
                            </Border>
                            <DataGrid  MaxHeight="200" Grid.Row="1" ItemsSource="{Binding CategoryRegisters}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
               CanUserSortColumns="False" CanUserAddRows="False" Margin="0,5,0,0" MinHeight="245" IsReadOnly="True"
               SelectedItem="{Binding CurrentRegister}" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Margin" Value="0,0,0,5"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding AddressHex}" Header="寄存器地址(HEX)" Width="*"/>
                                    <DataGridTextColumn Binding="{Binding Category}" Header="分类" Width="*"/>
                                    <DataGridTextColumn Binding="{Binding SubCategory}" Header="子分类" Width="*"/>
                                    <DataGridTextColumn Binding="{Binding Name}" Header="寄存器名称" Width="*"/>
                                    <DataGridTextColumn Binding="{Binding HexValue}" Header="数据(HEX)" Width="*"/>
                                    <DataGridTemplateColumn Header="记录时间" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <hc:NumericUpDown Style="{StaticResource NumericUpDownExtend.Small}" Width="80">
                                                        <hc:NumericUpDown.Value>
                                                            <Binding Path="RecordTime" UpdateSourceTrigger="PropertyChanged"/>
                                                        </hc:NumericUpDown.Value>
                                                    </hc:NumericUpDown>
                                                    <TextBlock Text="秒" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="开始" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="开始记录" Style="{StaticResource ButtonInfo.Small}" HorizontalAlignment="Left"  IsEnabled="{c:Binding !IsStartRecord}"
                             Command="{Binding Path=DataContext.BeginRecordCommand,RelativeSource={RelativeSource AncestorType=DataGrid}}"
                             CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="停止" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="停止记录" Style="{StaticResource ButtonWarning.Small}" HorizontalAlignment="Left"  IsEnabled="{c:Binding IsStartRecord}"
                              Command="{Binding Path=DataContext.StopRecordCommand,RelativeSource={RelativeSource AncestorType=DataGrid}}"
                              CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="添加到数据监测表" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding Path=DataContext.WatchGroups,RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Style="{StaticResource ComboBoxExtend.Small}"
                               DisplayMemberPath="Header"
                               SelectedValue="{Binding TableId,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                               SelectedValuePath="Id">
                                                    <i:Interaction.Triggers>
                                                        <i:EventTrigger EventName="SelectionChanged">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.TableChangeCommand,RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                        CommandParameter="{Binding}" />
                                                        </i:EventTrigger>
                                                    </i:Interaction.Triggers>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>


                        <!--</StackPanel>-->
                    </DockPanel>
                </Border>
                <hc:Divider Grid.Row="1" Margin="0,5"/>
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="增加数据监测表" Style="{StaticResource ButtonPrimary}" hc:IconElement.Geometry="{StaticResource AddGeometry}"
                   HorizontalAlignment="Left" hc:IconElement.Width="14"
                   Command="{Binding AddWatchGroupCommand}"/>
                            <TextBlock Width="10"></TextBlock>
                            <Button Content="展示数据监测表" Style="{StaticResource ButtonPrimary}" hc:IconElement.Geometry="{StaticResource  PushGeometry}"
HorizontalAlignment="Left" hc:IconElement.Width="14"
Command="{Binding ShowWatchGroupCommand}"/>
                            <TextBlock Width="10"></TextBlock>
                            <Button Content="展示数据监测图" Style="{StaticResource ButtonPrimary}" hc:IconElement.Geometry="{StaticResource   HTabGroup}"
HorizontalAlignment="Left" hc:IconElement.Width="14"
Command="{Binding ShowChartGroupCommand}"/>
                        </StackPanel>

                    </Border>
                    <Border Grid.Row="1">
                        <hc:TabControl Grid.Row="2" IsAnimationEnabled="True" Margin="0,5,0,0" ShowCloseButton="True" IsDraggable="True" 
                                   ItemsSource="{Binding WatchGroups}" OverflowMenuDisplayMemberPath="Header" SelectedItem="{Binding CurrentTab}">
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Header}"/>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                            <TabControl.ContentTemplate>
                                <DataTemplate>
                                    <Border Padding="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <DockPanel LastChildFill="True" Grid.Column="0">
                                                <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top">
                                                    <DockPanel>
                                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                            <TextBlock Text="{Binding TableName}" FontSize="{StaticResource SubHeadFontSize}" VerticalAlignment="Center"/>
                                                            <Button Style="{StaticResource ButtonDefault.Small}" hc:IconElement.Geometry="{StaticResource PenGeometry}"
                                                                Margin="5,0,0,0" 
                                                                Command="{Binding RenameCommand}"
                                                                CommandParameter="Table"/>
                                                        </StackPanel>
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <Button DockPanel.Dock="Right" Content="下载" Style="{StaticResource ButtonPrimary.Small}" hc:IconElement.Geometry="{StaticResource CustomDownload}"
                                                                Command="{Binding HistoryDownloadCommand}"/>
                                                            <TextBlock Width="10"></TextBlock>
                                                            <hc:SplitButton DockPanel.Dock="Right" Content="显示列：" Style="{StaticResource SplitButtonDefault.Small}" HorizontalAlignment="Right">
                                                                <hc:SplitButton.DropDownContent>
                                                                    <ItemsControl ItemsSource="{Binding TableColumns}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Padding="8,0">
                                                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </hc:SplitButton.DropDownContent>
                                                            </hc:SplitButton>

                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                                <DataGrid ItemsSource="{Binding BitFields}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                                      CanUserSortColumns="False" CanUserAddRows="False" Margin="0,5,0,0"
                                                      SelectedItem="{Binding CurrentSequence}"
                                                      x:Name="MyDataGrid">
                                                    <DataGrid.Resources>
                                                        <utils:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
                                                    </DataGrid.Resources>
                                                    <DataGrid.ColumnHeaderStyle>
                                                        <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                            <Setter Property="FontSize" Value="13"/>
                                                            <Setter Property="Margin" Value="0,0,0,5"/>
                                                        </Style>
                                                    </DataGrid.ColumnHeaderStyle>
                                                    <DataGrid.Columns>
                                                        <DataGridTemplateColumn  Header="序号" Width="45" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[0].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock HorizontalAlignment="Center">
                                                                        <TextBlock.Text>
                                                                            <MultiBinding Converter="{StaticResource RowIndexConverter}">
                                                                                <Binding />
                                                                                <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn Binding="{Binding Desc}" Header="名称" Width="Auto"
                                                                        Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[1].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                                        <DataGridTemplateColumn Header="寄存器地址(HEX)" Width="Auto"
                                                                            Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[2].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock HorizontalAlignment="Center" Text="{Binding AddressHexName}"/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTemplateColumn Header="解析范围" Width="75"
                                                                            Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[3].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                        <TextBlock Text="b"/>
                                                                        <TextBlock Text="{Binding EndBit}"/>
                                                                        <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'Length>1',FalseToVisibility=Collapsed}">
                                                                            <TextBlock Text="-"/>
                                                                            <TextBlock Text="b"/>
                                                                            <TextBlock Text="{Binding StartBit}"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTemplateColumn Header="解析要求" Width="*" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[4].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" >
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                        <TextBlock Text="{Binding FormParam.ParamName}"/>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn Header="解析结果" Binding="{Binding Result}" Width="*" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[5].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                                        <DataGridTextColumn Header="原始值(Dec)" Binding="{Binding Value}" Width="*" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[6].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                                        <DataGridTextColumn Header="原始值(Bit)" Binding="{Binding ReadBinary}" Width="*" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[7].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                                        <DataGridTextColumn Header="单位"  Binding="{Binding FormParam.UnitName}" Width="50" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[8].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"></DataGridTextColumn>
                                                        <DataGridTemplateColumn Header="添加到监测图" Width="*" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[9].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel HorizontalAlignment="Center">
                                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Command="{Binding DataContext.AddToChartCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                    </DataGrid.Columns>

                                                </DataGrid>
                                            </DockPanel>
                                            <DockPanel LastChildFill="True" Grid.Column="1" Margin="15,0,0,0">
                                                <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top" VerticalAlignment="Center">
                                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ChartName}" FontSize="{StaticResource SubHeadFontSize}" VerticalAlignment="Center"/>
                                                        <Button Style="{StaticResource ButtonDefault.Small}" hc:IconElement.Geometry="{StaticResource PenGeometry}"
                                                            Margin="5,0,5,0" 
                                                            Command="{Binding RenameCommand}"
                                                            CommandParameter="Chart"/>
                                                        <TextBox Text="{Binding Chart1MinX}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Title="X最小值："  Margin="5,0,0,0"
                                                            hc:InfoElement.TitlePlacement="Left" Width="120" />
                                                        <TextBox Text="{Binding Chart1MaxX}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Title="X最大值："  Margin="5,0,0,0"
                                                            hc:InfoElement.TitlePlacement="Left" Width="120" />
                                                        <TextBox Text="{Binding Chart1MinY}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Title="Y最小值："  Margin="5,0,0,0"
                                                            hc:InfoElement.TitlePlacement="Left" Width="120" />
                                                        <TextBox Text="{Binding Chart1MaxY}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Title="Y最大值："  Margin="5,0,0,0"
                                                            hc:InfoElement.TitlePlacement="Left" Width="120" />
                                                        <Button Style="{StaticResource ButtonPrimary}" Content="设置" hc:IconElement.Geometry="{StaticResource  PenGeometry }"
                                                            Margin="5,0,0,0" 
                                                            Command="{Binding SettingChartLimitCommand}"
                                                            CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="0,5,0,0">
                                                    <ContentControl Content="{Binding WpfPlotControl,Mode=TwoWay}"/>

                                                </Border>
                                            </DockPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </hc:TabControl>
                    </Border>

                </Grid>
            </Grid>
        </Border>
    </Grid>
    
</UserControl>
