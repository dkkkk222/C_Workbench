<UserControl x:Class="Workbench.Views.dw.WatchTableListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.dw"
             mc:Ignorable="d" 
             xmlns:local_Model="clr-namespace:Workbench.Models"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:cvt="clr-namespace:Workbench.Converters"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
             xmlns:localBehaviors="clr-namespace:Workbench.Models.MoveThumb"
             xmlns:utils="clr-namespace:Workbench.Utils"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:controls_Title="clr-namespace:Workbench.Controls.Controls.Title;assembly=Workbench.Controls"
             d:DesignHeight="450" d:DesignWidth="800" x:Name="Root">
    <UserControl.Resources>
        <cvt:RowIndexConverter x:Key="RowIndexConverter"/>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- 顶部控制条 -->
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
            <!-- 行/列（建议 LostFocus 更新，避免输入中断言失败） -->

            <TextBlock Text="行:" Style="{StaticResource ItemTitle}" Width="30"/>
            <TextBox Width="60" Margin="8,0" Height="30"
                     Text="{Binding GridRows, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Text="列:" Style="{StaticResource ItemTitle}" Width="30"/>
            <TextBox Width="60" Margin="8,0" Height="30"
                     Text="{Binding GridColumns, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" /> 

            <!-- 卡片在单元格内水平/垂直对齐 -->
            <!--<TextBlock Text="水平对齐:" Style="{StaticResource ItemTitle}"/>
            <ComboBox Width="110" Margin="16,0,0,0" Height="30"
                      SelectedValue="{Binding ItemHorizontalAlignment, Mode=TwoWay}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="左" Tag="{x:Static HorizontalAlignment.Left}"/>
                <ComboBoxItem Content="居中" Tag="{x:Static HorizontalAlignment.Center}"/>
                <ComboBoxItem Content="右" Tag="{x:Static HorizontalAlignment.Right}"/>
                <ComboBoxItem Content="拉伸" Tag="{x:Static HorizontalAlignment.Stretch}"/>
            </ComboBox>
            <TextBlock Text="垂直对齐:" Style="{StaticResource ItemTitle}"/>
            <ComboBox Width="110" Margin="8,0" Height="30"
                      SelectedValue="{Binding ItemVerticalAlignment, Mode=TwoWay}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="上" Tag="{x:Static VerticalAlignment.Top}"/>
                <ComboBoxItem Content="居中" Tag="{x:Static VerticalAlignment.Center}"/>
                <ComboBoxItem Content="下" Tag="{x:Static VerticalAlignment.Bottom}"/>
                <ComboBoxItem Content="拉伸" Tag="{x:Static VerticalAlignment.Stretch}"/>
            </ComboBox>-->
            <Button Style="{StaticResource ButtonPrimary.Small}" Content="应用布局"
Background="{DynamicResource GenButtonBackgroundColor}"
BorderBrush="{DynamicResource GenButtonBackgroundColor}"
hc:IconElement.Geometry="{StaticResource  PenGeometry }"
Margin="5,0,0,0"
Command="{Binding ApplyLayoutCommand}" />
        </StackPanel>

        <!-- 主体列表 -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      CanContentScroll="False">

            <ItemsControl ItemsSource="{Binding WatchGroupsView}">
                <!-- 改为 Canvas 布局，自由定位 -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="{Binding CanvasWidth, FallbackValue=5000}"
                    Height="{Binding CanvasHeight, FallbackValue=3000}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- 位置尺寸绑定到项 VM -->
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left, Mode=TwoWay}"/>
                        <Setter Property="Canvas.Top"  Value="{Binding Top,  Mode=TwoWay}"/>
                        <Setter Property="Width"       Value="{Binding TableWidth,  Mode=TwoWay}"/>
                        <Setter Property="Height"      Value="{Binding TableHeight, Mode=TwoWay}"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <!-- 卡片主体 -->
                            <Border x:Name="RootCard"
                        Width="{Binding TableWidth,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Height="{Binding TableHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        MinWidth="540" MinHeight="200"
                        Background="White"
                        BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                        Padding="8" Margin="0">
                                <DockPanel LastChildFill="True">
                                    <!-- 顶部标题/工具条：在这层叠一个透明Thumb做“拖拽把手” -->
                                    <Border DockPanel.Dock="Top" Padding="2" Background="Transparent">
                                        <Grid>
                                            <!-- 你的原有标题与按钮 -->
                                            <DockPanel>
                                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                    <controls_Title:StandTitle Padding="0,0,0,0" BordMargin="0,0,5,0"
                                                                   StandText="{Binding TableName}"
                                                                   StandFontSize="{DynamicResource SubHeadFontSize}"/>
                                                </StackPanel>

                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                                                    <TextBox Text="{Binding TableWidth}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="宽：" Margin="5,0,0,0"
                                                         hc:InfoElement.TitlePlacement="Left" Width="70" />
                                                    <TextBlock Width="10"/>
                                                    <TextBox Text="{Binding TableHeight}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="高：" Margin="5,0,0,0"
                                                         hc:InfoElement.TitlePlacement="Left" Width="70" />
                                                    <TextBlock Width="10"/>
                                                    <Button Content="设置" Style="{StaticResource ButtonPrimary.Small}"
                                                        Background="{DynamicResource GenButtonBackgroundColor}"
                                                        BorderBrush="{DynamicResource GenButtonBackgroundColor}"
                                                        hc:IconElement.Geometry="{StaticResource PenGeometry}"
                                                        Command="{Binding SettingDefaultWHCommand2}"/>
                                                    <TextBlock Width="10"/>
                                                    <Button DockPanel.Dock="Right" Content="下载" Style="{StaticResource ButtonPrimary.Small}"
                                                        Background="{DynamicResource GenButtonBackgroundColor}"
                                                        BorderBrush="{DynamicResource GenButtonBackgroundColor}"
                                                        hc:IconElement.Geometry="{StaticResource CustomDownload}"
                                                        Command="{Binding HistoryDownloadCommand}"/>
                                                    <TextBlock Width="10"/>
                                                    <hc:SplitButton DockPanel.Dock="Right" Content="显示列：" Style="{StaticResource SplitButtonDefault.Small}" HorizontalAlignment="Right">
                                                        <hc:SplitButton.DropDownContent>
                                                            <ItemsControl ItemsSource="{Binding TableColumns}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Padding="8,0">
                                                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                                                <CheckBox.Style>
                                                                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                                                                                <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="false">
                                                                                                <Setter Property="Background" Value="Transparent"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </CheckBox.Style>
                                                                            </CheckBox>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </hc:SplitButton.DropDownContent>
                                                    </hc:SplitButton>
                                                </StackPanel>
                                            </DockPanel>

                                            <!-- 透明移动把手（避免与 DataGrid 的交互冲突） -->
                                            <Thumb Cursor="SizeAll" Background="Transparent" Margin="0,-10,0,0" BorderThickness="11"
                                             HorizontalAlignment="Stretch" VerticalAlignment="Top" BorderBrush="Transparent" 
                                             Panel.ZIndex="10"   Height="20">
                                                <i:Interaction.Behaviors>
                                                    <localBehaviors:MoveThumbBehavior LeftPropertyName="Left" TopPropertyName="Top"/>
                                                </i:Interaction.Behaviors>
                                            </Thumb>
                                        </Grid>
                                    </Border>

                                    <!-- 中间 DataGrid：保持你原来的列定义与样式 -->
                                    <DataGrid ItemsSource="{Binding BitFields}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                              CanUserSortColumns="False" CanUserAddRows="False" Margin="0,5,0,0" RowHeight="40"
                                              Background="{DynamicResource DataGridBackgroundColor}" AlternationCount="2"
                                              SelectedItem="{Binding CurrentSequence}" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              
                                              x:Name="MyDataGrid">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                                <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Padding" Value="0,0,0,0"/>
                                                <Setter Property="Margin" Value="0,0,0,0"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                                <Setter Property="BorderThickness" Value="1,0,0,1" />
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>

                                        <DataGrid.Resources>
                                            <utils:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{StaticResource RowSelectedBrush}"/>
                                        </DataGrid.Resources>

                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                <!-- 前景色跟随行 -->
                                                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </Trigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </MultiDataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>

                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                <Setter Property="SnapsToDevicePixels" Value="True" />
                                                <!-- 新增：默认不加粗 -->
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Style.Triggers>
                                                    <Trigger Property="AlternationIndex" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True"/>
                                                            <Condition Property="IsMouseOver" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </MultiTrigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True"/>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </MultiTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>

                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="序号" Width="45"
                                                                    Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[0].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource RowIndexConverter}">
                                                                    <Binding />
                                                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Binding="{Binding Desc}" Header="名称" Width="Auto"
                                                                Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[1].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}"
                                                                ElementStyle="{StaticResource CenterCellStyle}" IsReadOnly="True"/>

                                            <DataGridTemplateColumn Header="寄存器地址(HEX)" Width="Auto"
                                                                    Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[2].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock HorizontalAlignment="Center" Text="{Binding AddressHexName}" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="寄存器值(HEX)" Width="Auto" IsReadOnly="True" Binding="{Binding SourceHex}" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[3].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}">

                                            </DataGridTextColumn>
                                            <DataGridTemplateColumn Header="解析内容(bit)" Width="75"  Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[4].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="b"/>
                                                            <TextBlock Text="{Binding EndBit}"/>
                                                            <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'Length>1',FalseToVisibility=Collapsed}">
                                                                <TextBlock Text="-"/>
                                                                <TextBlock Text="b"/>
                                                                <TextBlock Text="{Binding StartBit}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="解析要求" Width="Auto"  MinWidth="70"  Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[5].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" >
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Visible" HorizontalAlignment="Center" Margin="0,0,0,0">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding FormParam.ParamName}" TextWrapping="Wrap"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </ScrollViewer>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="解析结果" Binding="{Binding Result}"  IsReadOnly="True" MinWidth="70" Width="Auto" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[6].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                            <DataGridTextColumn Header="解析内容(hex)" Binding="{Binding Value}" IsReadOnly="True" Width="Auto" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[7].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                            <DataGridTextColumn Header="解析内容(binery)" Binding="{Binding ReadBinary}" IsReadOnly="True" Width="Auto" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[8].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                            <DataGridTextColumn Header="单位"  Binding="{Binding FormParam.UnitName}"  IsReadOnly="True" MinWidth="50" Width="Auto" Visibility="{Binding Source={StaticResource DataContextProxy},Path=Data.TableColumns[9].IsChecked,Converter={StaticResource Boolean2VisibilityConverter}}" ElementStyle="{StaticResource CenterCellStyle}"></DataGridTextColumn>

                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <!-- 右下角改大小把手 -->
                            <Thumb Width="14" Height="14"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0" Cursor="SizeNWSE"
                       Background="Transparent" BorderBrush="Transparent" BorderThickness="7"
                       ToolTip="拖拽调整大小" Panel.ZIndex="20">
                                <i:Interaction.Behaviors>
                                    <localBehaviors:ResizeThumbBehavior
                            WidthPropertyName="TableWidth"
                            HeightPropertyName="TableHeight"
                            MinWidth="540"
                            MinHeight="200"/>
                                </i:Interaction.Behaviors>
                            </Thumb>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
