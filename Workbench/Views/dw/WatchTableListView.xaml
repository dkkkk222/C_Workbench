<UserControl x:Class="Workbench.Views.dw.WatchTableListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.dw"
             mc:Ignorable="d" 
             xmlns:local_Model="clr-namespace:Workbench.Models"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:cvt="clr-namespace:Workbench.Converters"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:utils="clr-namespace:Workbench.Utils"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:controls_Title="clr-namespace:Workbench.Controls.Controls.Title;assembly=Workbench.Controls"
             d:DesignHeight="450" d:DesignWidth="800" x:Name="Root">
    <UserControl.Resources>
        <cvt:RowIndexConverter x:Key="RowIndexConverter"/>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- 顶部控制条 -->
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
            <!-- 行/列（建议 LostFocus 更新，避免输入中断言失败） -->

            <TextBlock Text="行:" Style="{StaticResource ItemTitle}"/>
            <TextBox Width="60" Margin="8,0" Height="30"
                     Text="{Binding GridRows, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Text="列:" Style="{StaticResource ItemTitle}"/>
            <TextBox Width="60" Margin="8,0" Height="30"
                     Text="{Binding GridColumns, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" /> 

            <!-- 卡片在单元格内水平/垂直对齐 -->
            <TextBlock Text="水平对齐:" Style="{StaticResource ItemTitle}"/>
            <ComboBox Width="110" Margin="16,0,0,0" Height="30"
                      SelectedValue="{Binding ItemHorizontalAlignment, Mode=TwoWay}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="左" Tag="{x:Static HorizontalAlignment.Left}"/>
                <ComboBoxItem Content="居中" Tag="{x:Static HorizontalAlignment.Center}"/>
                <ComboBoxItem Content="右" Tag="{x:Static HorizontalAlignment.Right}"/>
                <ComboBoxItem Content="拉伸" Tag="{x:Static HorizontalAlignment.Stretch}"/>
            </ComboBox>
            <TextBlock Text="垂直对齐:" Style="{StaticResource ItemTitle}"/>
            <ComboBox Width="110" Margin="8,0" Height="30"
                      SelectedValue="{Binding ItemVerticalAlignment, Mode=TwoWay}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="上" Tag="{x:Static VerticalAlignment.Top}"/>
                <ComboBoxItem Content="居中" Tag="{x:Static VerticalAlignment.Center}"/>
                <ComboBoxItem Content="下" Tag="{x:Static VerticalAlignment.Bottom}"/>
                <ComboBoxItem Content="拉伸" Tag="{x:Static VerticalAlignment.Stretch}"/>
            </ComboBox>
        </StackPanel>

        <!-- 主体列表 -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      CanContentScroll="False">

            <ItemsControl ItemsSource="{Binding WatchGroups, Mode=TwoWay}">
                <i:Interaction.Behaviors>
                    <local_Model:DragDropReorderBehavior/>
                </i:Interaction.Behaviors>
                <!-- 使用 Style 切换 ItemsPanel（Uniform / Wrap），并显式绑定到 ItemsControl.DataContext -->
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <!-- 默认 UniformGrid：行/列可动态绑定 -->
                        <Setter Property="ItemsPanel">
                            <Setter.Value>
                                <ItemsPanelTemplate>
                                    <UniformGrid
                                        Rows="{Binding DataContext.GridRows, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        Columns="{Binding DataContext.GridColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                </ItemsPanelTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <!-- UseWrapLayout=true 时切换为 WrapPanel -->
                            <DataTrigger Binding="{Binding DataContext.UseWrapLayout, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                <Setter Property="ItemsPanel">
                                    <Setter.Value>
                                        <ItemsPanelTemplate>
                                            <WrapPanel
                                                Orientation="{Binding DataContext.ItemOrientation, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                ItemWidth="{Binding DataContext.CellWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                ItemHeight="{Binding DataContext.CellHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                        </ItemsPanelTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>

                <!-- 每个 Item 容器的对齐（可选，增强边界情况） -->
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment"
                                Value="{Binding DataContext.ItemContainerHorizontalAlignment, ElementName=Root}"/>
                        <Setter Property="VerticalAlignment"
                                Value="{Binding DataContext.ItemContainerVerticalAlignment, ElementName=Root}"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <!-- ★不要再写固定的 ItemsPanelTemplate（否则会覆盖上面的 Style 切换） -->

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="RootCard"
                                HorizontalAlignment="{Binding DataContext.ItemHorizontalAlignment, ElementName=Root}"
                                VerticalAlignment="{Binding DataContext.ItemVerticalAlignment, ElementName=Root}"
                                Width="{Binding TableWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                MinWidth="540" MinHeight="200"
                                Height="{Binding TableHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Background="White"
                                BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                                Padding="8" Margin="8">

                            <Grid>
                                <DockPanel LastChildFill="True" Grid.Column="0">
                                    <Border Style="{StaticResource BorderClip}" Padding="2" Margin="0,0,0,0" DockPanel.Dock="Top" BorderBrush="Transparent" Background="Transparent">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                <controls_Title:StandTitle Padding="0,0,0,0" BordMargin="0,0,5,0"
                                                                           StandText="{Binding TableName}"
                                                                           StandFontSize="{DynamicResource SubHeadFontSize}"/>
                                            </StackPanel>

                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                                                <TextBox Text="{Binding TableWidth}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="宽：" Margin="5,0,0,0"
                                                         hc:InfoElement.TitlePlacement="Left" Width="70" />
                                                <TextBlock Width="10"/>
                                                <TextBox Text="{Binding TableHeight}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="高：" Margin="5,0,0,0"
                                                         hc:InfoElement.TitlePlacement="Left" Width="70" />
                                                <TextBlock Width="10"/>
                                                <Button Content="设置" Style="{StaticResource ButtonPrimary.Small}"
                                                        Background="{DynamicResource GenButtonBackgroundColor}"
                                                        BorderBrush="{DynamicResource GenButtonBackgroundColor}"
                                                        hc:IconElement.Geometry="{StaticResource PenGeometry}"
                                                        Command="{Binding SettingDefaultWHCommand2}"/>
                                                <TextBlock Width="10"/>
                                                <Button DockPanel.Dock="Right" Content="下载" Style="{StaticResource ButtonPrimary.Small}"
                                                        Background="{DynamicResource GenButtonBackgroundColor}"
                                                        BorderBrush="{DynamicResource GenButtonBackgroundColor}"
                                                        hc:IconElement.Geometry="{StaticResource CustomDownload}"
                                                        Command="{Binding HistoryDownloadCommand}"/>
                                                <TextBlock Width="10"/>
                                                <hc:SplitButton DockPanel.Dock="Right" Content="显示列：" Style="{StaticResource SplitButtonDefault.Small}" HorizontalAlignment="Right">
                                                    <hc:SplitButton.DropDownContent>
                                                        <ItemsControl ItemsSource="{Binding TableColumns}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="8,0">
                                                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </hc:SplitButton.DropDownContent>
                                                </hc:SplitButton>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <DataGrid ItemsSource="{Binding BitFields}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                              CanUserSortColumns="False" CanUserAddRows="False" Margin="0,5,0,0"
                                              Background="{DynamicResource DataGridBackgroundColor}" AlternationCount="2"
                                              SelectedItem="{Binding CurrentSequence}"
                                              x:Name="MyDataGrid">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                                <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Padding" Value="0,0,0,0"/>
                                                <Setter Property="Margin" Value="0,0,0,0"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>

                                        <DataGrid.Resources>
                                            <utils:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{StaticResource RowSelectedBrush}"/>
                                        </DataGrid.Resources>

                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                <!-- 前景色跟随行 -->
                                                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </Trigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </MultiDataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>

                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                <Setter Property="SnapsToDevicePixels" Value="True" />
                                                <Style.Triggers>
                                                    <Trigger Property="AlternationIndex" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True"/>
                                                            <Condition Property="IsMouseOver" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter Property="Background" Value="{StaticResource RowSelectedBrush}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource RowSelectedForeground}"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </MultiTrigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True"/>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter Property="Background" Value="{StaticResource RowSelectedBrush}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource RowSelectedForeground}"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </MultiTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>

                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="序号" Width="45"
                                                                    Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[0].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource RowIndexConverter}">
                                                                    <Binding />
                                                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Binding="{Binding Desc}" Header="名称" Width="Auto"
                                                                Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[1].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}"
                                                                ElementStyle="{StaticResource CenterCellStyle}"/>

                                            <DataGridTemplateColumn Header="寄存器地址(HEX)" Width="Auto"
                                                                    Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[2].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock HorizontalAlignment="Center" Text="{Binding AddressHexName}" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="解析范围" Width="75"
                                                                    Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[3].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="b"/>
                                                            <TextBlock Text="{Binding EndBit}"/>
                                                            <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'Length>1', FalseToVisibility=Collapsed}">
                                                                <TextBlock Text="-"/>
                                                                <TextBlock Text="b"/>
                                                                <TextBlock Text="{Binding StartBit}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="解析要求" Width="*"
                                                                    Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[4].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding FormParam.ParamName}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="解析结果" Binding="{Binding Result}" Width="*"
                                                                Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[5].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}"
                                                                ElementStyle="{StaticResource CenterCellStyle}"/>

                                            <DataGridTextColumn Header="原始值(Dec)" Binding="{Binding Value}" Width="*"
                                                                Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[6].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}"
                                                                ElementStyle="{StaticResource CenterCellStyle}"/>

                                            <DataGridTextColumn Header="原始值(Bit)" Binding="{Binding ReadBinary}" Width="*"
                                                                Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[7].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}"
                                                                ElementStyle="{StaticResource CenterCellStyle}"/>

                                            <DataGridTextColumn Header="单位" Binding="{Binding FormParam.UnitName}" Width="50"
                                                                Visibility="{Binding Source={StaticResource DataContextProxy}, Path=Data.TableColumns[8].IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}"
                                                                ElementStyle="{StaticResource CenterCellStyle}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
