<UserControl x:Class="Workbench.Views.dw.WatchTableListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.dw"
             mc:Ignorable="d" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:cvt="clr-namespace:Workbench.Converters"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:utils="clr-namespace:Workbench.Utils"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border x:Name="RootCard"
            Width="{Binding TableWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Height="{Binding TableHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Background="White"
            BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
            Padding="8" Margin="8">
            <Grid>
                <!-- 你的原始内容：DockPanel + DataGrid（几乎不动） -->
                <DockPanel LastChildFill="True" Grid.Column="0">
                    <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <TextBlock Text="{Binding TableName}"
                                       FontSize="{StaticResource SubHeadFontSize}"
                                       VerticalAlignment="Center"/>
                                <Button Style="{StaticResource ButtonDefault.Small}"
                                    hc:IconElement.Geometry="{StaticResource PenGeometry}"
                                    Margin="5,0,0,0"
                                    Command="{Binding RenameCommand}"
                                    CommandParameter="Table"/>
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"  >
                                <!-- 新增：手动输入宽高（实时生效） -->
                                <TextBlock VerticalAlignment="Center" Text="W:"/>
                                <TextBox Width="70"
                                     Text="{Binding TableWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}"/>
                                <TextBlock VerticalAlignment="Center" Text="H:"/>
                                <TextBox Width="70"
                                     Text="{Binding TableHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}"/>

                                <Button Content="下载" Style="{StaticResource ButtonPrimary.Small}"
                                    hc:IconElement.Geometry="{StaticResource CustomDownload}"
                                    Command="{Binding HistoryDownloadCommand}"/>

                                <hc:SplitButton Content="显示列：" Style="{StaticResource SplitButtonDefault.Small}" HorizontalAlignment="Right">
                                    <hc:SplitButton.DropDownContent>
                                        <ItemsControl ItemsSource="{Binding TableColumns}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,0">
                                                        <CheckBox Content="{Binding Name}"
                                                              IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </hc:SplitButton.DropDownContent>
                                </hc:SplitButton>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <DataGrid ItemsSource="{Binding BitFields}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                          CanUserSortColumns="False" CanUserAddRows="False" Margin="0,5,0,0"
                          SelectedItem="{Binding CurrentSequence}"
                          x:Name="MyDataGrid">
                        <DataGrid.Resources>
                            <utils:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
                        </DataGrid.Resources>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource DataGridColumnHeaderStyle.Small}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Margin" Value="0,0,0,5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <!-- 你的列定义保持不变（略） -->
                        <!-- ……………… 这里保留你提供的所有 DataGrid.Columns ……………… -->
                    </DataGrid>
                </DockPanel>

                <!-- 右下角拖拽柄 -->
                <Thumb Width="14" Height="14"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Cursor="SizeNWSE" Opacity="0.9" Panel.ZIndex="10"
                   DragDelta="ResizeThumb_DragDelta">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border BorderBrush="#999" BorderThickness="1" Background="#EEE" CornerRadius="2"/>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
            </Grid>
        </Border>
    </Grid>
</UserControl>
