<UserControl x:Class="Workbench.Views.dw.WatchChartListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.dw"
              xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
            xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
            xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             mc:Ignorable="d" 
               xmlns:hc="https://handyorg.github.io/handycontrol"
  xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
  xmlns:cvt="clr-namespace:Workbench.Converters"
  xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
  xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
  xmlns:utils="clr-namespace:Workbench.Utils"
  xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
               xmlns:controls_Scottplot="clr-namespace:Workbench.Controls.Controls.Scottplot;assembly=Workbench.Controls"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <cvt:RowIndexConverter x:Key="RowIndexConverter"/>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>

        </Style>
    </UserControl.Resources>
    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  CanContentScroll="False">
            <ItemsControl ItemsSource="{Binding WatchGroupsView}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="RootCard"
    Width="{Binding ChartWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="680" MinHeight="300"
    Height="{Binding ChartHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
    Background="White"
    BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
    Padding="8" Margin="8">
                            <Grid>
                                <DockPanel LastChildFill="True" Grid.Column="1">
                                    <Border Style="{StaticResource BorderTipPrimary}" DockPanel.Dock="Top" VerticalAlignment="Center"  BorderBrush="{DynamicResource BordTitleBackgroundColor}">
                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition></RowDefinition>
                                                    <RowDefinition></RowDefinition>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding ChartName}" FontSize="{StaticResource SubHeadFontSize}" VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource ButtonDefault.Small}" hc:IconElement.Geometry="{StaticResource PenGeometry}" 
Margin="5,0,5,0" 
Command="{Binding RenameCommand}"
CommandParameter="Chart"/>
                                                    <TextBox Text="{Binding Chart1MinX}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="X最小值："  Margin="5,0,0,0"
hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                    <TextBox Text="{Binding Chart1MaxX}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="X最大值："  Margin="5,0,0,0"
hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                    <TextBox Text="{Binding Chart1MinY}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="Y最小值："  Margin="5,0,0,0"
hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                    <TextBox Text="{Binding Chart1MaxY}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="Y最大值："  Margin="5,0,0,0"
hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                    <Button Style="{StaticResource ButtonPrimary.Small}" Content="设置" Background="{DynamicResource GenButtonBackgroundColor}"  hc:IconElement.Geometry="{StaticResource  PenGeometry }" Margin="5,0,0,0" Command="{Binding SettingChartLimitCommand}" CommandParameter="{Binding}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1"  Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5,0,0">
                                                    <TextBox Text="{Binding ChartWidth}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="宽："  Margin="0,0,0,0"
hc:InfoElement.TitlePlacement="Left" Width="80" />
                                                    <TextBlock Width="30"></TextBlock>
                                                    <TextBox Text="{Binding ChartHeight}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="高："  Margin="5,0,0,0"
hc:InfoElement.TitlePlacement="Left" Width="80" />
                                                    <TextBlock Width="5"></TextBlock>
                                                    <Button   Content="设置" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource GenButtonBackgroundColor}"  hc:IconElement.Geometry="{StaticResource PenGeometry}" Command="{Binding SettingDefaultChartWHCommand1}"/>

                                                </StackPanel>
                                                  </Grid>
                                          
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,5,0,0">
                                        <!--<ContentControl Content="{Binding WpfPlotControl,Mode=TwoWay}"/>-->
                                        <controls_Scottplot:LiveDataPlot PlotData="{Binding WpfPlotControl2,Mode=TwoWay}"/> 
                                    </Border>
                                </DockPanel> 
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
