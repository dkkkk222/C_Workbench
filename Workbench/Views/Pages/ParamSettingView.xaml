<UserControl x:Class="Workbench.Views.Pages.ParamSettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.Pages"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local:ParamSettingTemplateSelector x:Key="ParamSettingTemplateSelector"/>
        <DataTemplate x:Key="Select">
            <Border Margin="0,8" Padding="10,0">
                <controls:PPEC_ComboBox Title="{Binding Title, Mode=TwoWay}"
                                    ItemsSource="{Binding Options,Mode=TwoWay}"
                                    ComboBoxSelectionChanged="ComboBox_ComboBoxSelectionChanged"
                                    Width="150"
                                    Height="30"
                                    TitleWidth="180"
                                    SelectedValue="{Binding Value}"
                                    FontSize="14"
                                    DisplayMemberPath="Label"
                                    SelectedValuePath="Value"/>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="TextBox">
            <Border Margin="0,8" Padding="10,0">
                <controls:TitleTextBox BlockText="{Binding Title}"
                       TextWidth="150"
                       TextHeight="30"
                       Unit="{Binding Unit}"
                       FontSize="14"
                       Precision="{Binding TopoConfigMeta.Precision}"
                       Text="{Binding Value, Mode=TwoWay}"
                       BlockWidth="180"/>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Background="{DynamicResource HomeBackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="Transparent" Width="225" Padding="8">
            <TreeView x:Name="developTreeView" ItemsSource="{Binding Menus}"
                     SelectedItemChanged="developTreeView_SelectedItemChanged"
                     ItemContainerStyle="{DynamicResource TreeViewItemStyle}"
                     Style="{DynamicResource TreeViewStyle}">
                <TreeView.ItemTemplate >
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Height="28" >
                            <TextBlock Text="{Binding Name}" 
                                      FontSize="14" 
                                      VerticalAlignment="Center" 
                                      Foreground="{DynamicResource PrimaryFontColor}"
                                      Margin="8,0,0,0"></TextBlock>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
        <Border Grid.Column="1" Background="Transparent" Padding="10,10,1,1">
            <ScrollViewer x:Name="scrollViewer" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl x:Name="ItemsControlPanel"  ItemsSource="{Binding ParamSettingElements}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical">
                                    <Border Margin="0,0,0,15">
                                        <StackPanel>
                                            <Border Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#909399" Padding="5,8">
                                                <controls:HomeTitle Title="{Binding Title}" Padding="0,0"/>
                                            </Border>
                                            <Border Padding="20,0">
                                                <ItemsControl ItemsSource="{Binding Elements}" ItemTemplateSelector="{StaticResource ParamSettingTemplateSelector}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Columns="2"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </Border>

                                        </StackPanel>

                                    </Border>

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Margin="0,0,0,15">
                        <StackPanel>
                            <Border Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#909399" Padding="5,8">
                                <controls:HomeTitle x:Name="ComSetting" Title="通讯设置" Padding="0,0"/>
                            </Border>
                            <Border Padding="20,0">
                                <Border Margin="0,8" Padding="10,0">
                                    <controls:PPEC_ComboBox Title="端口号" ItemsSource="{Binding PortList, Mode=TwoWay}" 
                                                            SelectedItem="{Binding SelectedPort, Mode=TwoWay}"
                                                            FontSize="14" Height="30" Width="150" TitleWidth="180"/>
                                </Border>
                            </Border>
                        </StackPanel>
                    </Border>
                    <StackPanel Height="125"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>

</UserControl>
