<UserControl x:Class="Workbench.Views.Content.ContentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:utils="clr-namespace:Workbench.Utils"
             xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
             xmlns:pane="clr-namespace:Workbench.AvalonDock"
             xmlns:views="clr-namespace:Workbench.Views.Content.Tabs"
             xmlns:dwViews="clr-namespace:Workbench.Views.dw"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- 拦截标签页左键 -->
        <Style TargetType="{x:Type avalonDock:LayoutDocumentTabItem}">
            <EventSetter Event="PreviewMouseLeftButtonDown"
                         Handler="DocTab_PreviewMouseLeftButtonDown"/>
        </Style>
    </UserControl.Resources>
    <Grid Background="{DynamicResource PrimaryBackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border>
            <ContentControl prism:RegionManager.RegionName="{x:Static utils:RegionNames.ButtonBarRegion}"/>
        </Border>
        <Border Grid.Row="1" Background="{DynamicResource MainPageBackgroundColor}" Padding="8,8,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="205" Background="Transparent" Margin="0,0,4,0" CornerRadius="6">
                    <ContentControl prism:RegionManager.RegionName="{x:Static utils:RegionNames.SideRegion}"/>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource AvalonDockAreaBackgroundColor}" Margin="4,0,0,0" CornerRadius="6">
                    <avalonDock:DockingManager DocumentsSource="{Binding Documents}"
                                               DocumentPaneControlStyle="{DynamicResource DocumentPaneControlStyle}"
                                               ActiveContent="{Binding ActiveDocument,Mode=TwoWay}">
                        <!--<avalonDock:DockingManager.DocumentContextMenu>
                            <ContextMenu Style="{StaticResource ContextMenu.Small}" Width="165">
                                <MenuItem Header="关闭" Click="Close_Click" Foreground="{DynamicResource TitleBarColor}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xe639;" 
                                                   Style="{DynamicResource ContextMenuStyle}"
                                                   FontFamily="{StaticResource Iconfont}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="关闭其他" Click="CloseOthers_Click" Foreground="{DynamicResource TitleBarColor}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xe63a;" 
                                                   Style="{DynamicResource ContextMenuStyle}"
                                                   FontFamily="{StaticResource Iconfont}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="关闭左侧" Click="CloseLeft_Click" Foreground="{DynamicResource TitleBarColor}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xe695;" 
                                                   Style="{DynamicResource ContextMenuStyle}"
                                                   FontFamily="{StaticResource Iconfont}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="关闭右侧" Click="CloseRight_Click" Foreground="{DynamicResource TitleBarColor}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xe694;" 
                                                   Style="{DynamicResource ContextMenuStyle}"
                                                   FontFamily="{StaticResource Iconfont}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="关闭所有" Click="CloseAll_Click" Foreground="{DynamicResource TitleBarColor}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xe6f0;" 
                                                   Style="{DynamicResource ContextMenuStyle}"
                                                   FontFamily="{StaticResource Iconfont}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </avalonDock:DockingManager.DocumentContextMenu>-->
                        <avalonDock:DockingManager.DocumentHeaderTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" MinWidth="80">
                                    <TextBlock Text="{Binding Title}" 
                                               Margin="0,0,4,0" 
                                               FontSize="14"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </avalonDock:DockingManager.DocumentHeaderTemplate>
                        <avalonDock:DockingManager.LayoutItemTemplateSelector>
                            <pane:PanesTemplateSelector>
                                <pane:PanesTemplateSelector.HomeViewTemplate>
                                    <DataTemplate>
                                        <views:HomeView/>
                                    </DataTemplate>
                                </pane:PanesTemplateSelector.HomeViewTemplate>
                                <pane:PanesTemplateSelector.DevelopViewTemplate>
                                    <DataTemplate>
                                        <views:DevelopView/>
                                    </DataTemplate>
                                </pane:PanesTemplateSelector.DevelopViewTemplate>
                                <pane:PanesTemplateSelector.DebugViewTemplate>
                                    <DataTemplate>
                                        <views:DebugView/>
                                    </DataTemplate>
                                </pane:PanesTemplateSelector.DebugViewTemplate>
                                <pane:PanesTemplateSelector.SingleParamsViewTemplate>
                                    <DataTemplate>
                                        <dwViews:SingleParamsView/>
                                    </DataTemplate>
                                </pane:PanesTemplateSelector.SingleParamsViewTemplate>
                                <pane:PanesTemplateSelector.BatchParamsViewTemplate>
                                    <DataTemplate>
                                        <dwViews:BatchParamsView/>
                                    </DataTemplate>
                                </pane:PanesTemplateSelector.BatchParamsViewTemplate>
                                <pane:PanesTemplateSelector.WatchViewTemplate>
                                    <DataTemplate>
                                        <dwViews:WatchView/>
                                    </DataTemplate>
                                </pane:PanesTemplateSelector.WatchViewTemplate>
                            </pane:PanesTemplateSelector>

                        </avalonDock:DockingManager.LayoutItemTemplateSelector>
                        <avalonDock:DockingManager.LayoutItemContainerStyleSelector>
                            <pane:PanesStyleSelector>
                                <pane:PanesStyleSelector.HomeStyle>
                                    <Style TargetType="{x:Type avalonDock:LayoutItem}">
                                        <Setter Property="Title" Value="{Binding Model.Title}"/>
                                        <Setter Property="ContentId" Value="{Binding Model.ContentId}"/>
                                        <Setter Property="CloseCommand" Value="{Binding Model.CloseCommand}"/>
                                        <Setter Property="IsSelected" Value="{Binding Model.IsSelected, Mode=TwoWay}"/>
                                        <Setter Property="IsActive" Value="{Binding Model.IsActive, Mode=TwoWay}"/>
                                    </Style>
                                </pane:PanesStyleSelector.HomeStyle>
                                <pane:PanesStyleSelector.DevelopStyle>
                                    <Style TargetType="{x:Type avalonDock:LayoutItem}">
                                        <Setter Property="Title" Value="{Binding Model.Title}"/>
                                        <Setter Property="ContentId" Value="{Binding Model.ContentId}"/>
                                        <Setter Property="CloseCommand" Value="{Binding Model.CloseCommand}"/>
                                        <Setter Property="IsSelected" Value="{Binding Model.IsSelected, Mode=TwoWay}"/>
                                        <Setter Property="IsActive" Value="{Binding Model.IsActive, Mode=TwoWay}"/>
                                    </Style>
                                </pane:PanesStyleSelector.DevelopStyle>
                                <pane:PanesStyleSelector.DebugStyle>
                                    <Style TargetType="{x:Type avalonDock:LayoutItem}">
                                        <Setter Property="Title" Value="{Binding Model.Title}"/>
                                        <Setter Property="CloseCommand" Value="{Binding Model.CloseCommand}"/>
                                        <Setter Property="ContentId" Value="{Binding Model.ContentId}"/>
                                        <Setter Property="IsSelected" Value="{Binding Model.IsSelected, Mode=TwoWay}"/>
                                        <Setter Property="IsActive" Value="{Binding Model.IsActive, Mode=TwoWay}"/>
                                    </Style>
                                </pane:PanesStyleSelector.DebugStyle>
                                <pane:PanesStyleSelector.SingleParamsStyle>
                                    <Style TargetType="{x:Type avalonDock:LayoutItem}">
                                        <Setter Property="Title" Value="{Binding Model.Title}"/>
                                        <Setter Property="CloseCommand" Value="{Binding Model.CloseCommand}"/>
                                        <Setter Property="ContentId" Value="{Binding Model.ContentId}"/>
                                        <Setter Property="IsSelected" Value="{Binding Model.IsSelected, Mode=TwoWay}"/>
                                        <Setter Property="IsActive" Value="{Binding Model.IsActive, Mode=TwoWay}"/>
                                    </Style>
                                </pane:PanesStyleSelector.SingleParamsStyle>
                                <pane:PanesStyleSelector.BatchParamsStyle>
                                    <Style TargetType="{x:Type avalonDock:LayoutItem}">
                                        <Setter Property="Title" Value="{Binding Model.Title}"/>
                                        <Setter Property="CloseCommand" Value="{Binding Model.CloseCommand}"/>
                                        <Setter Property="ContentId" Value="{Binding Model.ContentId}"/>
                                        <Setter Property="IsSelected" Value="{Binding Model.IsSelected, Mode=TwoWay}"/>
                                        <Setter Property="IsActive" Value="{Binding Model.IsActive, Mode=TwoWay}"/>
                                    </Style>
                                </pane:PanesStyleSelector.BatchParamsStyle>
                                <pane:PanesStyleSelector.WatchStyle>
                                    <Style TargetType="{x:Type avalonDock:LayoutItem}">
                                        <Setter Property="Title" Value="{Binding Model.Title}"/>
                                        <Setter Property="CloseCommand" Value="{Binding Model.CloseCommand}"/>
                                        <Setter Property="ContentId" Value="{Binding Model.ContentId}"/>
                                        <Setter Property="IsSelected" Value="{Binding Model.IsSelected, Mode=TwoWay}"/>
                                        <Setter Property="IsActive" Value="{Binding Model.IsActive, Mode=TwoWay}"/>
                                    </Style>
                                </pane:PanesStyleSelector.WatchStyle>
                            </pane:PanesStyleSelector>
                        </avalonDock:DockingManager.LayoutItemContainerStyleSelector>

                    </avalonDock:DockingManager>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
