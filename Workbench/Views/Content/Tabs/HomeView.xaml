<UserControl x:Class="Workbench.Views.Content.Tabs.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:homeTitle="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Background="{DynamicResource HomeBackgroundColor}" Padding="40,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0">
                    <TextBlock Text="欢迎使用!" FontSize="26" 
                                           Foreground="{DynamicResource PrimaryFontColor}"
                                           Margin="0,0,0,25"/>
                </Border>
                <Border Grid.Row="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <homeTitle:HomeTitle Title="快速开始"/>
                            <Border HorizontalAlignment="Left">
                                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                                    <Border Background="{StaticResource GenButtonBackgroundColor}" Height="50" Width="215" CornerRadius="5" Padding="20,0">
                                        <hc:UniformSpacingPanel Spacing="10" VerticalAlignment="Center">
                                            <TextBlock Text="&#xe620;" FontFamily="{StaticResource Iconfont}" 
                                                           Foreground="{DynamicResource ButtonBarIconColor}"
                                                           FontSize="32" VerticalAlignment="Center"/>
                                            <Border>
                                                <TextBlock FontSize="18" VerticalAlignment="Center">
                                                    <Hyperlink Style="{DynamicResource HyperlinkStyle}" Command="{Binding NewProjectCommand}">
                                                        新 建 工 程
                                                    </Hyperlink>
                                                </TextBlock>
                                            </Border>
                                        </hc:UniformSpacingPanel>
                                    </Border>
                                    <Border Background="{StaticResource GenButtonBackgroundColor}" Height="50" Width="215" CornerRadius="5" Padding="20,0">
                                        <hc:UniformSpacingPanel Spacing="10" VerticalAlignment="Center">
                                            <TextBlock Text="&#xe60a;" FontFamily="{StaticResource Iconfont}" 
                                                           Foreground="{DynamicResource ButtonBarIconColor}"
                                                           FontSize="32" VerticalAlignment="Center"/>
                                            <Border>
                                                <TextBlock FontSize="18" VerticalAlignment="Center">
                                                    <Hyperlink Style="{DynamicResource HyperlinkStyle}" Command="{Binding OpenProjectCommand}">
                                                        打 开 工 程
                                                    </Hyperlink>
                                                </TextBlock>
                                            </Border>
                                        </hc:UniformSpacingPanel>
                                    </Border>
                                    <Border Background="{StaticResource GenButtonBackgroundColor}" Height="50" Width="215" CornerRadius="5" Padding="20,0">
                                        <hc:UniformSpacingPanel Spacing="10" VerticalAlignment="Center">
                                            <TextBlock Text="&#xe615;" FontFamily="{StaticResource Iconfont}" 
                                                           Foreground="{DynamicResource ButtonBarIconColor}"
                                                           FontSize="32" VerticalAlignment="Center"/>
                                            <Border>
                                                <TextBlock FontSize="18" VerticalAlignment="Center">
                                                    <Hyperlink Style="{DynamicResource HyperlinkStyle}">
                                                        查 找 例 子
                                                    </Hyperlink>
                                                </TextBlock>
                                            </Border>
                                        </hc:UniformSpacingPanel>
                                    </Border>
                                    <Border Background="{StaticResource GenButtonBackgroundColor}" Height="50" Width="215" CornerRadius="5" Padding="20,0">
                                        <hc:UniformSpacingPanel Spacing="10" VerticalAlignment="Center">
                                            <TextBlock Text="&#xe623;" FontFamily="{StaticResource Iconfont}" 
                                                           Foreground="{DynamicResource ButtonBarIconColor}"
                                                           FontSize="32" VerticalAlignment="Center"/>
                                            <Border>
                                                <TextBlock FontSize="18" VerticalAlignment="Center">
                                                    <Hyperlink Style="{DynamicResource HyperlinkStyle}">
                                                        更 多 信 息
                                                    </Hyperlink>
                                                </TextBlock>
                                            </Border>
                                        </hc:UniformSpacingPanel>
                                    </Border>
                                </hc:UniformSpacingPanel>
                            </Border>
                            <!--<Border Style="{DynamicResource QuickStartBorderStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xe620;" FontFamily="{StaticResource Iconfont}" 
                                                   Foreground="{DynamicResource PrimaryFontColor}"
                                                   FontSize="20"/>
                                    <TextBlock Style="{DynamicResource QuickStartStyle}">
                                        <Hyperlink Style="{DynamicResource HyperlinkStyle}" Command="{Binding NewProjectCommand}">
                                            新建工程
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{DynamicResource QuickStartBorderStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xe60a;" FontFamily="{StaticResource Iconfont}" 
                                                   Foreground="{DynamicResource PrimaryFontColor}"
                                                   FontSize="20"/>
                                    <TextBlock Style="{DynamicResource QuickStartStyle}">
                                        <Hyperlink Style="{DynamicResource HyperlinkStyle}" Command="{Binding OpenProjectCommand}">
                                            打开工程
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{DynamicResource QuickStartBorderStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xe615;" FontFamily="{StaticResource Iconfont}" 
                                                   Foreground="{DynamicResource PrimaryFontColor}"
                                                   FontSize="20"/>
                                    <TextBlock Style="{DynamicResource QuickStartStyle}">
                                        <Hyperlink Style="{DynamicResource HyperlinkStyle}">
                                            查找例子
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{DynamicResource QuickStartBorderStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xe623;" FontFamily="{StaticResource Iconfont}" 
                                                   Foreground="{DynamicResource PrimaryFontColor}"
                                                   FontSize="20"/>
                                    <TextBlock Style="{DynamicResource QuickStartStyle}">
                                        <Hyperlink Style="{DynamicResource HyperlinkStyle}" Command="{Binding OpenWebPageCommand}"
                                                   CommandParameter="http://www.senmuleishi.com">
                                            更多信息
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>-->
                        </StackPanel>
                        <hc:Divider Grid.Column="1"/>
                        <Border Grid.Column="2" Background="Transparent" Padding="0,0,10,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <homeTitle:HomeTitle Title="最近工程"/>
                                    <ItemsControl ItemsSource="{Binding RecentFiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,15">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontSize="14" VerticalAlignment="Center">
                                                        <Hyperlink Style="{StaticResource HyperlinkStyle}"   Foreground="{StaticResource IndexPageFontBackground}"
                                                                   Command="{Binding Path=DataContext.OpenRecentFileCommand,RelativeSource={ RelativeSource Mode=FindAncestor,AncestorType=ItemsControl}}"
                                                                   CommandParameter="{Binding}">
                                                            <TextBlock Text="{Binding FileName}"/>
                                                        </Hyperlink>
                                                    </TextBlock>
                                                        <TextBlock Text="{Binding DirPath}" FontSize="13" 
                                                               Foreground="{DynamicResource PrimaryFontColor}"
                                                               Margin="20,0,0,0"
                                                               TextTrimming="WordEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Margin="0,10,0,0">
                                        <TextBlock FontSize="14">
                                                <Hyperlink Style="{DynamicResource HyperlinkStyle}" Foreground="{StaticResource IndexPageFontBackground}" Command="{Binding ShowRecentFileViewCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="更多>>"/>
                                                    </StackPanel>
                                                </Hyperlink>
                                            </TextBlock>
                                    </Border>
                                </StackPanel>
                                <Border Grid.Row="1" Background="Transparent">
                                    <StackPanel>
                                        <homeTitle:HomeTitle Title="产品介绍"/>
                                        <ItemsControl ItemsSource="{Binding Introduces}" IsEnabled="True">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8" BorderThickness="0,0,0,1" BorderBrush="#A6A6A6" Padding="0,0,0,15">
                                                        <StackPanel>
                                                            <Border>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Icon,Converter={StaticResource StringToIconConverter}}" 
                                                                       FontFamily="{StaticResource Iconfont}" 
                                                                       Foreground="{DynamicResource PrimaryFontColor}"
                                                                       FontSize="20" 
                                                                       VerticalAlignment="Center"/>
                                                                    <TextBlock FontSize="14" 
                                                                       Margin="10,0,0,0"
                                                                       VerticalAlignment="Center">
                                                                <Hyperlink Style="{DynamicResource HyperlinkStyle}" 
                                                                           Command="{Binding Path=DataContext.OpenWebPageCommand,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=ItemsControl}}"
                                                                           CommandParameter="{Binding Href}">
                                                                    <TextBlock Text="{Binding Title}"/>
                                                                </Hyperlink>
                                                            </TextBlock>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Margin="0,3,0,0">
                                                                <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis" 
                                                                   Foreground="{DynamicResource PrimaryFontColor}"
                                                                   FontSize="13"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

        </Border>
    </ScrollViewer>


</UserControl>
