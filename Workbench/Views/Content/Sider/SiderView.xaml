<UserControl x:Class="Workbench.Views.Content.Sider.SiderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.Content.Sider"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="225">
    <UserControl.Resources>
        <ContextMenu x:Key="CuContextMenu" Style="{StaticResource ContextMenu.Small}" Width="165">
            <MenuItem Name="Save" Header="{Binding SaveProjectName}" Command="{Binding SaveProjectCommand}"/>
            <MenuItem Name="Delete" Header="{Binding DelProjectName}" Command="{Binding RemoveCurrentProjectCommand}"/>
            <MenuItem Name="Copy" Header="另存为" Command="{Binding SaveAsProjectCommand}"/>
        </ContextMenu>
    </UserControl.Resources>
    <Border Padding="0" Background="{DynamicResource TreeViewTitleBackgroundColor}" ContextMenu="{StaticResource CuContextMenu}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="{DynamicResource LeftTreeViewTitleBackgroundColor}" Height="24" CornerRadius="6,6,0,0" BorderThickness="1,1,1,0" BorderBrush="{DynamicResource TreeViewPannelBordBrush}">
                <TextBlock Text="工程管理" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryFontColor}"
                           VerticalAlignment="Center"  Background="{DynamicResource LeftTreeViewTitleBackgroundColor}"
                           Padding="5,0,0,0"/>
            </Border>
            <Border Grid.Row="1" Visibility="{c:Binding !HasProject,FalseToVisibility=Collapsed}">
                <StackPanel VerticalAlignment="Center">
                    <svgc:SvgViewbox Source="pack://application:,,,/Workbench;component/Resource/Images/SVG/无数据-copy.svg" 
                                   Width="88"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center">
                    </svgc:SvgViewbox>
                    <Label Content="请创建或打开芯片工程" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0" Style="{StaticResource LabelDefault}"/>
                </StackPanel>

            </Border>
            <TreeView Grid.Row="1"  x:Name="treeView" ItemsSource="{Binding Projects}" HorizontalAlignment="Stretch"   BorderThickness="1,0,1,1" BorderBrush="{DynamicResource TreeViewPannelBordBrush}"
                      Style="{DynamicResource TreeViewStyle}" Visibility="{c:Binding HasProject,FalseToVisibility=Collapsed}"
                      SelectedItemChanged="treeView_SelectedItemChanged"
                      MouseDoubleClick="treeView_MouseDoubleClick"
                      MouseRightButtonDown="TreeView_MouseRightButtonDown"
                      ItemContainerStyle="{DynamicResource TreeViewItemStyle}"
                      VerticalAlignment="Stretch">
                <TreeView.ItemTemplate >
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Height="28" >
                            <TextBlock Text="{Binding Icon,Converter={StaticResource StringToIconConverter}}" FontFamily="{StaticResource Iconfont}" 
                                       Foreground="{DynamicResource PrimaryFontColor}"
                                       FontSize="18"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" FontSize="14" 
                                       Foreground="{DynamicResource PrimaryFontColor}"
                                       VerticalAlignment="Center" 
                                       Margin="8,0,0,0"></TextBlock>
                            
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

    </Border>
</UserControl>
