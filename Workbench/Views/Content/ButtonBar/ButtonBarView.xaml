<UserControl x:Class="Workbench.Views.Content.ButtonBar.ButtonBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:prism="http://prismlibrary.com/"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>

        </Style>
        <!-- ComboBoxItem 样式 -->
        <Style x:Key="CustomComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{StaticResource ComboBoxItem.Small}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Bd" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" 
     Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" 
     CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                   SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                   VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- 选中项鼠标悬停时的背景色 -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="ListBoxItem.IsSelected" Value="False"/>
                        <Condition Property="UIElement.IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Value="{DynamicResource SecondaryRegionBrush}" Property="Background"/>
                </MultiTrigger>
                <!-- 选中项的背景颜色 -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="ListBoxItem.IsSelected" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Value="{DynamicResource PrimaryBrush}" Property="Background"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiTrigger>
                <!-- 设置选中项的背景颜色 -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryBackgroundColor}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- ComboBox 样式 -->
        <Style x:Key="CustomComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ComboBoxExtend.Small}">
            <Setter Property="ItemContainerStyle" Value="{StaticResource CustomComboBoxItemStyle}" />
            <Style.Triggers>
                <!-- 获得焦点时变色 -->
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Height="35" Background="{DynamicResource SecondaryBackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Padding="13,5,5,5" BorderThickness="0,1,0,1" BorderBrush="#CCCCCC">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ButtonBarStyle}" ToolTip="新建" Command="{Binding NewProjectCommand}">
                    <TextBlock Text="&#xe620;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                </Button>
                <Button Style="{StaticResource ButtonBarStyle}" ToolTip="打开" Command="{Binding OpenProjectCommand}">
                    <TextBlock Text="&#xe614;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                </Button>
                <Button Style="{StaticResource ButtonBarStyle}" ToolTip="保存" Command="{Binding SaveProjectCommand}">
                    <TextBlock Text="&#xe627;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                </Button>
                <Button Style="{StaticResource ButtonBarStyle}" ToolTip="另存为" Command="{Binding SaveAsProjectCommand}">
                    <TextBlock Text="&#xe628;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                </Button>
                <StackPanel Orientation="Horizontal" Visibility="{calc:Binding IsSelectedProject,FalseToVisibility=Collapsed}">
                    <Border Style="{StaticResource VerticalSeparatorStyle}"/>
                    <Button Style="{StaticResource ButtonBarStyle}" 
                            ToolTip="{Binding ConnectStr,Mode=TwoWay}" 
                            Command="{Binding ConnectCommand}">
                        <TextBlock Text="{Binding ConnectIcon,Mode=TwoWay}" 
                                   FontFamily="{StaticResource Iconfont}" 
                                   Style="{StaticResource ButtonBarIconStyle}"/>
                    </Button> 
                    <Border Style="{StaticResource VerticalSeparatorStyle}"/>
                    <!-- 通讯方式 -->
                    <Border Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="通讯方式：" Style="{DynamicResource ButtonBarTitleStyle}"/>
                            <ComboBox Width="100" ItemsSource="{Binding CommunicationTypeList}" Style="{StaticResource CustomComboBoxStyle}"
                                      SelectedItem="{Binding SelectedCommunicationType}"
                                      IsEnabled="{calc:Binding !IsConnected}"
                                      Height="22"/>
                        </StackPanel>
                    </Border>
                    <!-- 端口 -->
                    <Border Margin="10,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PortTitle}" Style="{DynamicResource ButtonBarTitleStyle}"/>
                            <ComboBox ItemsSource="{Binding PortList}" Width="120" Style="{StaticResource CustomComboBoxStyle}"
                                      SelectedItem="{Binding SerialPortName, Mode=TwoWay}"
                                      Height="22"
                                      IsEnabled="{calc:Binding !IsConnected}"
                                      Visibility="{calc:Binding 'ConnectType==1',FalseToVisibility=Collapsed}" />
                            <TextBlock Text="通信速率：" Style="{DynamicResource ButtonBarTitleStyle}" Margin="10,0,0,0"  Visibility="{calc:Binding 'ConnectType==1',FalseToVisibility=Collapsed}"/>
                            <ComboBox ItemsSource="{Binding BuandList}" Width="120" Style="{StaticResource CustomComboBoxStyle}"
                                      SelectedItem="{Binding BuandName, Mode=TwoWay}"
                                      Height="22"
                                      IsEnabled="{calc:Binding !IsConnected}"
                                      Visibility="{calc:Binding 'ConnectType==1',FalseToVisibility=Collapsed}"/>
                            <StackPanel Orientation="Horizontal"   Visibility="{calc:Binding 'ConnectType==1',FalseToVisibility=Collapsed}" 
                                        Margin="10,0,0,0" Height="22"  IsEnabled="{calc:Binding !IsConnected}">
                                <TextBlock Text="帧间隔设置(ms):" Foreground="White" Style="{StaticResource ItemTitle}" Width="100"/>
                                <TextBox Style="{StaticResource TextBoxExtend.Small}" Width="100"   Height="22"   Text="{Binding Delay}" 
                        Visibility="{calc:Binding 'ConnectType==1',FalseToVisibility=Collapsed}"/>

                            </StackPanel>
                            <!-- CAN口 -->
                            <ComboBox Width="120" ItemsSource="{Binding CANList}" Style="{StaticResource CustomComboBoxStyle}"
                                      SelectedItem="{Binding SelectedCAN,Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Value"
                                      Height="22"
                                      IsEnabled="{calc:Binding !IsConnected}"
                                      Visibility="{calc:Binding 'ConnectType==2',FalseToVisibility=Collapsed}"/>
                            
                            <StackPanel  Orientation="Horizontal"   Visibility="{calc:Binding 'ConnectType==2',FalseToVisibility=Collapsed}" 
                                        Margin="0,0,0,0" Height="22"  IsEnabled="{calc:Binding !IsConnected}">
                            <TextBlock Text="通信速率:" Foreground="White" Style="{StaticResource ItemTitle}" Width="80"/>
                                <ComboBox Width="120" ItemsSource="{Binding CANBaudList}" Style="{StaticResource CustomComboBoxStyle}"
                                         SelectedItem="{Binding SelectedCANBaud,Mode=TwoWay}"
                                         DisplayMemberPath="Name"
                                         SelectedValuePath="Value"
                                         Height="22"
                                         IsEnabled="{calc:Binding !IsConnected}"
                                         Visibility="{calc:Binding 'ConnectType==2',FalseToVisibility=Collapsed}"/>
                            </StackPanel>
                            <StackPanel  Orientation="Horizontal"   Visibility="{calc:Binding 'ConnectType==2',FalseToVisibility=Collapsed}" 
            Margin="0,0,0,0" Height="22"  IsEnabled="{calc:Binding !IsConnected}">
                                <TextBlock Text="设备驱动:" Foreground="White" Style="{StaticResource ItemTitle}" Width="80"/>
                                <ComboBox Width="120" ItemsSource="{Binding BBLLCCANTYPEList}" Style="{StaticResource CustomComboBoxStyle}"
                                             SelectedItem="{Binding SelectedCANType,Mode=TwoWay}"
                                             DisplayMemberPath="Name"
                                             SelectedValuePath="Value"
                                             Height="22"
                                             IsEnabled="{calc:Binding !IsConnected}"
                                             Visibility="{calc:Binding 'ConnectType==2',FalseToVisibility=Collapsed}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"   Visibility="{calc:Binding 'ConnectType==2',FalseToVisibility=Collapsed}"  Height="22"  IsEnabled="{calc:Binding !IsConnected}">
                                <TextBlock Text="数据帧间隔设置(ms):" Foreground="White" Style="{StaticResource ItemTitle}"  Width="130"/>
                                <TextBox Style="{StaticResource TextBoxExtend.Small}" Width="100"   Height="22"   Text="{Binding CanDelay}" 
             Visibility="{calc:Binding 'ConnectType==2',FalseToVisibility=Collapsed}"/>

                            </StackPanel>
                            <!-- I2C -->
                            <ComboBox Width="200" ItemsSource="{Binding CommunicationI2CList}" Style="{StaticResource CustomComboBoxStyle}"
                                     SelectedItem="{Binding SelectedCommunicationI2CType,Mode=TwoWay}"
                                     DisplayMemberPath="Name"
                                     SelectedValuePath="Value"
                                     Height="22"
                                     IsEnabled="{calc:Binding !IsConnected}"
                                     Visibility="{calc:Binding 'ConnectType==3',FalseToVisibility=Collapsed}"/>
                     
                            
                            <TextBlock Width="5"></TextBlock>                          
                            <StackPanel  Orientation="Horizontal"   Visibility="{calc:Binding 'ConnectType==3',FalseToVisibility=Collapsed}">
                                <TextBlock Text="时钟速率:" Foreground="White" Width="70" Style="{StaticResource ItemTitle}"/>
                                <ComboBox Width="100" ItemsSource="{Binding CommunicationI2CClock}" Style="{StaticResource CustomComboBoxStyle}"
                                      SelectedItem="{Binding SelectedCommunicationI2CClock,Mode=TwoWay}"   
                                        DisplayMemberPath="Name"
                                        SelectedValuePath="Value"
                                      Height="22"
                                      IsEnabled="{calc:Binding !IsConnected}"
                                      Visibility="{calc:Binding 'ConnectType==3',FalseToVisibility=Collapsed}"/>    
                            </StackPanel>
                            <TextBlock Width="5"></TextBlock>
                            <StackPanel Orientation="Horizontal"   Visibility="{calc:Binding 'ConnectType==3',FalseToVisibility=Collapsed}">
                                <TextBlock Text="从机地址:" Foreground="White" Width="70" Style="{StaticResource ItemTitle}"/>
                                <ComboBox Width="100" ItemsSource="{Binding CommunicationI2CDeviceList}" Style="{StaticResource CustomComboBoxStyle}"
                        SelectedItem="{Binding SelectedCommunicationI2CDevice,Mode=TwoWay}"        
                        Height="22"
                        IsEnabled="{calc:Binding !IsConnected}"
                        Visibility="{calc:Binding 'ConnectType==3',FalseToVisibility=Collapsed}"/>
                            </StackPanel>
                            <TextBlock Width="5"></TextBlock>
                            <StackPanel  Orientation="Horizontal"   Visibility="{calc:Binding 'ConnectType==3',FalseToVisibility=Collapsed}">
                                <TextBlock Text="时钟延展:" Foreground="White" Width="70" Style="{StaticResource ItemTitle}"/>
                                <ComboBox Width="100" ItemsSource="{Binding CommunicationI2CSCL}" Style="{StaticResource CustomComboBoxStyle}"
                                  SelectedItem="{Binding SelectCommunicationI2CSCL,Mode=TwoWay}"        
                                  Height="22"
                                  IsEnabled="{calc:Binding !IsConnected}"
                                  Visibility="{calc:Binding 'ConnectType==3',FalseToVisibility=Collapsed}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"   Visibility="{calc:Binding 'ConnectType==3',FalseToVisibility=Collapsed}"  Height="22"  IsEnabled="{calc:Binding !IsConnected}">
                                <TextBlock Text="数据帧间隔设置(ms):" Foreground="White" Style="{StaticResource ItemTitle}"  Width="140"/>
                                <TextBox Style="{StaticResource TextBoxExtend.Small}" Width="100"   Height="22"   Text="{Binding Delay}" 
                                         Visibility="{calc:Binding 'ConnectType==3',FalseToVisibility=Collapsed}"/>

                            </StackPanel>
                            <StackPanel Orientation="Horizontal"  Margin="10,0,0,0"   Height="22"  IsEnabled="{calc:Binding !IsConnected}">
                                <TextBlock Text="寄存器查询间隔(ms):" Foreground="White" Style="{StaticResource ItemTitle}"  Width="120"/>
                                <TextBox Style="{StaticResource TextBoxExtend.Small}" Width="100"   Height="22"   Text="{Binding RegisterDelay}"  />

                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                

            </StackPanel>
        </Border>
        <!--<Border Grid.Column="1" Padding="0,0,8,0">
            <controls:ToggleButton VerticalAlignment="Center" IsChecked="{Binding IsDarkTheme,Mode=TwoWay}"/>
        </Border>-->
    </Grid>
</UserControl>
