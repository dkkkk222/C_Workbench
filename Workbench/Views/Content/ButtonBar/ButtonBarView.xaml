<UserControl x:Class="Workbench.Views.Content.ButtonBar.ButtonBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:prism="http://prismlibrary.com/"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="800">
    <Grid Height="35" Background="{DynamicResource SecondaryBackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Padding="5,5" BorderThickness="0,1,0,1" BorderBrush="#CCCCCC">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ButtonBarStyle}" ToolTip="新建" Command="{Binding NewProjectCommand}">
                    <TextBlock Text="&#xe620;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                </Button>
                <Button Style="{StaticResource ButtonBarStyle}" ToolTip="打开" Command="{Binding OpenProjectCommand}">
                    <TextBlock Text="&#xe614;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                </Button>
                <Button Style="{StaticResource ButtonBarStyle}" ToolTip="保存" Command="{Binding SaveProjectCommand}">
                    <TextBlock Text="&#xe627;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                </Button>
                <Button Style="{StaticResource ButtonBarStyle}" ToolTip="另存为" Command="{Binding SaveAsProjectCommand}">
                    <TextBlock Text="&#xe628;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                </Button>
                <StackPanel Orientation="Horizontal" Visibility="{calc:Binding IsSelectedProject,FalseToVisibility=Collapsed}">
                    <Border Style="{StaticResource VerticalSeparatorStyle}"/>
                    <Button Style="{StaticResource ButtonBarStyle}" 
                            ToolTip="连接" 
                            Command="{Binding ConnectCommand}"
                            IsEnabled="{calc:Binding !IsConnected}">
                        <TextBlock Text="&#xe67e;" 
                                   FontFamily="{StaticResource Iconfont}" 
                                   Style="{StaticResource ButtonBarIconStyle}"/>
                    </Button>
                    <Button Style="{StaticResource ButtonBarStyle}" 
                            ToolTip="断开" 
                            Command="{Binding DisconnectCommand}"
                            IsEnabled="{Binding IsConnected}">
                        <TextBlock Text="&#xe64d;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                    </Button>
                    <Button Style="{StaticResource ButtonBarStyle}" ToolTip="调试" IsEnabled="{Binding IsConnected}">
                        <TextBlock Text="&#xe671;" 
                                   FontFamily="{StaticResource Iconfont}" 
                                   Style="{StaticResource ButtonBarIconStyle}"/>
                    </Button>
                    <!--<Button Style="{StaticResource ButtonBarStyle}" ToolTip="固化参数" IsEnabled="{Binding IsConnected}">
                        <TextBlock Text="&#xe60b;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                    </Button>-->
                    <!--<Button Style="{StaticResource ButtonBarStyle}" ToolTip="下发参数" IsEnabled="{Binding IsConnected}">
                        <TextBlock Text="&#xe62d;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                    </Button>-->
                    <!--<Button Style="{StaticResource ButtonBarStyle}" ToolTip="工程设置">
                        <TextBlock Text="&#xe61c;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                    </Button>
                    <Button Style="{StaticResource ButtonBarStyle}" ToolTip="固件升级">
                        <TextBlock Text="&#xe60f;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource ButtonBarIconStyle}"/>
                    </Button>-->
                    <Border Style="{StaticResource VerticalSeparatorStyle}"/>
                    <!-- 通讯方式 -->
                    <Border Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="通讯方式：" Style="{DynamicResource ButtonBarTitleStyle}"/>
                            <ComboBox Width="120" ItemsSource="{Binding CommunicationTypeList}" Style="{StaticResource ComboBoxExtend.Small}"
                                      SelectedItem="{Binding SelectedCommunicationType}"
                                      IsEnabled="{calc:Binding !IsConnected}"
                                      Height="22"/>
                        </StackPanel>
                    </Border>
                    <!-- 端口 -->
                    <Border Margin="10,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PortTitle}" Style="{DynamicResource ButtonBarTitleStyle}"/>
                            <ComboBox ItemsSource="{Binding PortList}" Width="120" Style="{StaticResource ComboBoxExtend.Small}"
                                      SelectedItem="{Binding SerialPortName, Mode=TwoWay}"
                                      Height="22"
                                      IsEnabled="{calc:Binding !IsConnected}"
                                      Visibility="{calc:Binding IsModbusSelected,FalseToVisibility=Collapsed}"/>
                            <!-- CAN口 -->
                            <!--<ComboBox Width="120" ItemsSource="{Binding CANList}"
                                      SelectedItem="{Binding SelectedCAN,Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Value"
                                      Height="22"
                                      IsEnabled="{calc:Binding !IsConnected}"
                                      Visibility="{calc:Binding !IsModbusSelected,FalseToVisibility=Collapsed}"/>-->
                        </StackPanel>
                    </Border>
                </StackPanel>
                

            </StackPanel>
        </Border>
        <!--<Border Grid.Column="1" Padding="0,0,8,0">
            <controls:ToggleButton VerticalAlignment="Center" IsChecked="{Binding IsDarkTheme,Mode=TwoWay}"/>
        </Border>-->
    </Grid>
</UserControl>
