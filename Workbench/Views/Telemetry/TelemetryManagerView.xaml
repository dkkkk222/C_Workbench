<UserControl x:Class="Workbench.Views.Telemetry.TelemetryManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.Telemetry"
             mc:Ignorable="d" 
             xmlns:cvt="clr-namespace:Workbench.Converters"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:utils="clr-namespace:Workbench.Utils"
             UseLayoutRounding="True"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <cvt:IntToStatusConverter x:Key="IntToStatusConverter"/>
        <BooleanToVisibilityConverter x:Key="Bool2Vis"/>
        <cvt:BoolToGridLengthStarOrZeroConverter x:Key="BoolToStarOrZero"/>
        <cvt:BoolToGridLengthPixelOrZeroConverter x:Key="BoolTo10pxOrZero" Pixels="10"/>
        <cvt:BoolToTextConverter x:Key="BoolToText"/>
        <cvt:RowIndexConverter x:Key="RowIndexConverter"/>
        <cvt:IsOddAlternationConverter x:Key="IsOddAlternationConverter"/>
        <Style x:Key="FilePathCellStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <!-- 超出部分显示 “...” -->
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <!-- 悬停显示完整 -->
            <Setter Property="ToolTip" Value="{Binding FilePath}"/>
        </Style>
        <Style x:Key="MenuItemIcon" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style x:Key="FormBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="0,10"/>
        </Style>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border Grid.Column="1" Background="{StaticResource HomeBackgroundColor}" Margin="4,0,0,0" CornerRadius="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition  Height="50"></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Border Grid.Row="1" Padding="0,0,0,0">
                    <DataGrid x:Name="SequenceGrid" ItemsSource="{Binding TelemetryItemsView}" AutoGenerateColumns="False" CanUserResizeColumns="True"                                  
                                  AlternationCount="2"   Background="{DynamicResource DataGridBackgroundColor}"  ColumnHeaderHeight="20"
                                      RowHeaderWidth="40" LoadingRow="SequenceGrid_LoadingRow" Sorting="SequenceGrid_Sorting" RowHeight="40"
                                      Loaded="SequenceGrid_OnLoaded" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0" SelectionChanged="SequenceGrid_SelectionChanged">
                         
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}"  >
                                <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="10,0,0,0"/>
                                <Setter Property="Margin" Value="0,0,12,0"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                <Setter Property="BorderThickness" Value="1,0,0,1" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Resources>
                            <utils:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#3D7EFF"/>
                        </DataGrid.Resources>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                <Setter Property="Margin" Value="8,0,12,0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <!-- 前景色跟随行 -->
                                <Setter Property="Foreground"
Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>

                                <Style.Triggers>
                                    <!-- 选中 -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>

                                    <!-- 选中 + DataGrid失焦（例如右键弹菜单） -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </MultiDataTrigger>

                                    <!-- Hover 时也别盖住整行背景 -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
                                <Setter Property="Tag" Value="{Binding Path=DataContext,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <!--<Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu Style="{StaticResource ContextMenu.Small}" Width="125">
                                            <MenuItem Header="删除" Command="{Binding Path=PlacementTarget.Tag.RemoveSequenceItemCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                            <MenuItem Header="复制" Command="{Binding Path=PlacementTarget.Tag.CopyCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                            <MenuItem Header="上移" Command="{Binding Path=PlacementTarget.Tag.MoveUpCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                            <MenuItem Header="下移" Command="{Binding Path=PlacementTarget.Tag.MoveDownCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>-->
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="SnapsToDevicePixels" Value="True" />
                                <!-- 新增：默认不加粗 -->
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <!-- 斑马纹：奇数行底色 -->
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self},
                                               Path=AlternationIndex,
                                               Converter={StaticResource IsOddAlternationConverter}}"
                             Value="True">
                                        <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <!-- Hover：偶数行 -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=AlternationIndex,
                                                     Converter={StaticResource IsOddAlternationConverter}}"
                                   Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="{StaticResource RowHoverBrushEven}"/>
                                    </MultiDataTrigger>

                                    <!-- Hover：奇数行 -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=AlternationIndex,
                                                     Converter={StaticResource IsOddAlternationConverter}}"
                                   Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="{StaticResource RowHoverBrushOdd}"/>
                                    </MultiDataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                    </Trigger>

                                    <!-- 选中（鼠标不在上面） -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                        <!-- 白字 -->
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <!-- 去掉分割线 -->
                                    </MultiTrigger>

                                    <!-- 选中 + 悬停 -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="指令名称" Width="Auto" MinWidth="60" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[0].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!--<TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" TextTrimming="CharacterEllipsis"/>-->
                                            <TextBox Text="{Binding Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"
                                                                IsReadOnly="False">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxExtend.Small}">
                                                        <Style.Triggers>
                                                            <!-- 获得焦点时变色 -->
                                                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="指令类型" Binding="{Binding Type , Converter={StaticResource IntToStatusConverter}}"  Width="Auto" MinWidth="60" ElementStyle="{StaticResource CenterCellStyle}" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[1].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}"/>

                            <DataGridTemplateColumn Header="指令码(HEX)" Width="*" MinWidth="110" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[4].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}"  >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Code,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"
                                                        IsReadOnly="False"
                                                 LostFocus="HexValueText_LostFocus">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxExtend.Small}">
                                                    <Style.Triggers>
                                                        <!-- 获得焦点时变色 -->
                                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="管理" Width="170" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">

                                            
                                            <hc:UniformSpacingPanel Spacing="10">
                                                <!--<Button Content="修改" Style="{StaticResource ButtonInfo.Small}" hc:IconElement.Geometry="{StaticResource PenGeometry}"/>-->
                                                <Button Content="删除" Style="{StaticResource ButtonDanger.Small}" hc:IconElement.Geometry="{StaticResource TrashGeometry}" Click="Delete_Click"/>
                                                <Button Content="保存修改" Style="{StaticResource ButtonDanger.Small}" Background="{DynamicResource ShowPageButtonBackgroundColor}" BorderBrush="{DynamicResource ShowPageButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource ReadGeometry}" Click="Save_Click"/>
                                            </hc:UniformSpacingPanel>

                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="100">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="选择"/>
                                        <CheckBox IsChecked="{Binding Path=DataContext.CheckAll,RelativeSource={RelativeSource AncestorType=UserControl}}"
                      Margin="5,0,0,0">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <TextBlock Text="选择" Visibility="Hidden"/>
                                            <CheckBox IsChecked="{Binding IsChecked,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Margin="10,0,0,0">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                            </CheckBox>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                </Border>

                <Border Grid.Row="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <hc:SearchBar Grid.Row="3" Margin="0,0,250,0" Width="150" hc:InfoElement.Placeholder="请输入搜索关键字" hc:InfoElement.ShowClearButton="True">
                            <hc:SearchBar.Style>
                                <Style TargetType="hc:SearchBar" BasedOn="{StaticResource SearchBarPlus}">
                                    <Style.Triggers>
                                        <!-- 获得焦点时变色 -->
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </hc:SearchBar.Style>
                            <hc:SearchBar.Text>
                                <Binding Path="TreeKeyword" UpdateSourceTrigger="PropertyChanged"/>
                            </hc:SearchBar.Text>
                        </hc:SearchBar>
                        
                        <Button Content="批量删除" Style="{StaticResource ButtonPrimary}" Margin="0,0,5,0" Background="{DynamicResource DelButtonBackground}" BorderBrush="{DynamicResource DelButtonBackground}" hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
Command="{Binding BatchDelCommand}"/>
                        
                        <Button Style="{StaticResource ButtonPrimary}" Margin="0,0,5,0" Background="{StaticResource ShowPageButtonBackgroundColor}" BorderBrush="{StaticResource ShowPageButtonBackgroundColor}" Content="新增" Width="80" Height="30" Command="{Binding AddCommand}"
         hc:IconElement.Geometry="{StaticResource AddGeometry}" hc:IconElement.Width="13"/>
                        
                        <Button Style="{StaticResource ButtonPrimary}" Margin="0,0,5,0" Background="{StaticResource StopButtonBackground}" BorderBrush="{StaticResource StopButtonBackground}" Content="导出" Width="80" Height="30" Command="{Binding ExportCommand}"
                                hc:IconElement.Geometry="{StaticResource PinMaximize}" hc:IconElement.Width="13"/>
                        
                        <Button Style="{StaticResource ButtonPrimary}" Background="{StaticResource ShowPageButtonBackgroundColor}" Content="导入" Width="80" Height="30" Command="{Binding ImportCommand}"
                                hc:IconElement.Geometry="{StaticResource SaveGeometry}" hc:IconElement.Width="13"/>

                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
