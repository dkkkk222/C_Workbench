<UserControl x:Class="Workbench.Views.Telemetry.TelemetryChartListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.Telemetry"
             mc:Ignorable="d" 
              xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:local_Model="clr-namespace:Workbench.Models"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:cvt="clr-namespace:Workbench.Converters"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
             xmlns:localBehaviors="clr-namespace:Workbench.Models.MoveThumb"
             xmlns:utils="clr-namespace:Workbench.Utils"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:controls_Title="clr-namespace:Workbench.Controls.Controls.Title;assembly=Workbench.Controls"
             xmlns:controls_Scottplot="clr-namespace:Workbench.Controls.Controls.Scottplot;assembly=Workbench.Controls"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <cvt:RowIndexConverter x:Key="RowIndexConverter"/>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>

        </Style>
        <!-- 背景网格（10px） -->
        <DrawingBrush x:Key="DesignerGridBrush"
          TileMode="Tile"
          Viewport="0,0,10,10"
          ViewportUnits="Absolute"
          Stretch="None">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#22000000" Thickness="1"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <!-- 只画右边和下边，Tile 后就是网格 -->
                        <GeometryGroup>
                            <LineGeometry StartPoint="10,0" EndPoint="10,10"/>
                            <LineGeometry StartPoint="0,10" EndPoint="10,10"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- 顶部控制条：行/列、布局方式、方向、对齐 -->
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
            <!-- 行/列（LostFocus 更新，避免输入中间报错） -->
            <TextBlock Text="行:" Style="{StaticResource ItemTitle}" Width="30"/>
            <TextBox Width="60" Margin="8,0" Height="30"
              Text="{Binding GridRows, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Text="列:" Style="{StaticResource ItemTitle}" Width="30"/>
            <TextBox Width="60" Margin="8,0" Height="30"
              Text="{Binding GridColumns, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
            <Button Style="{StaticResource ButtonPrimary.Small}" Content="应用布局"
 Background="{DynamicResource GenButtonBackgroundColor}"
 BorderBrush="{DynamicResource GenButtonBackgroundColor}"
 hc:IconElement.Geometry="{StaticResource  PenGeometry }"
 Margin="5,0,0,0"
 Command="{Binding ApplyLayoutCommand}" />
            <Button 
       Margin="5,0,0,0"  Background="{DynamicResource GenButtonBackgroundColor}"
BorderBrush="{DynamicResource GenButtonBackgroundColor}"  hc:IconElement.Geometry="{StaticResource  PenGeometry }"
       Command="{Binding ToggleGridCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary.Small}">
                        <Setter Property="Content" Value="隐藏网格"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGridVisible}" Value="False">
                                <Setter Property="Content" Value="显示网格"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- 主体列表 -->
        <ScrollViewer Grid.Row="1"
              HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Auto"
              CanContentScroll="False">
            <!-- 关键：提供 AdornerLayer，用于对齐线 -->
            <AdornerDecorator>
                <Grid Width="{Binding CanvasWidth, FallbackValue=5000}"
              Height="{Binding CanvasHeight, FallbackValue=3000}"
              SnapsToDevicePixels="True"
              UseLayoutRounding="True"
              ClipToBounds="True"
              RenderOptions.EdgeMode="Aliased">

                    <!-- 背景网格：可显示/隐藏，不影响吸附 -->
                    <Rectangle Fill="{StaticResource DesignerGridBrush}"
                       IsHitTestVisible="False">
                        <Rectangle.Style>
                            <Style TargetType="Rectangle">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGridVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Rectangle.Style>
                    </Rectangle>
                    <ItemsControl ItemsSource="{Binding WatchGroupsView}">
                <!-- 用 Canvas 做面板，支持自由定位 -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- 画布尺寸可以绑定到 VM 的 CanvasWidth/Height；也可先给个大一点的固定值 -->
                        <Canvas Width="{Binding CanvasWidth, FallbackValue=5000}"
                        Height="{Binding CanvasHeight, FallbackValue=3000}"  Background="Transparent"
                                SnapsToDevicePixels="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- Item 容器：把位置/尺寸绑到项 VM -->
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left, Mode=TwoWay}" />
                        <Setter Property="Canvas.Top"  Value="{Binding Top,  Mode=TwoWay}" />
                        <Setter Property="Width"       Value="{Binding ChartWidth,  Mode=TwoWay}" />
                        <Setter Property="Height"      Value="{Binding ChartHeight, Mode=TwoWay}" />
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <!-- 卡片主体（你原有内容） -->
                            <Border x:Name="RootCard"
                            Width="{Binding ChartWidth,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Height="{Binding ChartHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            MinWidth="380" MinHeight="300"
                            Background="White"
                            BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                            Padding="8" Margin="0">
                                <DockPanel LastChildFill="True">
                                    <!-- 顶部：标题/参数区（我们会在这层加一个透明 Thumb 当“拖拽把手”） -->
                                    <Border DockPanel.Dock="Top" Padding="2" Background="Transparent">
                                        <Grid>
                                            <!-- 你的原有头部内容 -->
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                    <controls_Title:StandTitle Padding="0" BordMargin="10,0,5,0" Margin="0"
                                                                       TextMargin="0"
                                                                       StandText="{Binding ChartName}"
                                                                       StandFontSize="{DynamicResource SubHeadFontSize}"/>
                                                    <!-- 省略：你原先的四个 TextBox + “设置”按钮 -->
                                                </StackPanel>

                                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                    <controls_Title:StandTitle Padding="0,0,0,0" BordMargin="10,0,5,0" Margin="0,0,0,0" TextMargin="0,0,0,0"
                                                                       StandText="{Binding ChartName}"
                                                                       StandFontSize="{DynamicResource SubHeadFontSize}"/>

                                                    <TextBox Text="{Binding Chart1MinX}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="X最小值：" Margin="5,0,0,0"
                                                     hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                    <TextBox Text="{Binding Chart1MaxX}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="X最大值：" Margin="5,0,0,0"
                                                     hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                    <TextBox Text="{Binding Chart1MinY}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="Y最小值：" Margin="5,0,0,0"
                                                     hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                    <TextBox Text="{Binding Chart1MaxY}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="Y最大值：" Margin="5,0,0,0"
                                                     hc:InfoElement.TitlePlacement="Left" Width="110" />
                                                    <Button Style="{StaticResource ButtonPrimary.Small}" Content="设置"
                                                    Background="{DynamicResource GenButtonBackgroundColor}"
                                                    BorderBrush="{DynamicResource GenButtonBackgroundColor}"
                                                    hc:IconElement.Geometry="{StaticResource  PenGeometry }"
                                                    Margin="5,0,0,0"
                                                    Command="{Binding SettingChartLimitCommand}"
                                                    CommandParameter="{Binding}"/>
                                                </StackPanel>

                                                <!--<StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5,0,0">
                                                    <TextBox Text="{Binding ChartWidth}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="宽：" hc:InfoElement.TitlePlacement="Left" Width="80"/>
                                                    <TextBlock Width="35"/>
                                                    <TextBox Text="{Binding ChartHeight}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="高：" hc:InfoElement.TitlePlacement="Left" Width="80"/>
                                                    <TextBlock Width="80"/>
                                                    <Button Visibility="Hidden" Content="设置" Style="{StaticResource ButtonPrimary.Small}"
                                                    Background="{DynamicResource GenButtonBackgroundColor}"
                                                    BorderBrush="{DynamicResource GenButtonBackgroundColor}"
                                                    hc:IconElement.Geometry="{StaticResource PenGeometry}"/>
                                                </StackPanel>-->

                                                <!--<StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5,0,0">
                                                    <TextBox Text="{Binding ChartWidth}"  Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="宽：" hc:InfoElement.TitlePlacement="Left" Width="80"/>
                                                    <TextBlock Width="30"/>
                                                    <TextBox Text="{Binding ChartHeight}" Style="{StaticResource TextBoxExtend.Small}" hc:InfoElement.Title="高：" hc:InfoElement.TitlePlacement="Left" Width="80"/>
                                                </StackPanel>-->
                                            </Grid>

                                            <!-- 透明移动把手：只覆盖头部区域，避免和 Plot 的交互冲突 -->
                                            <Thumb Cursor="SizeAll" Background="Transparent" Margin="0,-10,0,0" BorderThickness="11"
                                           HorizontalAlignment="Stretch" VerticalAlignment="Top" BorderBrush="Transparent" 
                                           Panel.ZIndex="10"   Height="20">
                                                <i:Interaction.Behaviors>
                                                            <localBehaviors:MoveThumbBehavior LeftPropertyName="Left" TopPropertyName="Top" WidthPropertyName="TableWidth"
                                                                                                HeightPropertyName="TableHeight"
                                                                                                GridSize="10"
                                                                                                SnapThreshold="6"
                                                                                                SnapToGrid="True"
                                                                                                SnapToOtherItems="True"/>
                                                </i:Interaction.Behaviors>
                                            </Thumb>
                                        </Grid>
                                    </Border>

                                    <!-- 中间：你的 ScottPlot 实时图 -->
                                    <Border Margin="0,1,0,0">
                                        <controls_Scottplot:LiveDataPlot PlotData="{Binding WpfPlotControl2, Mode=TwoWay}"/>
                                    </Border>
                                </DockPanel>
                            </Border>

                            <!-- 右下角改大小把手（覆盖在卡片之上） -->
                            <Thumb Width="14" Height="14"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Margin="0" Cursor="SizeNWSE"
                           Background="Transparent" BorderBrush="Transparent" BorderThickness="7"
                           ToolTip="拖拽调整大小"
                           Panel.ZIndex="20">
                                <i:Interaction.Behaviors>
                                    <localBehaviors:ResizeThumbBehavior
                                WidthPropertyName="ChartWidth"
                                HeightPropertyName="ChartHeight"
                                MinWidth="380"
                                MinHeight="300"/>
                                </i:Interaction.Behaviors>
                            </Thumb>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
                </Grid>
            </AdornerDecorator>
        </ScrollViewer>
    </Grid>
</UserControl>
