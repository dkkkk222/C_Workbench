<UserControl x:Class="Workbench.Views.Telemetry.TelemetryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views.Telemetry"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:viewModels="clr-namespace:Workbench.ViewModels.Telemetry"
             xmlns:views="clr-namespace:Workbench.Views.Telemetry"
             xmlns:cvt="clr-namespace:Workbench.Converters"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:utils="clr-namespace:Workbench.Utils"
             xmlns:behaviors="clr-namespace:Workbench.Behaviors"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:controls_Title="clr-namespace:Workbench.Controls.Controls.Title;assembly=Workbench.Controls"
             xmlns:local_Model="clr-namespace:Workbench.Models"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewModels:TelemetryViewModel}">
            <views:TelemetryView />
        </DataTemplate>
        <cvt:IntToStatusConverter x:Key="IntToStatusConverter"/>
        <BooleanToVisibilityConverter x:Key="Bool2Vis"/>
        <cvt:BoolToGridLengthStarOrZeroConverter x:Key="BoolToStarOrZero"/>
        <cvt:BoolToGridLengthPixelOrZeroConverter x:Key="BoolTo10pxOrZero" Pixels="10"/>
        <cvt:BoolToTextConverter x:Key="BoolToText"/>
        <cvt:RowIndexConverter x:Key="RowIndexConverter"/>
        <cvt:IsOddAlternationConverter x:Key="IsOddAlternationConverter"/>
        <Style x:Key="ItemTitle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
        </Style>
        <!-- ComboBoxItem 样式 -->
        <Style x:Key="CustomComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{StaticResource ComboBoxItem.Small}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Bd" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" 
  Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" 
  CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- 选中项鼠标悬停时的背景色 -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="ListBoxItem.IsSelected" Value="False"/>
                        <Condition Property="UIElement.IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Value="{DynamicResource SecondaryRegionBrush}" Property="Background"/>
                </MultiTrigger>
                <!-- 选中项的背景颜色 -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="ListBoxItem.IsSelected" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Value="{DynamicResource PrimaryBrush}" Property="Background"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiTrigger>
                <!-- 设置选中项的背景颜色 -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryBackgroundColor}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- ComboBox 样式 -->
        <Style x:Key="CustomComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ComboBoxExtend.Small}">
            <Setter Property="ItemContainerStyle" Value="{StaticResource CustomComboBoxItemStyle}" />
            <Style.Triggers>
                <!-- 获得焦点时变色 -->
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Name="LeftCol" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Width="324" HorizontalAlignment="Left" Background="{StaticResource AvalonDockAreaBackgroundColor}" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                    <Border Style="{StaticResource BorderCircular}" Margin="5,10,0,0"  BorderBrush="Transparent" Background="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <controls_Title:StandTitle Padding="0,0,0,0" BordMargin="0,0,5,0" StandText="指令目录" StandFontSize="{DynamicResource SubHeadFontSize}"/>
                        </StackPanel>
                    </Border>
                    <hc:UniformSpacingPanel Spacing="8" Orientation="Horizontal" Margin="0,10">
                        <RadioButton GroupName="OrderBy" Content="按分类"
             IsChecked="{Binding IsOrderByCategory, Mode=TwoWay}" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"/>
                        <RadioButton GroupName="OrderBy" Content="按名称"
             IsChecked="{Binding IsOrderByName, Mode=TwoWay}" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"/>
                        <RadioButton GroupName="OrderBy" Content="按编码"
             IsChecked="{Binding IsOrderByAddress, Mode=TwoWay}" Style="{StaticResource CheckedOnlyColorRadio}" Tag="{DynamicResource BordTitleBackgroundColor}"/>
                        
                        <CheckBox Content="全选/反选" IsChecked="{Binding BatchAllCheck,Mode=TwoWay}" Command="{Binding SelectAllCommand}" CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="false">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>
                    </hc:UniformSpacingPanel>
                </hc:UniformSpacingPanel>
             
                <hc:SearchBar Grid.Row="3"  hc:InfoElement.Placeholder="请输入搜索关键字" hc:InfoElement.ShowClearButton="True">
                    <hc:SearchBar.Style>
                        <Style TargetType="hc:SearchBar" BasedOn="{StaticResource SearchBarPlus}">
                            <Style.Triggers>
                                <!-- 获得焦点时变色 -->
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </hc:SearchBar.Style>
                    <hc:SearchBar.Text>
                        <Binding Path="TreeKeyword" UpdateSourceTrigger="PropertyChanged"/>
                    </hc:SearchBar.Text>
                </hc:SearchBar>
                <Border Margin="0,5,0,0" Grid.Row="4">
                    <TreeView ItemsSource="{Binding SingleParamTrees}" Background="{DynamicResource InLeftTreeViewBackGround}">
                        <TreeView.Resources>
                            <!-- ★ 继承原样式，只追加两个 Setter -->
                            <Style x:Key="BindableTreeViewItemStyle"
                                TargetType="TreeViewItem"
                                BasedOn="{StaticResource TreeViewItemStyle}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.Resources>

                        <!-- 只影响当前这棵 TreeView -->
                        <TreeView.ItemContainerStyle>
                            <StaticResource ResourceKey="BindableTreeViewItemStyle"/>
                        </TreeView.ItemContainerStyle>
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectedItemChanged">
                                <i:InvokeCommandAction Command="{Binding SelectedItemChangedCommand}" 
                                 CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel>
                                    <TextBlock Visibility="{c:Binding 'AddressHex==null',FalseToVisibility=Collapsed}" Text="{Binding Title}" Foreground="{DynamicResource TreeViewNodeBrush}"/>
                                    <StackPanel Orientation="Horizontal" Visibility="{c:Binding 'AddressHex!=null',FalseToVisibility=Collapsed}">
                                        <CheckBox IsChecked="{Binding IsCheck}">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCheck}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCheck}" Value="false">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>
                                        <TextBlock Width="5"></TextBlock>
                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TreeViewNodeBrush}"/>
                                        <TextBlock Text=" : "/>
                                        <TextBlock Text="{Binding AddressHex}" Foreground="{DynamicResource TreeViewNodeBrush}"/>
                                        
                                        


                                    </StackPanel>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Padding="2,8,28,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{Binding UpGridWidth,Mode=TwoWay}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{Binding DownGridWidth,Mode=TwoWay}"/>
                </Grid.RowDefinitions>
                <Border>
                    <Grid>
                        <Border Margin="0,0,0,0" >
                            <DockPanel LastChildFill="True">
                                <Border Style="{StaticResource BorderCircular}" Margin="5,10,0,5" DockPanel.Dock="Top"  BorderBrush="Transparent" Background="Transparent">
                                    <DockPanel LastChildFill="True">
                                        <!--<TextBlock Text="序列管理列表" FontSize="{StaticResource SubHeadFontSize}" DockPanel.Dock="Left" VerticalAlignment="Center"/>-->
                                        <controls_Title:StandTitle Padding="0,0,0,0" BordMargin="0,0,5,0" StandText="遥控指令配置列表" StandFontSize="{DynamicResource SubHeadFontSize}"/>
                                        <TextBlock Width="10"></TextBlock>
                                        <Button Style="{StaticResource ButtonDefault.Small}" Margin="0,0,0,6" Width="126" VerticalAlignment="Center"
        ToolTip="展开/收起指令目录" Content="展开指令目录" Visibility="{c:Binding !IsLeftOpen,FalseToVisibility=Collapsed}"
        Command="{Binding ToggleDrawerCommand}" hc:IconElement.Geometry="{StaticResource  AlignLeftGeometry}"/>
                                        <Button Style="{StaticResource ButtonDefault.Small}" Margin="0,0,0,6" Width="126" VerticalAlignment="Center"
ToolTip="展开/收起指令目录" Content="收起指令目录" Visibility="{c:Binding IsLeftOpen,FalseToVisibility=Collapsed}"
Command="{Binding ToggleDrawerCommand}" hc:IconElement.Geometry="{StaticResource AlignRightGeometry}" />

                                       
                                        <Border>

                                            <hc:UniformSpacingPanel Spacing="10" HorizontalAlignment="Right">

                                                <Button Content="添加到序列" Style="{StaticResource ButtonPrimary}" Width="110"  Background="{DynamicResource GenButtonBackgroundColor}" BorderBrush="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                            Command="{Binding AddRegisterToSequenceCommand}"/>
                                                <Button Content="批量删除" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource DelButtonBackground}" BorderBrush="{DynamicResource DelButtonBackground}" hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                Command="{Binding BatchDelRegisterCommand}"/>

                                            </hc:UniformSpacingPanel>
                                            <!--<hc:UniformSpacingPanel Spacing="10" HorizontalAlignment="Right">
                                                <Button Content="新增序列" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource GenButtonBackgroundColor}" BorderBrush="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                                        Command="{Binding AddSequenceCommand}"/>                                                
                                                <Button Content="批量删除" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource DelButtonBackground}" BorderBrush="{DynamicResource DelButtonBackground}" hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                                                        Command="{Binding BatchDelCommand}"/>
                                                <Button Content="批量下发" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource StopButtonBackground}" BorderBrush="{DynamicResource StopButtonBackground}" hc:IconElement.Geometry="{StaticResource AllGeometry}"
                                                        Command="{Binding BatchSendCommand}"/>
                                            </hc:UniformSpacingPanel>-->
                                        </Border>
                                    </DockPanel>
                                </Border>
                                <DataGrid x:Name="SequenceGrid" ItemsSource="{Binding CurrentSequence.TelemetryItems}" AutoGenerateColumns="False" CanUserResizeColumns="True"                                  
                                  AlternationCount="2"   Background="{DynamicResource DataGridBackgroundColor}"  ColumnHeaderHeight="20"
                                      RowHeaderWidth="40" LoadingRow="SequenceGrid_LoadingRow" Sorting="SequenceGrid_Sorting" RowHeight="40"
                                      Loaded="SequenceGrid_OnLoaded" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0" SelectionChanged="SequenceGrid_SelectionChanged">
                                    <!--<i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseDoubleClick">
                                        <i:InvokeCommandAction Command="{Binding ConfigRegisterCommand}" CommandParameter="{Binding SelectedItem, ElementName=SequenceGrid}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>-->
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}"  >
                                            <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Padding" Value="10,0,0,0"/>
                                            <Setter Property="Margin" Value="0,0,12,0"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                            <Setter Property="BorderThickness" Value="1,0,0,1" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Resources>
                                        <utils:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#3D7EFF"/>
                                    </DataGrid.Resources>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                            <Setter Property="Margin" Value="8,0,12,0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <!-- 前景色跟随行 -->
                                            <Setter Property="Foreground"
Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>

                                            <Style.Triggers>
                                                <!-- 选中 -->
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>

                                                <!-- 选中 + DataGrid失焦（例如右键弹菜单） -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </MultiDataTrigger>

                                                <!-- Hover 时也别盖住整行背景 -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
                                            <Setter Property="Tag" Value="{Binding Path=DataContext,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <Setter Property="ContextMenu">
                                                <Setter.Value>
                                                    <ContextMenu Style="{StaticResource ContextMenu.Small}" Width="125">
                                                        <MenuItem Header="删除" Command="{Binding Path=PlacementTarget.Tag.RemoveSequenceItemCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                                        <MenuItem Header="复制" Command="{Binding Path=PlacementTarget.Tag.CopyCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                                        <MenuItem Header="上移" Command="{Binding Path=PlacementTarget.Tag.MoveUpCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                                        <MenuItem Header="下移" Command="{Binding Path=PlacementTarget.Tag.MoveDownCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
              CommandParameter="{Binding}"/>
                                                    </ContextMenu>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                            <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="SnapsToDevicePixels" Value="True" />
                                            <!-- 新增：默认不加粗 -->
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <!-- 斑马纹：奇数行底色 -->
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self},
                                               Path=AlternationIndex,
                                               Converter={StaticResource IsOddAlternationConverter}}"
                             Value="True">
                                                    <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                                </DataTrigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Trigger>
                                                <!-- Hover：偶数行 -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=AlternationIndex,
                                                     Converter={StaticResource IsOddAlternationConverter}}"
                                   Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource RowHoverBrushEven}"/>
                                                </MultiDataTrigger>

                                                <!-- Hover：奇数行 -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=AlternationIndex,
                                                     Converter={StaticResource IsOddAlternationConverter}}"
                                   Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource RowHoverBrushOdd}"/>
                                                </MultiDataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                                </Trigger>

                                                <!-- 选中（鼠标不在上面） -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                    <!-- 白字 -->
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <!-- 去掉分割线 -->
                                                </MultiTrigger>

                                                <!-- 选中 + 悬停 -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="指令名称" Width="Auto" MinWidth="60" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[0].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="指令类型" Binding="{Binding Type , Converter={StaticResource IntToStatusConverter}}"  Width="Auto" MinWidth="60" ElementStyle="{StaticResource CenterCellStyle}" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[1].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}"/>

                                        <DataGridTemplateColumn Header="指令码(HEX)" Width="*" MinWidth="110" Visibility="{Binding 
                                                        Source={StaticResource DataContextProxy},
                                                        Path=Data.TableColumns[4].IsChecked,
                                                        Converter={StaticResource Boolean2VisibilityConverter}}"  >
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Code,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"
                                                        IsReadOnly="False"
                                                 LostFocus="HexValueText_LostFocus">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxExtend.Small}">
                                                                <Style.Triggers>
                                                                    <!-- 获得焦点时变色 -->
                                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="下发" Width="Auto" MinWidth="90">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource ButtonInfo.Small}" VerticalAlignment="Center"
                              Content="下发"
                              Command="{Binding DataContext.SendSignCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}"
                              HorizontalAlignment="Left" Background="{DynamicResource GenButtonBackgroundColor}"
                              BorderBrush="{DynamicResource GenButtonBackgroundColor}"
                              hc:IconElement.Geometry="{StaticResource PushGeometry}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Width="Auto" MinWidth="50">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                    <TextBlock Text="选择"/>
                                                    <CheckBox IsChecked="{Binding Path=DataContext.CheckAllResister,RelativeSource={RelativeSource AncestorType=UserControl}}"
                  Margin="5,0,0,0">
                                                        <CheckBox.Style>
                                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </CheckBox.Style>
                                                    </CheckBox>
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
                                                        <TextBlock Text="选择" Visibility="Hidden"/>
                                                        <CheckBox IsChecked="{Binding IsChecked,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Margin="10,0,0,0">
                                                            <CheckBox.Style>
                                                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </CheckBox.Style>
                                                        </CheckBox>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
                <GridSplitter Grid.Row="1" Grid.Column="1" Height="5" Margin="0,5,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{StaticResource GridSplitterBordColor}" ResizeDirection="Rows"></GridSplitter>

                <!--<hc:Divider Grid.Row="1" Margin="0,8"/>-->
                <Border Grid.Row="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding SplitterPositionLeft,Mode=TwoWay}"></ColumnDefinition>
                            <ColumnDefinition  Width="Auto"/>
                            <!-- 分隔列 -->
                            <ColumnDefinition   Width="{Binding SplitterPositionRight,Mode=TwoWay}"/>
                            <!-- 右侧详情 -->
                        </Grid.ColumnDefinitions>
                        <DockPanel LastChildFill="True" MinWidth="560">

                            <Border Style="{StaticResource BorderCircular}" DockPanel.Dock="Top"  Margin="5,10,0,5"  BorderBrush="Transparent" Background="Transparent">
                                <DockPanel LastChildFill="True">
                                    <hc:UniformSpacingPanel  DockPanel.Dock="Left" Spacing="5">
                                        <!--<TextBlock Text="序列配置详情:" FontSize="{StaticResource SubHeadFontSize}" VerticalAlignment="Center"/>-->
                                        <controls_Title:StandTitle  Padding="0,5,0,0"  BordMargin="0,0,5,0" StandText="遥控指令管理列表 :" StandFontSize="{DynamicResource SubHeadFontSize}"/>
                                        <TextBlock Padding="0,5,0,0"  Text="{Binding CurrentSequence.Name}" ToolTip="{Binding CurrentSequence.Name}"  TextTrimming="CharacterEllipsis"  MaxWidth="100"  FontSize="{StaticResource SubHeadFontSize}" VerticalAlignment="Center"/>
                                    </hc:UniformSpacingPanel>
                                    <!--<TextBox Text="{Binding AllTime,Mode=TwoWay}"  VerticalAlignment="Center" Margin="5,5,0,6" hc:InfoElement.TitlePlacement="Left" Width="60" >
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxExtend.Small}">
                                                <Style.Triggers>
                                                    --><!-- 获得焦点时变色 --><!--
                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <Button Content="批量设置间隔" Style="{StaticResource ButtonPrimary.Small}" Background="{DynamicResource ShowPageButtonBackgroundColor}" BorderBrush="{DynamicResource ShowPageButtonBackgroundColor}"   
HorizontalAlignment="Left" hc:IconElement.Width="14"  Margin="5,5,0,6"
Command="{Binding SettingAllTimeCommand}"/>-->
                                    
                                    <Border Margin="0,0,10,0">
                                        
                                        <hc:UniformSpacingPanel Spacing="10" HorizontalAlignment="Right">

                                            <Button Content="新增序列" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource GenButtonBackgroundColor}" BorderBrush="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource AddGeometry}"
             Command="{Binding AddSequenceCommand}"/>
                                            <Button Content="批量删除" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource DelButtonBackground}" BorderBrush="{DynamicResource DelButtonBackground}" hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
             Command="{Binding BatchDelCommand}"/>
                                            <Button Content="批量下发" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource StopButtonBackground}" BorderBrush="{DynamicResource StopButtonBackground}" hc:IconElement.Geometry="{StaticResource AllGeometry}"
             Command="{Binding BatchSendCommand}"/>
                                        </hc:UniformSpacingPanel>
                                    </Border>
                                </DockPanel>
                            </Border>

                            <DataGrid ItemsSource="{Binding SequenceList}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                      CanUserSortColumns="False" CanUserAddRows="False" Margin="0,5,0,0"  RowHeight="40"   Height="Auto"
                                       Background="{DynamicResource DataGridBackgroundColor}" AlternationCount="2"
                                      SelectedItem="{Binding CurrentSequence}">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="{x:Type DataGridColumnHeader}"  >
                                        <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Padding" Value="10,0,0,0"/>
                                        <Setter Property="Margin" Value="0,0,12,0"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                        <Setter Property="BorderThickness" Value="1,0,0,1" />
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
     Color="Transparent"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
     Color="#3D7EFF"/>
                                </DataGrid.Resources>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                        <Setter Property="Margin" Value="8,0,12,0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <!-- 前景色跟随行 -->
                                        <Setter Property="Foreground"
Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>

                                        <Style.Triggers>
                                            <!-- 选中 -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>

                                            <!-- 选中 + DataGrid失焦（例如右键弹菜单） -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </MultiDataTrigger>

                                            <!-- Hover 时也别盖住整行背景 -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Height" Value="40"/>
                                        <Setter Property="Tag" Value="{Binding Path=DataContext,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu Style="{StaticResource ContextMenu.Small}" Width="125">
                                                    <MenuItem Header="删除" Command="{Binding Path=PlacementTarget.Tag.RemoveSequenceListCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
CommandParameter="{Binding}"/>
                                                    <MenuItem Header="复制" Command="{Binding Path=PlacementTarget.Tag.CopySequenceListCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
CommandParameter="{Binding}"/>
                                                    <MenuItem Header="上移" Command="{Binding Path=PlacementTarget.Tag.MoveUpSequenceListCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
CommandParameter="{Binding}"/>
                                                    <MenuItem Header="下移" Command="{Binding Path=PlacementTarget.Tag.MoveDownSequenceListCommand,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="SnapsToDevicePixels" Value="True" />
                                        <!-- 新增：默认不加粗 -->
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Style.Triggers>
                                            <Trigger Property="AlternationIndex" Value="1">
                                                <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Trigger>
                                            <!-- 选中（鼠标不在上面） -->
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                <!-- 白字 -->
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <!-- 去掉分割线 -->
                                            </MultiTrigger>

                                            <!-- 选中 + 悬停 -->
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </MultiTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn  Header="序列编号" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <!-- 使用 MultiBinding -->
                                                        <MultiBinding Converter="{StaticResource RowIndexConverter}">
                                                            <!-- 第一个绑定：绑定到当前行的数据项 (DataContext) -->
                                                            <Binding />
                                                            <!-- 第二个绑定：通过 RelativeSource 找到父级的 DataGrid 控件 -->
                                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="序列名称" Width="*" MinWidth="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  VerticalAlignment="Center"
                                                               hc:InfoElement.Placeholder="请输入名称">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxExtend.Small}">
                                                            <Style.Triggers>
                                                                <!-- 获得焦点时变色 -->
                                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="参数下发数量" Binding="{Binding Items.Count}"  Width="*" IsReadOnly="True"  ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTemplateColumn Header="参数下发间隔(ms)"  Width="*" MinWidth="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <hc:NumericUpDown   Minimum="1" DecimalPlaces="0" VerticalAlignment="Center">
                                                    <hc:NumericUpDown.Style>
                                                        <Style TargetType="hc:NumericUpDown" BasedOn="{StaticResource NumericUpDownExtend.Small}">
                                                            <Style.Triggers>
                                                                <!-- 获得焦点时变色 -->
                                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource BordTitleBackgroundColor}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </hc:NumericUpDown.Style>
                                                    <hc:NumericUpDown.Value>
                                                        <Binding Path="ParamPushInterval" UpdateSourceTrigger="PropertyChanged"></Binding>
                                                    </hc:NumericUpDown.Value>
                                                </hc:NumericUpDown>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="下发" Width="*" MinWidth="50">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource ButtonInfo.Small}" VerticalAlignment="Center"
                                                            Content="下发"
                                                            Command="{Binding DataContext.SendCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            HorizontalAlignment="Left" Background="{DynamicResource GenButtonBackgroundColor}"
                                                            BorderBrush="{DynamicResource GenButtonBackgroundColor}"
                                                            hc:IconElement.Geometry="{StaticResource PushGeometry}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="下发状态" Width="*" MinWidth="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <hc:UniformSpacingPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                    <ProgressBar Style="{StaticResource ProgressBarWarning}" Foreground="{StaticResource StopButtonBackground}" Value="{Binding Progress,Mode=TwoWay}" Width="100"/>
                                                    <Border>
                                                        <TextBlock Text="{Binding Statement}" VerticalAlignment="Center"/>
                                                    </Border>
                                                </hc:UniformSpacingPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="*">
                                        <DataGridTemplateColumn.Header>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                <TextBlock Text="选择"/>
                                                <CheckBox IsChecked="{Binding Path=DataContext.CheckAll,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          Margin="5,0,0,0">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                            </StackPanel>
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                    <TextBlock Text="选择" Visibility="Hidden"/>
                                                    <CheckBox IsChecked="{Binding IsChecked,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Margin="10,0,0,0">
                                                        <CheckBox.Style>
                                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource BordTitleBackgroundColor}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </CheckBox.Style>
                                                    </CheckBox>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                        </DockPanel>
                        <GridSplitter x:Name="DetailSplitter" Grid.Column="1" Width="5" Margin="0,0,0,0" 
                                      Background="{StaticResource GridSplitterBordColor}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  />

                        <Border Grid.Column="2" Padding="2,2,0,0">
                            <DockPanel LastChildFill="True">
                                <Border Style="{StaticResource BorderCircular}" Margin="5,5,0,5" DockPanel.Dock="Top"  BorderBrush="Transparent" Background="Transparent">
                                    <hc:UniformSpacingPanel Spacing="15"  VerticalAlignment="Center">
                                        <controls_Title:StandTitle Padding="0,5,0,0" BordMargin="0,0,5,0" StandText="历史数据" StandFontSize="{DynamicResource SubHeadFontSize}"/>

                                        <Button Content="下载" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource GenButtonBackgroundColor}" BorderBrush="{DynamicResource GenButtonBackgroundColor}" hc:IconElement.Geometry="{StaticResource CustomDownload}"
                                                Command="{Binding HistoryDownloadCommand}"/>
                                        <Button Content="清除历史" Style="{StaticResource ButtonPrimary}" Background="{DynamicResource DelButtonBackground}" BorderBrush="{DynamicResource DelButtonBackground}" hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                Command="{Binding CleraHistoryCommand}"/>
                                    </hc:UniformSpacingPanel>
                                </Border>
                                <DataGrid ItemsSource="{Binding ReadWriteHistory}" AutoGenerateColumns="False" Style="{StaticResource DataGrid.Small}"
                                  Background="{DynamicResource DataGridBackgroundColor}" AlternationCount="2"  RowHeight="40" Height="Auto"
                                              CanUserSortColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}"  >
                                            <Setter Property="Background" Value="{StaticResource DataGridHeadBackgroundColor}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Padding" Value="10,0,0,0"/>
                                            <Setter Property="Margin" Value="0,0,12,0"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                            <Setter Property="BorderThickness" Value="1,0,0,1" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
     Color="Transparent"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
     Color="#3D7EFF"/>
                                    </DataGrid.Resources>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                                            <Setter Property="Margin" Value="8,0,12,0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <!-- 前景色跟随行 -->
                                            <Setter Property="Foreground"
Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>

                                            <Style.Triggers>
                                                <!-- 选中 -->
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>

                                                <!-- 选中 + DataGrid失焦（例如右键弹菜单） -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </MultiDataTrigger>

                                                <!-- Hover 时也别盖住整行背景 -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Height" Value="40"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                            <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundColor}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="SnapsToDevicePixels" Value="True" />
                                            <!-- 新增：默认不加粗 -->
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <Trigger Property="AlternationIndex" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource DataGridRowAltBackgroundColor}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Trigger>
                                                <!-- 选中（鼠标不在上面） -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                    <!-- 白字 -->
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <!-- 去掉分割线 -->
                                                </MultiTrigger>

                                                <!-- 选中 + 悬停 -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource LeftTreeViewTitleBackgroundColor}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TabSelectedFontColor}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="读/写" Binding="{Binding ReadWrite}"  Width="70" ElementStyle="{StaticResource CenterCellStyle}"/>
                                        <DataGridTextColumn Header="名称" Binding="{Binding Name}"  Width="*" ElementStyle="{StaticResource CenterCellStyle}"/>
                                        <DataGridTextColumn Header="指令(HEX)" Binding="{Binding Hex}"  Width="120" ElementStyle="{StaticResource CenterCellStyle}"/>
                                        <DataGridTextColumn Header="类型" Binding="{Binding Type}"  Width="*" ElementStyle="{StaticResource CenterCellStyle}"/>
                                        <DataGridTextColumn Header="状态" Binding="{Binding State}"  Width="80" ElementStyle="{StaticResource CenterCellStyle}"/>
                                        <DataGridTextColumn Header="操作时间" Binding="{Binding Datetime}"  Width="*" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>

            </Grid>
        </Border>

    </Grid>
</UserControl>
