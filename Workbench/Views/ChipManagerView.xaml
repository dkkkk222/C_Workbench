<UserControl x:Class="Workbench.Views.ChipManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views"
              xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
              UseLayoutRounding="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="FilePathCellStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <!-- 超出部分显示 “...” -->
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <!-- 悬停显示完整 -->
            <Setter Property="ToolTip" Value="{Binding FilePath}"/>
        </Style>
        <Style x:Key="MenuItemIcon" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style x:Key="FormBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="0,10"/>
        </Style>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
         </Style> 
    </UserControl.Resources>
    <Grid>        
        <Border Grid.Column="1" Background="Transparent" Margin="4,0,0,0" CornerRadius="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="40"></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="40"></RowDefinition>
                </Grid.RowDefinitions>
                <StackPanel Margin="10">
                    <Border Style="{StaticResource FormBorderStyle}" Margin="0,0,35,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="工程名称 : " HorizontalAlignment="Center"  VerticalAlignment="Center" Style="{DynamicResource TitleStyle}"/>
                            <TextBlock Width="10"></TextBlock>
                            <controls:CommonTextBox Text="{Binding ChipName,Mode=TwoWay}" TitleWidth="0" Width="350" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource FormBorderStyle}" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="工程路径 : " HorizontalAlignment="Center"  VerticalAlignment="Center"  Style="{DynamicResource TitleStyle}"/>
                            <TextBlock Width="10"></TextBlock>
                            <controls:CommonTextBox Text="{Binding FilePath,Mode=TwoWay}" Width="350"  TitleWidth="0"/>
                            <Button Grid.Column="1" Margin="8,0,0,0" Padding="4" Command="{Binding BrowseCommand}">
                                <svgc:SvgViewbox Source="pack://application:,,,/Workbench;component/Resource/Images/SVG/open.svg" 
               Height="18"
               VerticalAlignment="Center"
               HorizontalAlignment="Center">
                                </svgc:SvgViewbox>
                                <Button.Resources>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#bee6fd"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
               
                </StackPanel>
                <Border Grid.Row="1">
                    <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                        <!-- 使用样式 -->
                        <Button Style="{StaticResource ConfirmButtonStyle}" Width="80" Height="30"
Content="新增" Command="{Binding AddCommand}"/>
                        <TextBlock Width="10"></TextBlock>
                        <Button Style="{StaticResource ConfirmButtonStyle}" Width="80" Height="30"
                    Content="确认" Command="{Binding ComfirmCommand}"/>
                        <TextBlock Width="10"></TextBlock>
                        <Button Style="{StaticResource CancelButtonStyle}" Width="80" Height="30"
                    Content="取消" Command="{Binding CloseCommand}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Background="#fff" Padding="10">
                    <DataGrid x:Name="DeviceDataGrid"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="LightGray"
                  BorderThickness="0"
                  RowHeaderWidth="0"
                  CanUserResizeRows="False"
                  CanUserSortColumns="False"
                  SelectionMode="Single"
                  RowHeight="40"
                  CanUserAddRows="False"
                  ColumnHeaderHeight="40" IsReadOnly="True"
ItemsSource="{Binding Chips,Mode=TwoWay}" SelectedItem="{Binding SelectedChip, Mode=TwoWay}">                      
                        <!-- 定义列 -->
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="芯片名称" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource CenterCellStyle}"/>
                            <DataGridTextColumn Header="寄存器说明文件" Binding="{Binding FilePath}" Width="*"  ElementStyle="{StaticResource FilePathCellStyle}"/>
                           
                            <DataGridTemplateColumn Header="管理" Width="*" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock Text="修改" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#306CBF"
                                       Cursor="Hand"
                                       Margin="0,0,16,0"
                                       MouseLeftButtonUp="TextBlock_MouseLeftButtonUp"/>

                                            <TextBlock Width="10"></TextBlock>
                                            <Button Width="16"
                                    Height="16"
                                    Padding="0"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Click="Delete_Click">
                                                <TextBlock Text="&#xe690;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource MenuItemIcon}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                        <!-- 表头样式 -->
                        <DataGrid.Resources>
                            <!-- 透明掉单元格选中背景 -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"   Color="Transparent"/>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <!-- 列头样式 -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"                Value="#F5F5F5"/>
                                <Setter Property="BorderBrush"               Value="LightGray"/>
                                <Setter Property="BorderThickness"           Value="0,0,0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment"   Value="Center"/>
                                <Setter Property="FontWeight"                Value="Bold"/>
                            </Style>
                            <!-- 单元格样式 -->
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderBrush"            Value="LightGray"/>
                                <Setter Property="BorderThickness"        Value="0,0,0,1"/>
                                <Setter Property="Padding"                Value="8,0"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Background"             Value="Transparent"/>
                                <Setter Property="Foreground"             Value="Black"/>
                                <Setter Property="FocusVisualStyle"       Value="{x:Null}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <!-- 行样式 -->

                    </DataGrid>
                </Border>
            </Grid>

        </Border>
    </Grid>
</UserControl>
