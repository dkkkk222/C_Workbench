<UserControl x:Class="Workbench.Views.ChipManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             UseLayoutRounding="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="FilePathCellStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <!-- 超出部分显示 “...” -->
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <!-- 悬停显示完整 -->
            <Setter Property="ToolTip" Value="{Binding FilePath}"/>
        </Style>
        <Style x:Key="MenuItemIcon" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style x:Key="FormBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="0,10"/>
        </Style>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border Grid.Column="1" Background="{StaticResource DarkDefaultBrush}" Margin="4,0,0,0" CornerRadius="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="40"></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="40"></RowDefinition>
                </Grid.RowDefinitions>
                <StackPanel Margin="10">
                    <Border Style="{StaticResource FormBorderStyle}" Margin="0,0,35,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBox Text="{Binding ChipName,Mode=TwoWay}" Style="{StaticResource TextBoxExtend}" Width="350" 
                                     hc:InfoElement.Placeholder="请输入芯片名称" hc:InfoElement.Title="芯片名称:" hc:InfoElement.Necessary="True"
                                     hc:InfoElement.TitlePlacement="Left"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource FormBorderStyle}" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <TextBox Text="{Binding FilePath,Mode=TwoWay}" Width="372" Style="{StaticResource TextBoxExtend}"
                                     hc:InfoElement.Placeholder="请输入或选择文件路径" hc:InfoElement.Title="寄存器文件:" hc:InfoElement.Necessary="True"
                                     hc:InfoElement.TitlePlacement="Left"/>
                            <Button Grid.Column="1" Margin="8,0,0,0" Padding="4" Command="{Binding BrowseCommand}">
                                <svgc:SvgViewbox Source="pack://application:,,,/Workbench;component/Resource/Images/SVG/open.svg" 
                                               Height="18"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center">
                                </svgc:SvgViewbox>
                                <Button.Resources>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#bee6fd"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource FormBorderStyle}" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <TextBox Text="{Binding ParseFilePath,Mode=TwoWay}" Width="385" Style="{StaticResource TextBoxExtend}" 
                 hc:InfoElement.Placeholder="请输入或选择文件路径" hc:InfoElement.Title="解析要求文件:" hc:InfoElement.Necessary="True"
                 hc:InfoElement.TitlePlacement="Left"/>
                            <Button Grid.Column="1" Margin="8,0,0,0" Padding="4" Command="{Binding BrowseParseCommand}">
                                <svgc:SvgViewbox Source="pack://application:,,,/Workbench;component/Resource/Images/SVG/open.svg" 
                           Height="18"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center">
                                </svgc:SvgViewbox>
                                <Button.Resources>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#bee6fd"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border Grid.Row="1">
                    <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                        <!-- 使用样式 -->
                        <Button Width="80" Height="30" Content="取消" Command="{Binding CloseCommand}" hc:IconElement.Geometry="{StaticResource CloseGeometry}"/>
                        <!--<TextBlock Width="10"></TextBlock>
                        <Button Style="{StaticResource ButtonPrimary}" Width="80" Height="30" Content="新增" Command="{Binding AddCommand}" 
                                hc:IconElement.Geometry="{StaticResource AddGeometry}" hc:IconElement.Width="13"/>-->
                        <TextBlock Width="10"></TextBlock>
                        <Button Style="{StaticResource ButtonPrimary}" Width="80" Height="30" Content="确认" Command="{Binding ComfirmCommand}" 
                                hc:IconElement.Geometry="{StaticResource SaveGeometry}" hc:IconElement.Width="13"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Padding="10">
                    <DataGrid x:Name="DeviceDataGrid"
                              Style="{StaticResource DataGrid.Small}"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  RowHeaderWidth="0"
                  CanUserResizeRows="False"
                  CanUserSortColumns="False"
                  SelectionMode="Single"
                  RowHeight="40"
                  CanUserAddRows="False"
                  ColumnHeaderHeight="40" IsReadOnly="True"
                              ItemsSource="{Binding Chips,Mode=TwoWay}" SelectedItem="{Binding SelectedChip, Mode=TwoWay}">
                        <!-- 定义列 -->
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="芯片名称" Binding="{Binding Name}" Width="150" />
                            <DataGridTextColumn Header="寄存器说明文件" Binding="{Binding FileName}" Width="*" />
                            <DataGridTextColumn Header="日期" Binding="{Binding Datetime}" Width="*" />
                            <DataGridTemplateColumn Header="管理" Width="150" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                            <!--<TextBlock Text="修改" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Cursor="Hand" Margin="0,0,16,0" MouseLeftButtonUp="TextBlock_MouseLeftButtonUp"/>
                                            <TextBlock Width="10"></TextBlock>
                                            <Button Width="16"
                                                    Height="16"
                                                    Padding="0"
                                                    BorderThickness="0"
                                                    Background="Transparent"
                                                    Click="Delete_Click">
                                                <TextBlock Text="&#xe690;" FontFamily="{StaticResource Iconfont}" Style="{StaticResource MenuItemIcon}"/>
                                            </Button>-->
                                            <hc:UniformSpacingPanel Spacing="10">
                                                <!--<Button Content="修改" Style="{StaticResource ButtonInfo.Small}" hc:IconElement.Geometry="{StaticResource PenGeometry}"/>-->
                                                <Button Content="删除" Style="{StaticResource ButtonDanger.Small}" hc:IconElement.Geometry="{StaticResource TrashGeometry}" Click="Delete_Click"/>
                                            </hc:UniformSpacingPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                    </DataGrid>
                </Border>
            </Grid>

        </Border>
        <Grid Visibility="{calc:Binding Loading,FalseToVisibility=Collapsed}">
            <!--<Border Background="{StaticResource DarkDefaultBrush}" Opacity=".5"></Border>-->
            <!--<hc:LoadingCircle/>-->
        </Grid>
    </Grid>
</UserControl>
