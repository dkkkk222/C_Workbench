<UserControl x:Class="Workbench.Views.GlobalSettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Padding="15" Background="{DynamicResource DialogBackgroundColor}">
        <StackPanel >
            <controls:HomeTitle Title="更新设置"/>
            <Border Padding="15,0,0,0">
                <CheckBox Content="是否检查更新" IsChecked="{Binding IsCheckUpdate}" 
                          VerticalContentAlignment="Center" 
                          Foreground="{DynamicResource PrimaryFontColor}"
                          FontSize="13"/>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
