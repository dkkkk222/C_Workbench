<UserControl x:Class="Workbench.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="TextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleBarColor}"/>
        </Style>
    </UserControl.Resources>
    <Border Padding="15,15,15,5" Background="{DynamicResource TreeViewBackgroundColor}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#999999">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="Transparent">
                        <TextBlock Text="&#xe7dc;" FontFamily="{StaticResource Iconfont}" FontSize="38" Foreground="#2196f3"/>
                    </Border>
                    <Border Grid.Column="1" Padding="20,0,0,0">
                        <StackPanel>
                            <Border Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PPEC Workbench" Style="{DynamicResource TextBlockStyle}"/>
                                    <TextBlock Text="版本：1. 0. 0" Style="{DynamicResource TextBlockStyle}"
                                               FontStyle="Normal"
                                               Margin="25,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Build 2024.6.41723" Style="{DynamicResource TextBlockStyle}" Margin="0,10"/>
                            <TextBlock Text="电话：400-679-8818  拨1" Style="{DynamicResource TextBlockStyle}" Margin="0,10"/>
                            <TextBlock Text="地址：武汉市洪山区东港科技园" Style="{DynamicResource TextBlockStyle}" Margin="0,10"/>
                            <Border Margin="0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="主页：" Style="{DynamicResource TextBlockStyle}"/>
                                    <TextBlock Style="{DynamicResource TextBlockStyle}">
                                        <Hyperlink Style="{DynamicResource HyperlinkStyle}" Command="{Binding OpenWebPageCommand}"
                                                   CommandParameter="http://www.senmuleishi.com">
                                            http://www.senmuleishi.com/
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Margin="0,5">
                        <Button Content="确定" Style="{DynamicResource CommonButtonStyle}" 
                                Command="{Binding CloseCommand}"
                                VerticalAlignment="Top"/>
                    </Border>
                </Grid>
            </Border>
            <Border Grid.Row="1" Background="Transparent" Height="40">
                <TextBlock Text="版权所有 © 2017-2024，武汉森木磊石科技有限公司" FontSize="14"
                           Foreground="{DynamicResource TitleBarColor}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
