<UserControl x:Class="Workbench.Controls.Controls.Scottplot.LiveDataPlot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Controls.Controls.Scottplot"
             mc:Ignorable="d" x:Name="controlPlot"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <ContentControl  Content="{Binding PlotData, Mode=TwoWay, ElementName=controlPlot}" MouseWheel="PlotView_MouseWheel"/>
    </Grid>
</UserControl>
