<UserControl x:Class="Workbench.Controls.Pin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             x:Name="pin"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>

        <Style x:Key="PinTextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="LeftVerticalCheckboxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Border Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="120" Padding="0,0,8,0">
                                    <TextBlock Text="{Binding Name}" HorizontalAlignment="Right" FontSize="13" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="border" Width="30"
                                        Grid.Column="1"
                                        Height="21"
                                        Background="{Binding BackgroundColor}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        BorderBrush="{TemplateBinding BorderBrush}">
                                    <TextBlock x:Name="textBlock" Foreground="{Binding ForegroundColor}"  Text="{Binding Index}" Style="{StaticResource PinTextBlockStyle}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{Binding CheckedBackgroundColor}" TargetName="border"/>
                                <Setter Property="Foreground" Value="{Binding CheckedForegroundColor}" TargetName="textBlock"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RightVerticalCheckboxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Border Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1" Width="120" Padding="8,0,0,0">
                                    <TextBlock Text="{Binding Name}" HorizontalAlignment="Left" FontSize="13" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="border" Width="30"
                                        Grid.Column="0"
                                        Height="21"
                                        Background="{Binding BackgroundColor}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        BorderBrush="{TemplateBinding BorderBrush}">
                                    <TextBlock x:Name="textBlock" Foreground="{Binding ForegroundColor}" Text="{Binding Index}" Style="{StaticResource PinTextBlockStyle}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{Binding CheckedBackgroundColor}" TargetName="border"/>
                                <Setter Property="Foreground" Value="{Binding CheckedForegroundColor}" TargetName="textBlock"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopVerticalCheckboxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Border Padding="0">
                            <Grid Width="21">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Width="120" Height="120" Background="Transparent" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Name}" FontSize="13" Width="120" Height="120">
                                        <TextBlock.LayoutTransform>
                                            <TransformGroup>
                                                <RotateTransform Angle="90" />
                                                <ScaleTransform ScaleX="-1" ScaleY="-1"/>
                                            </TransformGroup>
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>
                                <Border x:Name="border"
                                        Grid.Row="1"
                                        Height="30"
                                        Background="{Binding BackgroundColor}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        BorderBrush="{TemplateBinding BorderBrush}">
                                    <TextBlock x:Name="textBlock" Foreground="{Binding ForegroundColor}"  Text="{Binding Index}" Style="{StaticResource PinTextBlockStyle}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{Binding CheckedBackgroundColor}" TargetName="border"/>
                                <Setter Property="Foreground" Value="{Binding CheckedForegroundColor}" TargetName="textBlock"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BottomVerticalCheckboxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Border Padding="0">
                            <Grid Width="21">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border x:Name="border"
                                        Grid.Row="0"
                                        Height="30"
                                        Background="{Binding BackgroundColor}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        BorderBrush="{TemplateBinding BorderBrush}">
                                    <TextBlock x:Name="textBlock" Foreground="{Binding ForegroundColor}"  Text="{Binding Index}" Style="{StaticResource PinTextBlockStyle}"/>
                                </Border>
                                <Border Grid.Row="1" Background="Transparent" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" Width="120" TextAlignment="Right"  Height="120">
                                        <TextBlock.LayoutTransform>
                                            <TransformGroup>
                                                <RotateTransform Angle="90" />
                                                <ScaleTransform ScaleX="-1" ScaleY="-1"/>
                                            </TransformGroup>
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{Binding CheckedBackgroundColor}" TargetName="border"/>
                                <Setter Property="Foreground" Value="{Binding CheckedForegroundColor}" TargetName="textBlock"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Canvas x:Name="parentCanvas" Height="650" Width="650" Background="Transparent">

                <!--<Canvas x:Name="childCanvas" Height="400" Width="400">
                    <Canvas.Background>
                        <ImageBrush ImageSource="/Resource/Images/ct.png"/>
                    </Canvas.Background>
                </Canvas>-->
                <Border x:Name="childCanvas" Height="333" Width="333" BorderThickness="2" BorderBrush="Black">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="/Resource/Images/Logo/logo.png" Width="250"/>
                        <TextBlock Text="PPEC-86CA3MC2" FontSize="38" Margin="0,50,0,0" FontFamily="楷体" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Top Border -->
                <Border x:Name="topBorder" Canvas.Top="0" Canvas.Left="0">
                    <ItemsControl ItemsSource="{Binding ElementName=pin,Path=TopBorders}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked,Mode=TwoWay}"
                                          Style="{DynamicResource TopVerticalCheckboxStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Bottom Border -->
                <Border x:Name="bottomBorder" Canvas.Top="0" Canvas.Left="0">
                    <ItemsControl ItemsSource="{Binding ElementName=pin,Path=BottomBorders,Mode=TwoWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked,Mode=TwoWay}"
                                          Style="{DynamicResource BottomVerticalCheckboxStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Left Border -->
                <Border x:Name="leftBorder" Canvas.Top="0" Canvas.Left="0">
                    <ItemsControl ItemsSource="{Binding ElementName=pin,Path=LeftSideBorders,Mode=TwoWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked,Mode=TwoWay}"
                                          Style="{DynamicResource LeftVerticalCheckboxStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Right Border -->
                <Border x:Name="rightBorder" Canvas.Top="0" Canvas.Left="0">
                    <ItemsControl ItemsSource="{Binding ElementName=pin,Path=RightSideBorders,Mode=TwoWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked,Mode=TwoWay}"
                                          Style="{DynamicResource RightVerticalCheckboxStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </Canvas>
        </ScrollViewer>


    </Grid>
</UserControl>
