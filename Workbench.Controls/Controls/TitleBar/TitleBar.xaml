<UserControl x:Class="Common.Controls.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             mc:Ignorable="d" 
             x:Name="titleBar"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary Source="pack://application:,,,/Workbench.Controls;component/ControlStyle.xaml"/>
    </UserControl.Resources>
    <Grid>
        <Border Grid.Row="0" x:Name="CustomTitleBar" Style="{DynamicResource TitleBarBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="10,5">
                    <Image Source="/Resource/20240426-165532.ico"/>
                </Border>
                <Border Grid.Column="1">
                    <ContentPresenter Content="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" VerticalAlignment="Center"/>
                </Border>
                        <Border Grid.Column="2"></Border>
                        <Border Grid.Column="3">
                            <StackPanel Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="&#xe646;" Style="{DynamicResource WindowControlButton}" Foreground="{DynamicResource TitleBarIconColor}"
                                        Click="Minimum_Click"
                                        Visibility="{calc:Binding ElementName=titleBar, Path=ShowMaximize, FalseToVisibility=Collapsed}"/>
                        <Button Style="{StaticResource MaximizeButtonStyle}" Click="Maximum_Click"  Foreground="{DynamicResource TitleBarIconColor}"
                                        Visibility="{calc:Binding ElementName=titleBar, Path=ShowMinimize, FalseToVisibility=Collapsed}"/>
                        <Button Content="&#xe653;" Style="{StaticResource WindowCloseButton}" Click="Close_Click"  Foreground="{DynamicResource TitleBarIconColor}" />
                            </StackPanel>
                        </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
