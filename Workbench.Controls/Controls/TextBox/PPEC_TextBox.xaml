<UserControl x:Class="Workbench.Controls.PPEC_TextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Workbench.Controls.TextBox"
             x:Name="tbx"
             mc:Ignorable="d" 
             d:DesignHeight="125" d:DesignWidth="400">
    <Border>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Width="{Binding ElementName=tbx, Path=TitleWidth}" Padding="0,0,10,0">
                <TextBlock Text="{Binding ElementName=tbx, Path=Title}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Column="1">
                <TextBox Text="{Binding ElementName=tbx, Path=Text}"
                         local:TextBoxProperties.IsNumericOnly="True"
                         local:TextBoxProperties.RetainPlaces="{Binding ElementName=tbx,Path=RetainPlaces}"
                         Height="{Binding ElementName=tbx, Path=Height}" 
                         AcceptsReturn="{Binding ElementName=tbx, Path=AcceptsReturn}"
                         TextWrapping="{Binding ElementName=tbx, Path=TextWrapping}"
                         VerticalScrollBarVisibility="{Binding ElementName=tbx, Path=VerticalScrollBarVisibility}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor,AncestorType=TextBox}}"/>
                    </TextBox.InputBindings>
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type TextBox}">
                                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                Background="{TemplateBinding Background}" 
                                                SnapsToDevicePixels="True" 
                                                CornerRadius="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ScrollViewer Grid.Column="0" x:Name="PART_ContentHost" 
                                                              Focusable="false" 
                                                              HorizontalScrollBarVisibility="Hidden" 
                                                              VerticalScrollBarVisibility="Hidden" 
                                                              VerticalAlignment="Center" 
                                                              HorizontalAlignment="Stretch" />
                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding ElementName=tbx, Path=Unit}" 
                                                           VerticalAlignment="Center" 
                                                           Margin="0,0,5,0" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="UIElement.Opacity" Value="0.56"/>
                                </Trigger>
                                <Trigger Property="IsReadOnly" Value="true">
                                    <Setter Property="Background" Value="#F0F0F0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>
        </Grid>
    </Border>
</UserControl>
