<UserControl x:Class="Workbench.Controls.SwitchCommonButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             x:Name="switchButton"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="SwitchStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Background" Value="#f2f2f2"></Setter>
            <Setter Property="Foreground" Value="#ffffff"></Setter>
            <Setter Property="Cursor" Value="Hand"></Setter>
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
            <Setter Property="HorizontalAlignment" Value="Center"></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <!--控件模板-->
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Grid x:Name="grid"  VerticalAlignment="Center" >
                            <Border x:Name="border" Width="40" Height="20" 
                            Background="{TemplateBinding Background}" SnapsToDevicePixels="True"
                            Margin="0,0,0,0" CornerRadius="10" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <!--圆形-->
                                    <Border x:Name="state" Width="16" Height="16" Margin="1" CornerRadius="8" SnapsToDevicePixels="True" VerticalAlignment="Center" 
                                            Background="{TemplateBinding Foreground}">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="transState" X="0"></TranslateTransform>
                                        </Border.RenderTransform>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!--触发器，切换有动画-->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#eff0f1" TargetName="state"/>
                                <Setter Property="Background" Value="#2c2c2c" TargetName="border"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="transState" Storyboard.TargetProperty="X" To="23" Duration="0:0:0.3" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="transState" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.3" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Opacity" Value="0.5" TargetName="border"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <CheckBox HorizontalAlignment="Center" Style="{DynamicResource SwitchStyle}" 
              IsChecked="{Binding ElementName=switchButton, Path=IsChecked, Mode=TwoWay}"
              PreviewMouseDown="CheckBox_PreviewMouseDown"
              VerticalAlignment="Center"/>
    </Grid>
</UserControl>
