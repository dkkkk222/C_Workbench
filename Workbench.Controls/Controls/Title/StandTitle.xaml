<UserControl x:Class="Workbench.Controls.Controls.Title.StandTitle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Workbench.Controls.Controls.Title"
             mc:Ignorable="d"      x:Name="StandTitleControl"
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Orientation="Horizontal">
        <Border   Margin="{Binding BordMargin , ElementName=StandTitleControl}"  Width="{Binding TextWidth, ElementName=StandTitleControl}" Height="{Binding TextHeight, ElementName=StandTitleControl}" Background="{DynamicResource BordTitleBackgroundColor}" VerticalAlignment="Top" HorizontalAlignment="Left"/>

        <TextBlock  Text="{Binding StandText , ElementName=StandTitleControl}" FontWeight="Black" Margin="{Binding TextMargin , ElementName=StandTitleControl}" FontSize="{Binding StandFontSize , ElementName=StandTitleControl}" />
    </StackPanel>
</UserControl>
