<UserControl x:Class="Workbench.SerialAsistant.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Workbench.Controls;assembly=Workbench.Controls"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             FontFamily="Consolas,微软雅黑"
             FontSize="14"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Workbench.SerialAsistant;component/Resource/Style.xaml"/>
                <!-- 你可以在这里添加更多的ResourceDictionary -->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="{DynamicResource TreeViewBackgroundColor}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#999999">
                <ToolBarTray Background="{DynamicResource TreeViewBackgroundColor}">
                    <ToolBar Background="{DynamicResource TreeViewBackgroundColor}">
                        <Button Command="{Binding ConnnetCommand}"
                                IsEnabled="{calc:Binding !IsConnected}">
                            <TextBlock Text="&#xe604;" 
                                       Foreground="#2968af"
                                       FontSize="24"
                                       FontFamily="{StaticResource Iconfont}"/>
                        </Button>
                        <Button Command="{Binding DisconnnetCommand}" 
                                IsEnabled="{calc:Binding IsConnected}">
                            <TextBlock Text="&#xe602;" 
                                       Foreground="#2968af"
                                       FontSize="24"
                                       FontFamily="{StaticResource Iconfont}"/>
                        </Button>
                        <Button  Click="Clear_Click">
                            <TextBlock Text="&#xe61a;" 
                                       Foreground="#2968af"
                                       FontSize="24"
                                       FontFamily="{StaticResource Iconfont}"/>
                        </Button>
                    </ToolBar>
                </ToolBarTray>
            </Border>
            <Border Grid.Row="1" Background="Transparent" Padding="8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="320" Background="Transparent" Padding="0,8,8,8">
                        <StackPanel>
                            <GroupBox Header="串口设置" FontSize="14" BorderThickness="1" BorderBrush="#999999" Foreground="{DynamicResource TitleBarColor}">
                                <Border Padding="15">
                                    <StackPanel>
                                        <controls:PPEC_ComboBox Title="端口类型" 
                                                                Foreground="{DynamicResource TitleBarColor}"
                                                                ItemsSource="{Binding ConnectTypeList,Mode=TwoWay}"
                                                                SelectedItem="{Binding SelectedConnectType,Mode=TwoWay}"
                                                                Margin="{StaticResource CommonMargin}"/>
                                        <Border Visibility="{calc:Binding IsPort,FalseToVisibility=Collapsed}">
                                            <StackPanel>
                                                <controls:PPEC_ComboBox Title="串口"
                                                                        Foreground="{DynamicResource TitleBarColor}"
                                                                        ItemsSource="{Binding SerialPortList,Mode=TwoWay}"
                                                                        SelectedItem="{Binding SelectedSerialPort,Mode=TwoWay}"
                                                                        Margin="{StaticResource CommonMargin}"/>
                                                <controls:PPEC_ComboBox Title="波特率" 
                                                                        Foreground="{DynamicResource TitleBarColor}"
                                                                        ItemsSource="{Binding BaudRateList,Mode=TwoWay}"
                                                                        DisplayMemberPath="Name"
                                                                        SelectedValuePath="Value"
                                                                        SelectedItem="{Binding SelectedBaudRate,Mode=TwoWay}"
                                                                        Margin="{StaticResource CommonMargin}"/>
                                                <controls:PPEC_ComboBox Title="数据位"
                                                                        Foreground="{DynamicResource TitleBarColor}"
                                                                        ItemsSource="{Binding DataBit,Mode=TwoWay}" 
                                                                        SelectedItem="{Binding SelectedDataBit,Mode=TwoWay}"
                                                                        Margin="{StaticResource CommonMargin}"/>
                                                <controls:PPEC_ComboBox Title="停止位" 
                                                                        Foreground="{DynamicResource TitleBarColor}"
                                                                        ItemsSource="{Binding StopBitList,Mode=TwoWay}"
                                                                        DisplayMemberPath="Name"
                                                                        SelectedValuePath="Value"
                                                                        SelectedItem="{Binding SelectedStopBit,Mode=TwoWay}"
                                                                        Margin="{StaticResource CommonMargin}"/>
                                                <controls:PPEC_ComboBox Title="校验位" 
                                                                        Foreground="{DynamicResource TitleBarColor}"
                                                                        ItemsSource="{Binding ParityList,Mode=TwoWay}"
                                                                        DisplayMemberPath="Name"
                                                                        SelectedValuePath="Value"
                                                                        SelectedItem="{Binding SelectedParity,Mode=TwoWay}"
                                                                        Margin="{StaticResource CommonMargin}"/>
                                                <controls:PPEC_TextBox Title="缓冲区" 
                                                                       Foreground="{DynamicResource TitleBarColor}"
                                                                       Text="{Binding BufferLength,Mode=TwoWay}" 
                                                                       Margin="{StaticResource CommonMargin}"/>
                                                <!--<controls:PPEC_ComboBox Title="流控制" 
                                                                        ItemsSource="{Binding FlowControlList,Mode=TwoWay}"
                                                                        DisplayMemberPath="Name"
                                                                        SelectedValuePath="Value"
                                                                        SelectedItem="{Binding SelectedFlowControl,Mode=TwoWay}"
                                                                        Margin="{StaticResource CommonMargin}"/>-->
                                            </StackPanel>
                                        </Border>
                                        <Border Visibility="{calc:Binding !IsPort,FalseToVisibility=Collapsed}">
                                            <StackPanel>
                                                <controls:PPEC_ComboBox Title="Mode"
                                                                        ItemsSource="{Binding TcpMode,Mode=TwoWay}"
                                                                        SelectedItem="{Binding SelectedTcpMode,Mode=TwoWay}"
                                                                        DisplayMemberPath="Name"
                                                                        SelectedValuePath="Value"
                                                                        Margin="{StaticResource CommonMargin}"/>
                                                <Border Visibility="{calc:Binding !IsTcpServer,FalseToVisibility=Collapsed}">
                                                    <controls:PPEC_TextBlock Title="IP地址" 
                                                                           Text="{Binding HostIP,Mode=TwoWay}"
                                                                           Margin="{StaticResource CommonMargin}"/>
                                                </Border>
                                                <controls:PPEC_TextBox Title="端口" 
                                                                       Text="{Binding HostPort,Mode=TwoWay}"
                                                                       Margin="{StaticResource CommonMargin}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                            </GroupBox>
                            <ListView ItemsSource="{Binding ConnectedClients}" 
                                      Visibility="{calc:Binding ShowConnectedClients,FalseToVisibility=Collapsed}"
                                      SelectedItem="{Binding SelectedClientName}"
                                      Margin="0,5,0,0"
                                      Height="200">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Connections" DisplayMemberBinding="{Binding}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <GroupBox Header="接收设置" FontSize="14" BorderThickness="1" BorderBrush="#999999" Margin="0,8,0,0" Foreground="{DynamicResource TitleBarColor}">
                                <Border Padding="15">
                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding ReceiveMessageType}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <RadioButton Content="{Binding Name}"
                                                                 Foreground="{DynamicResource TitleBarColor}"
                                                                 Margin="0,0,55,0"
                                                                 GroupName="ReceiveMessageType"
                                                                 IsChecked="{Binding IsSelected,Mode=TwoWay}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="{StaticResource CommonMargin}"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                        <CheckBox Content="显示发送" Margin="{StaticResource CommonMargin}" IsChecked="{Binding ShowSend,Mode=TwoWay}" Foreground="{DynamicResource TitleBarColor}"/>
                                        <CheckBox Content="显示时间" Margin="{StaticResource CommonMargin}" IsChecked="{Binding ShowTime,Mode=TwoWay}" Foreground="{DynamicResource TitleBarColor}"/>
                                    </StackPanel>
                                </Border>
                            </GroupBox>
                            <GroupBox Header="发送设置" FontSize="14" BorderThickness="1" BorderBrush="#999999" Margin="0,8,0,0" Foreground="{DynamicResource TitleBarColor}">
                                <Border Padding="15">
                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding SendMessageType}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <RadioButton Content="{Binding Name}"
                                                                 Foreground="{DynamicResource TitleBarColor}"
                                                                 Margin="0,0,55,0"
                                                                 GroupName="SendMessageType"
                                                                 IsChecked="{Binding IsSelected,Mode=TwoWay}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </GroupBox>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="Transparent" Padding="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <RichTextBox x:Name="richTextBox" Grid.Row="1"
                                                 IsReadOnly="True"
                                                 Padding="0,5,0,0"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 VerticalScrollBarVisibility="Auto">
                                        <FlowDocument Background="Transparent"></FlowDocument>
                                    </RichTextBox>
                                </Grid>
                            </Border>
                            <Border Grid.Row="1" Height="55" Margin="0,5,0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border>
                                        <TextBox Text="{Binding InputText}"/>
                                    </Border>
                                    <Border Grid.Column="1" Margin="8,0,0,0">
                                        <Button Content="发 送" Width="80"
                                                Height="25"
                                                Command="{Binding SendCommand}"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Background="Transparent"></Border>
                </Grid>
            </Border>
            <Border Grid.Row="2" Height="30" Background="Transparent" 
                    Padding="8,0"
                    BorderThickness="0,1,0,0" 
                    BorderBrush="#999999">
                <StatusBar Background="{DynamicResource TreeViewBackgroundColor}">
                    <StatusBarItem>
                        <TextBlock Text="{Binding StatusStr}" Foreground="{Binding StatusColor}"/>
                    </StatusBarItem>
                    <Border Height="20" BorderThickness="1" Width="1" BorderBrush="#999999" Margin="15,0"/>
                    <StatusBarItem>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Rx: " Foreground="{DynamicResource TitleBarColor}"/>
                            <TextBlock Text="{Binding ReceiveCount}" Margin="3,0" Foreground="{DynamicResource TitleBarColor}"/>
                            <TextBlock Text="Bytes" Foreground="{DynamicResource TitleBarColor}"/>
                        </StackPanel>
                    </StatusBarItem>
                    <Border Height="20" BorderThickness="1" Width="1" BorderBrush="#999999" Margin="15,0"/>
                    <StatusBarItem>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Tx: " Foreground="{DynamicResource TitleBarColor}"/>
                            <TextBlock Text="{Binding SendCount}" Margin="3,0" Foreground="{DynamicResource TitleBarColor}"/>
                            <TextBlock Text="Bytes" Foreground="{DynamicResource TitleBarColor}"/>
                        </StackPanel>
                    </StatusBarItem>
                </StatusBar>
            </Border>
        </Grid>
    </Border>
</UserControl>
